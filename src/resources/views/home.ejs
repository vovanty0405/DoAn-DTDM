                                                                    class="fas fa-star"></i><i
                                                                    class="fas fa-star"></i><i
                                                                    class="fas fa-star-half-alt"></i>
                                                            </div>
                                                            <div
                                                                class="d-flex justify-content-center align-items-center gap-3 mt-2">
                                                                <% if (product.stock_quantity> 0) { %>
                                                                    <a href="javascript:void(0);"
                                                                        onclick="addToCart('<%= product._id %>')"
                                                                        class="text-tempi-green transition-zoom"
                                                                        title="Thêm vào giỏ hàng">
                                                                        <i class="fas fa-cart-plus fs-4"></i>
                                                                    </a>
                                                                    <a href="/cart/buy-now/<%= product._id %>"
                                                                        class="btn btn-tempi-green flex-grow-1 text-white rounded-pill text-decoration-none text-center fw-bold shadow-sm">
                                                                        Mua ngay
                                                                    </a>
                                                                    <% } else { %>
                                                                        <a href="/product/<%= product._id %>"
                                                                            class="btn btn-secondary flex-grow-1 rounded-pill text-white text-decoration-none text-center fw-bold opacity-75">
                                                                            <i class="fas fa-clock me-1"></i> Hết hàng
                                                                        </a>
                                                                        <% } %>
                                                            </div>
                                            </div>
                            </div>
                        </div>
                        <% }) %>
                            <% } else { %>
                                <p class="text-center text-muted w-100">Chưa có gợi ý nào dành cho bạn.</p>
                                <% } %>
            </div>

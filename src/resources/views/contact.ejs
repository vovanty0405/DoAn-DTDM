<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Liên Hệ - Bách Hóa Pew</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="/css/style.css" rel="stylesheet" />
</head>

<body class="bg-light">
    <!-- Header -->
    <%- include('partials/navbar') %>

        <div class="container-fluid bg-tempi-green text-white py-5 text-center">
            <h1 class="fw-bold display-4 text-dark">Liên Hệ Với Chúng Tôi</h1>
            <p class="lead text-dark">Gửi thắc mắc, phản hồi hoặc yêu cầu hỗ trợ</p>
        </div>

        <div class="container my-5">
            <div class="row align-items-start">
                <!-- Cột Form Liên Hệ -->
                <div class="col-md-6 mb-4 mb-md-0 d-flex">
                    <div class="card border-0 shadow-sm w-100 p-4">
                        <h3 class="fw-bold mb-4 text-warning">Gửi tin nhắn</h3>

                        <% if (typeof contactSuccess !=='undefined' && contactSuccess) { %>
                            <div class="alert alert-success alert-dismissible fade show" role="alert">
                                <i class="fas fa-check-circle me-2"></i><strong>Thành công!</strong>
                                <%= contactSuccess %>
                                    <button type="button" class="btn-close" data-bs-dismiss="alert"
                                        aria-label="Close"></button>
                            </div>
                            <% } %>

                                <form action="/contact/store" method="POST">
                                    <div class="mb-3">
                                        <label class="form-label fw-semibold">Họ và tên của bạn</label>
                                        <input type="text" name="name" class="form-control" placeholder="Nhập họ và tên"
                                            required value="<%= user ? (user.fullname || user.full_name) : '' %>">
                                    </div>
                                    <div class="mb-3">
                                        <label class="form-label fw-semibold">Email liên hệ</label>
                                        <input type="email" name="email" class="form-control"
                                            placeholder="Địa chỉ email" required value="<%= user ? user.email : '' %>">
                                    </div>
                                    <div class="mb-3">
                                        <label class="form-label fw-semibold">Tiêu đề</label>
                                        <input type="text" name="title" class="form-control"
                                            placeholder="Tóm tắt vấn đề của bạn" required>
                                    </div>
                                    <div class="mb-4">
                                        <label class="form-label fw-semibold">Nội dung chi tiết</label>
                                        <textarea name="content" class="form-control" rows="5"
                                            placeholder="Hãy mô tả chi tiết để chúng tôi hỗ trợ tốt nhất nhé"
                                            required></textarea>
                                    </div>
                                    <button type="submit" class="btn btn-warning fw-bold w-100 py-2"> GỬI YÊU CẦU <i
                                            class="fas fa-paper-plane ms-2"></i></button>
                                </form>
                    </div>
                </div>

                <!-- Cột Bản đồ và Thông tin -->
                <div class="col-md-6 d-flex flex-column gap-4">
                    <div class="card border-0 shadow-sm p-4 h-100">
                        <h4 class="fw-bold text-success mb-4"><i class="fas fa-building me-2"></i> Trụ sở chính</h4>
                        <p class="mb-2"><i class="fas fa-map-marker-alt text-danger me-2" style="width: 20px;"></i> 18
                            Ung Văn Khiêm, P. Đông Xuyên, TP. Long Xuyên, Tỉnh An Giang</p>
                        <p class="mb-2"><i class="fas fa-phone-alt text-success me-2" style="width: 20px;"></i> Tổng
                            đài: <strong>1900 1000</strong></p>
                        <p class="mb-2"><i class="fas fa-envelope text-primary me-2" style="width: 20px;"></i>
                            cskh@bachhoapew.com</p>
                        <hr class="my-4">
                        <iframe
                            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3924.6265442263393!2d105.43105995788002!3d10.371715699563184!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x310a731e7546fd7b%3A0x953539cd7673d9e5!2zVHLGsOG7nW5nIMSQ4bqhaSBI4buNYyBBbiBHaWFuZyAtIMSQ4bqhaSBI4buNYyBRdeG7kWMgR2lhIFRow6BuaCBQaOG7kSBI4buTIENow60gTWluaA!5e0!3m2!1svi!2s"
                            width="100%" height="100%" style="border:0; min-height: 250px; border-radius: 8px;"
                            allowfullscreen="" loading="lazy"></iframe>
                    </div>
                </div>
            </div>
        </div>

        <!-- Footer -->
        <%- include('partials/footer') %>
            <!-- Modal -->
            <%- include('partials/modal') %>

                <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>

<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Thanh toán - Bách Hóa Pew</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/style.css">
    <link href="/css/style.css" rel="stylesheet" />
</head>

<body class="bg-light">
    <%- include('partials/navbar') %>

        <section class="container my-5">
            <nav aria-label="breadcrumb" class="mb-4">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="/cart" class="text-decoration-none">Giỏ hàng</a></li>
                    <li class="breadcrumb-item active">Thanh toán</li>
                </ol>
            </nav>

            <form action="/checkout/place-order" method="POST" id="checkoutForm">
                <!-- Truyền mã đơn hàng ID giả lập -->
                <input type="hidden" name="order_id" value="<%= typeof newOrderId !== 'undefined' ? newOrderId : '' %>">

                <div class="row">
                    <div class="col-lg-7 mb-4">
                        <div class="card shadow-sm border-0 p-4">
                            <h4 class="fw-bold mb-4"><i class="fas fa-truck me-2 text-success"></i>Thông tin giao hàng
                            </h4>

                            <input type="hidden" name="shipping_fee" id="shippingFeeInput" value="0">
                            <div class="mb-3">
                                <label class="form-label fw-semibold">Họ và tên người nhận</label>
                                <input type="text" name="fullname" class="form-control py-2"
                                    value="<%= user ? user.fullname : '' %>" required
                                    placeholder="Nhập họ tên người nhận">
                            </div>

                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label class="form-label fw-semibold">Số điện thoại</label>
                                    <input type="tel" name="phone" class="form-control py-2"
                                        value="<%= user ? user.phone : '' %>" required
                                        placeholder="Số điện thoại liên lạc">
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label class="form-label fw-semibold">Phương thức thanh toán</label>
                                    <select name="payment_method" class="form-select py-2 border-primary" required>
                                        <option value="Tiền mặt (COD)">Thanh toán khi nhận hàng (COD)</option>
                                        <option value="Chuyển khoản">Chuyển khoản ngân hàng (Thủ công)</option>
                                        <option value="VietQR" class="fw-bold text-primary">Thanh toán qua mã QR
                                            (VietQR)</option>
                                    </select>
                                </div>
                            </div>

                            <div class="mb-3 address-group">
                                <label class="form-label fw-semibold">Địa chỉ giao hàng cụ thể</label>
                                <div class="row mb-2">
                                    <div class="col-sm-4 mb-2 mb-sm-0">
                                        <select class="form-select province" required>
                                            <option value="">Tỉnh/Thành phố</option>
                                        </select>
                                    </div>
                                    <div class="col-sm-4 mb-2 mb-sm-0">
                                        <select class="form-select district" required>
                                            <option value="">Quận/Huyện</option>
                                        </select>
                                    </div>
                                    <div class="col-sm-4">
                                        <select class="form-select ward" required>
                                            <option value="">Phường/Xã</option>
                                        </select>
                                    </div>
                                </div>
                                <input type="text" class="form-control py-2 street"
                                    placeholder="Số nhà, tên đường cụ thể">
                                <input type="hidden" name="address" class="address-hidden"
                                    value="<%= user ? user.address : '' %>">
                            </div>
                        </div>
                    </div>
                    <!-- Section Đơn hàng của bạn -->
                    <div class="col-lg-5">
                        <div class="card shadow-sm border-0 p-4 sticky-top" style="top: 100px; z-index: 10;">
                            <h4 class="fw-bold mb-4">Đơn hàng của bạn</h4>

                            <div class="order-items mb-4" style="max-height: 300px; overflow-y: auto;">
                                <% carts.forEach(item=> { %>
                                    <div
                                        class="d-flex justify-content-between align-items-center mb-3 pb-3 border-bottom">
                                        <div class="d-flex align-items-center">
                                            <img src="/<%= item.product_id.cover_image %>" alt=""
                                                style="width: 50px; height: 50px; object-fit: contain;"
                                                class="rounded border me-3">
                                            <div>
                                                <div class="fw-bold small" style="max-width: 180px;">
                                                    <%= item.product_id.name %>
                                                </div>
                                                <div class="text-muted small">Số lượng: x<%= item.quantity %>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="fw-bold text-danger">
                                            <%= ((item.product_id.discount_price || item.product_id.price) *
                                                item.quantity).toLocaleString('vi-VN') %> đ
                                        </div>
                                    </div>
                                    <% }) %>
                            </div>

                            <div class="d-flex justify-content-between mb-2">
                                <span class="text-muted">Tạm tính:</span>
                                <span class="fw-semibold">
                                    <%= totalMoney.toLocaleString('vi-VN') %> đ
                                </span>
                            </div>
                            <div class="d-flex justify-content-between mb-4">
                                <span class="text-muted">Phí vận chuyển:</span>
                                <span class="text-success fw-bold" id="shippingFeeDisplay">0 đ</span>
                            </div>

                            <hr>
                            <div class="d-flex justify-content-between mb-4">
                                <span class="fs-5 fw-bold">Tổng Thanh Toán:</span>
                                <span class="fs-4 fw-bold text-danger" id="totalMoneyDisplay"
                                    data-value="<%= totalMoney %>">
                                    <%= totalMoney.toLocaleString('vi-VN') %> đ
                                </span>
                            </div>

                            <button type="submit"
                                class="btn btn-warning w-100 py-3 fw-bold fs-5 rounded-pill shadow-sm">
                                XÁC NHẬN ĐẶT HÀNG
                            </button>
                        </div>
                    </div>
                </div>
            </form>

            <!-- QR Code Modal cho VietQR -->
            <div class="modal fade" id="qrModal" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1"
                aria-labelledby="qrModalLabel" aria-hidden="true">
                <div class="modal-dialog modal-dialog-centered">
                    <div class="modal-content">
                        <div class="modal-header bg-primary text-white">
                            <h5 class="modal-title" id="qrModalLabel"><i class="fas fa-qrcode me-2"></i>Thanh Toán
                                VietQR</h5>
                            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"
                                aria-label="Close"></button>
                        </div>
                        <div class="modal-body text-center py-4">
                            <p class="mb-3 text-muted">Vui lòng quét mã QR dưới đây qua ứng dụng Mobile Banking hoặc
                                ZaloPay để thanh toán tự động.</p>

                            <!-- Container chứa ảnh mã QR -->
                            <div class="bg-light p-3 rounded d-inline-block shadow-sm mb-3">
                                <img id="qrCodeImage" src="" alt="Mã QR Thanh Toán" class="img-fluid"
                                    style="min-width: 250px; min-height: 250px; max-width: 300px;">
                            </div>

                            <div class="text-start bg-light p-3 rounded small">
                                <div class="mb-1"><strong>Ngân hàng:</strong> Vietcombank</div>
                                <div class="mb-1"><strong>Chủ TK:</strong> BACH HOA PEW</div>
                                <div class="mb-1"><strong>Số TK:</strong> <span
                                        class="text-primary fw-bold">1041092680</span></div>
                                <div class="mb-1"><strong>Số tiền:</strong> <span class="text-danger fw-bold">
                                        <%= totalMoney.toLocaleString('vi-VN') %> đ
                                    </span></div>
                                <div class="mb-1"><strong>Nội dung chuyền:</strong> <span
                                        class="text-success fw-bold">DH<%= typeof newOrderId !=='undefined' ?
                                            newOrderId.toString().slice(-6).toUpperCase() : '123' %></span></div>
                            </div>
                        </div>
                        <div class="modal-footer justify-content-center">
                            <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Hủy
                                bỏ</button>
                            <button type="button" class="btn btn-success fw-bold px-4" id="btnConfirmPaid"><i
                                    class="fas fa-check-circle me-1"></i>Đã Thanh Toán</button>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <%- include('partials/footer') %>

            <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
            <script>
                // Logic Auto Load Province API và Auto Fill Địa chỉ
                document.addEventListener('DOMContentLoaded', function () {
                    const addressGroups = document.querySelectorAll('.address-group');
                    addressGroups.forEach(group => {
                        const provinceSel = group.querySelector('.province');
                        const districtSel = group.querySelector('.district');
                        const wardSel = group.querySelector('.ward');
                        const streetInp = group.querySelector('.street');
                        const hiddenInp = group.querySelector('.address-hidden');

                        // Lấy dữ liệu địa chỉ cũ để auto fill
                        const fullAddress = hiddenInp.value;
                        let defaultProv = '', defaultDist = '', defaultWard = '', defaultStreet = '';
                        if (fullAddress) {
                            const parts = fullAddress.split(',').map(s => s.trim());
                            const len = parts.length;
                            
                            // Nếu có từ 3 phần trở lên (Tối thiểu phải có: Phường/Xã, Quận/Huyện, Tỉnh/Thành)
                            if (len >= 3) {
                                defaultProv = parts[len - 1]; // Tỉnh/Thành luôn ở cuối
                                defaultDist = parts[len - 2]; // Quận/Huyện áp chót
                                defaultWard = parts[len - 3]; // Phường/Xã trước Quận/Huyện
                                
                                // Nếu có nhiều hơn 3 phần, toàn bộ phần đầu tiên sẽ là số nhà/tên đường
                                if (len > 3) {
                                    defaultStreet = parts.slice(0, len - 3).join(', ');
                                }
                            } else {
                                // Fallback nếu người dùng ghi quá vắn tắt
                                defaultStreet = fullAddress; 
                            }
                        }

                        // Hàm hỗ trợ chọn option theo text
                        function selectOptionByText(selectEl, text) {
                            if (!text) return false;
                            const lowerText = text.toLowerCase();
                            for (let i = 0; i < selectEl.options.length; i++) {
                                if (selectEl.options[i].text.toLowerCase() === lowerText ||
                                    selectEl.options[i].text.toLowerCase().includes(lowerText)) {
                                    selectEl.selectedIndex = i;
                                    return true;
                                }
                            }
                            return false;
                        }

                        // Điền sẵn số nhà
                        if (defaultStreet) streetInp.value = defaultStreet;

                        // Lấy danh sách tỉnh thành
                        fetch('https://provinces.open-api.vn/api/p/')
                            .then(res => res.json())
                            .then(data => {
                                data.forEach(item => {
                                    provinceSel.innerHTML += `<option value="${item.code}">${item.name}</option>`;
                                });
                                // Tự động chọn Tỉnh
                                if (defaultProv && selectOptionByText(provinceSel, defaultProv)) {
                                    provinceSel.dispatchEvent(new Event('change')); // Trigger load Huyện
                                }
                            })
                            .catch(err => console.error("Lấy tỉnh không thành công:", err));

                        provinceSel.addEventListener('change', function () {
                            districtSel.innerHTML = '<option value="">Quận/Huyện</option>';
                            wardSel.innerHTML = '<option value="">Phường/Xã</option>';
                            if (this.value) {
                                fetch(`https://provinces.open-api.vn/api/p/${this.value}?depth=2`)
                                    .then(res => res.json())
                                    .then(data => {
                                        if (data.districts) {
                                            data.districts.forEach(item => {
                                                districtSel.innerHTML += `<option value="${item.code}">${item.name}</option>`;
                                            });
                                            // Tự động chọn Huyện (chỉ chạy lần đầu load trang nếu có default)
                                            if (defaultDist && selectOptionByText(districtSel, defaultDist)) {
                                                defaultDist = ''; // Xóa để không auto fill nếu user tự đổi tỉnh
                                                districtSel.dispatchEvent(new Event('change'));
                                            }
                                        }
                                    });
                            }
                            updateAddress();
                        });

                        districtSel.addEventListener('change', function () {
                            wardSel.innerHTML = '<option value="">Phường/Xã</option>';
                            if (this.value) {
                                fetch(`https://provinces.open-api.vn/api/d/${this.value}?depth=2`)
                                    .then(res => res.json())
                                    .then(data => {
                                        if (data.wards) {
                                            data.wards.forEach(item => {
                                                wardSel.innerHTML += `<option value="${item.code}">${item.name}</option>`;
                                            });
                                            // Tự động chọn Phường (chỉ chạy lần đầu load trang)
                                            if (defaultWard && selectOptionByText(wardSel, defaultWard)) {
                                                defaultWard = '';
                                            }
                                        }
                                    });
                            }
                            updateAddress();
                        });

                        wardSel.addEventListener('change', updateAddress);
                        streetInp.addEventListener('input', updateAddress);

                        function updateAddress() {
                            let parts = [];
                            if (streetInp.value.trim()) parts.push(streetInp.value.trim());
                            if (wardSel.value) parts.push(wardSel.options[wardSel.selectedIndex].text);
                            if (districtSel.value) parts.push(districtSel.options[districtSel.selectedIndex].text);
                            if (provinceSel.value) parts.push(provinceSel.options[provinceSel.selectedIndex].text);
                            hiddenInp.value = parts.join(', ');
                        }

                        const form = group.closest('form');
                        if (form) {
                            form.addEventListener('submit', updateAddress);
                        }
                    });
                });

                // Logic Xử lý phí vận chuyển từ Product Detail
                document.addEventListener('DOMContentLoaded', function () {
                    const savedFee = localStorage.getItem('shipping_fee');
                    if (savedFee) {
                        const fee = parseInt(savedFee) || 0;
                        const shippingFeeDisplay = document.getElementById('shippingFeeDisplay');
                        const shippingFeeInput = document.getElementById('shippingFeeInput');
                        const totalMoneyDisplay = document.getElementById('totalMoneyDisplay');
                        
                        if (shippingFeeDisplay) shippingFeeDisplay.innerText = fee.toLocaleString('vi-VN') + ' đ';
                        if (shippingFeeInput) shippingFeeInput.value = fee;
                        
                        if (totalMoneyDisplay) {
                            const subTotal = parseInt(totalMoneyDisplay.dataset.value) || 0;
                            const finalTotal = subTotal + fee;
                            totalMoneyDisplay.innerText = finalTotal.toLocaleString('vi-VN') + ' đ';
                            totalMoneyDisplay.dataset.value = finalTotal;
                        }
                        
                        // Xóa sau khi dùng để tránh nhầm lẫn cho đơn sau
                        localStorage.removeItem('shipping_fee');
                    }
                });

                // Logic Xử lý Modal Thanh toán VietQR
                document.addEventListener('DOMContentLoaded', function () {
                    const checkoutForm = document.getElementById('checkoutForm');
                    const qrModalEl = document.getElementById('qrModal');
                    const btnConfirmPaid = document.getElementById('btnConfirmPaid');
                    const qrCodeImage = document.getElementById('qrCodeImage');
                    const paymentSelect = document.querySelector('select[name="payment_method"]');

                    let qrModal = null;
                    if (qrModalEl && typeof bootstrap !== 'undefined') {
                        qrModal = new bootstrap.Modal(qrModalEl);
                    }

                    checkoutForm.addEventListener('submit', function (e) {
                        // Nếu chọn VietQR và chưa confirm qua modal
                        if (paymentSelect && paymentSelect.value === 'VietQR' && checkoutForm.dataset.qrConfirmed !== 'true') {
                            e.preventDefault(); // Chặn việc submit mặc định

                            if (!qrModal) {
                                alert("Không thể tải mã QR, vui lòng F5 trang gốc lại nhé!");
                                return;
                            }

                            // Lấy các tham số cấu hình thanh toán
                            const amountDisplay = document.getElementById('totalMoneyDisplay');
                            const amount = amountDisplay ? amountDisplay.dataset.value : 0;
                            const addInfo = 'DH<%= typeof newOrderId !== "undefined" ? newOrderId.toString().slice(-6).toUpperCase() : "123" %>';
                            const accountName = 'BACH HOA PEW';
                            const bankId = 'VCB'; // Tuỳ chỉnh thành Vietcombank
                            const accountNo = '1041092680'; // STK mà bạn đã sửa
                            const template = 'compact2';

                            // API VietQR: https://img.vietqr.io/image/<BANK_ID>-<ACCOUNT_NO>-<TEMPLATE>.png?amount=<AMOUNT>&addInfo=<DESCRIPTION>&accountName=<ACCOUNT_NAME>
                            const qrUrl = `https://img.vietqr.io/image/${bankId}-${accountNo}-${template}.png?amount=${amount}&addInfo=${addInfo}&accountName=${encodeURIComponent(accountName)}`;

                            // Cập nhật ảnh mã QR
                            if (qrCodeImage) qrCodeImage.src = qrUrl;

                            // Hiển thị Modal
                            qrModal.show();
                        }
                    });

                    // Khi người dùng bấm "Đã thanh toán"
                    if (btnConfirmPaid) {
                        btnConfirmPaid.addEventListener('click', function () {
                            // Đánh dấu form đã xác nhận qua modal
                            checkoutForm.dataset.qrConfirmed = 'true';
                            if (qrModal) qrModal.hide();

                            // Kích hoạt submit form 
                            checkoutForm.submit();
                        });
                    }
                });
            </script>
</body>

</html>

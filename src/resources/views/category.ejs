<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= currentCategory.name %> - Bách Hóa Pew
    </title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/style.css">
    <link href="/css/style.css" rel="stylesheet" />
    <style>
        .scroll-horizontal {
            display: flex;
            overflow-x: auto;
            gap: 15px;
            padding-bottom: 10px;
            scrollbar-width: none;
        }

        .scroll-horizontal::-webkit-scrollbar {
            display: none;
        }

        .subcat-item {
            min-width: 100px;
            text-align: center;
            cursor: pointer;
        }

        .subcat-img-wrapper {
            width: 90px;
            /* ĐÃ TĂNG SIZE TỪ 70px LÊN 90px */
            height: 90px;
            margin: 0 auto 10px auto;
            border-radius: 20px;
            background-color: #f1f3f5;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
            border: 2px solid #e9ecef;
            transition: 0.2s;
        }

        .subcat-img-wrapper img {
            width: 100%;
            height: 100%;
            object-fit: contain;
            padding: 5px;
        }

        /* Tô viền xanh cho Thể loại con đang được chọn */
        .subcat-item.active .subcat-img-wrapper {
            border-color: var(--tempi-green);
            background-color: #e6f2ee;
        }

        .subcat-item.active span {
            color: var(--tempi-green) !important;
            font-weight: bold;
        }

        .brand-btn {
            white-space: nowrap;
            border: 1px solid #e0e0e0;
            color: #333;
            background: white;
            transition: 0.2s;
        }

        .brand-btn:hover {
            border-color: var(--tempi-green);
            color: var(--tempi-green);
        }

        /* Tô nền xanh cho Hãng đang được chọn */
        .brand-btn.active {
            background-color: var(--tempi-green);
            color: white;
            border-color: var(--tempi-green);
        }
    </style>
</head>

<body>
    <!-- Header -->
    <%- include('partials/navbar') %>

        <div class="container my-3" id="category-filter-area">
            <% 
                // Tạo object query để giữ các filter khi chuyển trang hoặc đổi filter khác
                let query = {};
                if (typeof activeSubcat !== 'undefined' && activeSubcat) query.subcat = activeSubcat;
                if (typeof activeBrand !== 'undefined' && activeBrand) query.brand = activeBrand;
                if (typeof activeMinPrice !== 'undefined' && activeMinPrice) query.minPrice = activeMinPrice;
                if (typeof activeMaxPrice !== 'undefined' && activeMaxPrice) query.maxPrice = activeMaxPrice;
                if (typeof activeSort !== 'undefined' && activeSort) query.sort = activeSort;
            %>
            <div id="filter-loading-overlay" class="d-none position-absolute top-0 start-0 w-100 h-100 bg-white opacity-50 d-flex justify-content-center align-items-center" style="z-index: 1000; min-height: 500px;">
                <div class="spinner-border text-tempi-green" role="status"></div>
            </div>
            <% if (subCategories && subCategories.length> 0) { %>
                <div class="scroll-horizontal mb-4 mt-3 filter-scroll-area">
                    <a href="/category/<%= currentCategory.slug %>?<%= new URLSearchParams({...query, subcat: '', page: 1}).toString() %>" class="text-decoration-none ajax-filter-link">
                        <div
                            class="subcat-item <%= !activeSubcat ? 'active' : '' %>">
                            <div class="subcat-img-wrapper">
                                <img src="https://cdn-icons-png.flaticon.com/512/679/679821.png" alt="Tất cả">
                            </div>
                            <span class="small fw-semibold text-dark">Tất cả</span>
                        </div>
                    </a>

                    <% subCategories.forEach(sc=> { %>
                        <a href="/category/<%= currentCategory.slug %>?<%= new URLSearchParams({...query, subcat: sc._id, page: 1}).toString() %>"
                            class="text-decoration-none ajax-filter-link">
                            <div
                                class="subcat-item <%= (activeSubcat == sc._id) ? 'active' : '' %>">
                                <div class="subcat-img-wrapper">
                                    <img src="<%= sc.image ? '/' + sc.image : 'https://cdn-icons-png.flaticon.com/512/679/679821.png' %>"
                                        alt="<%= sc.name %>">
                                </div>
                                <span class="small fw-semibold text-dark text-truncate-2" style="font-size: 0.85rem;">
                                    <%= sc.name %>
                                </span>
                            </div>
                        </a>
                        <% }) %>
                </div>
                <% } %>
                    <% if (brands && brands.length> 0) { %>
                        <div class="d-flex align-items-center mb-3">
                            <i class="fas fa-filter text-muted me-3"></i>
                            <div class="scroll-horizontal flex-grow-1 filter-scroll-area" style="padding-bottom: 0;">
                                <!-- Nút tất cả hãng -->
                                <a href="?<%= new URLSearchParams({...query, brand: '', page: 1}).toString() %>" class="text-decoration-none ajax-filter-link">
                                    <button
                                        class="btn rounded-pill px-4 py-1 brand-btn fw-semibold shadow-sm <%= !activeBrand ? 'active' : '' %>">
                                        Tất cả hãng
                                    </button>
                                </a>

                                <% brands.forEach(b=> { %>
                                    <a href="?<%= new URLSearchParams({...query, brand: b._id, page: 1}).toString() %>"
                                        class="text-decoration-none ajax-filter-link">
                                        <button
                                            class="btn rounded-pill px-4 py-1 brand-btn fw-semibold shadow-sm <%= (activeBrand == b._id) ? 'active' : '' %>">
                                            <%= b.name %>
                                        </button>
                                    </a>
                                    <% }) %>
                            </div>
                        </div>
                        <% } %>

                            <!-- Lọc theo giá -->
                            <div class="d-flex align-items-center mb-4">
                                <i class="fas fa-coins text-muted me-3"></i>
                                <div class="scroll-horizontal flex-grow-1 filter-scroll-area" style="padding-bottom: 5px;">
                                    <% 
                                        const priceRanges = [
                                            { label: 'Tất cả giá', min: '', max: '' },
                                            { label: 'Dưới 100k', min: 0, max: 100000 },
                                            { label: '100k - 500k', min: 100000, max: 500000 },
                                            { label: '500k - 1tr', min: 500000, max: 1000000 },
                                            { label: 'Trên 1tr', min: 1000000, max: 99999999 }
                                        ];
                                    %>
                                    <% priceRanges.forEach(range => { %>
                                        <a href="?<%= new URLSearchParams({...query, minPrice: range.min, maxPrice: range.max, page: 1}).toString() %>" class="text-decoration-none ajax-filter-link">
                                            <button class="btn rounded-pill px-3 py-1 brand-btn fw-semibold shadow-sm <%= (activeMinPrice == range.min && activeMaxPrice == range.max) ? 'active' : '' %>">
                                                <%= range.label %>
                                            </button>
                                        </a>
                                    <% }) %>
                                </div>
                            </div>

                            <% 
            // KHAI BÁO ẢNH BANNER THEO SLUG
            const catBanners = {
                'rau-cu': '/image/Banner/freecompress-trang-cate-pc_phieugiamgia.jpg',
                'nuoc-ngot': '/image/Banner/freecompress-trang-cate-pc_tuigao.jpg',
                'my-mien-chao-pho': '/image/Banner/freecompress-trang-cate-pc_my.png',
                'do-gia-dung': '/image/Banner/banner-do-giadung.jpg',
                'do-hop': '/image/Banner/freecompress-trang-cate-pc_dohop.jpg',
                'banh-keo': '/image/Banner/cate-pc-compressed_nuocgiat.jpg',
            };
            // Nếu không có banner riêng, dùng banner mặc định này
            let bannerSrc = catBanners[currentCategory.slug] || 'https://via.placeholder.com/1200x200?text=Banner+Sieu+Giam+Gia';
        %>

                            <div class="mb-2 text-center">
                                <img src="<%= bannerSrc %>" alt="Banner <%= currentCategory.name %>"
                                    class="img-fluid rounded-3 shadow-sm w-100"
                                    style="object-fit: cover; max-height: 250px;">
                            </div>

                            <% if (saleProducts && saleProducts.length> 0) { %>
                                <div class="bg-danger rounded-4 p-4 mb-5 shadow-lg position-relative">
                                    <div class="d-flex justify-content-between align-items-center mb-4">
                                        <h3 class="text-white fw-bold fst-italic m-0"><i
                                                class="fas fa-bolt text-warning me-2"></i> KHUYẾN MÃI SỐC</h3>
                                    </div>

                                    <div class="row">
                                        <% saleProducts.forEach(product=> { %>
                                            <div class="col-6 col-md-3 mb-4">
                                                <div
                                                    class="card product-card h-100 border-0 shadow-sm position-relative">
                                                    <% let percent=Math.round(((product.price - product.discount_price)
                                                        / product.price) * 100); %>
                                                        <div class="badge-discount position-absolute top-0 end-0 m-2 bg-danger text-white px-2 py-1 rounded"
                                                            style="z-index: 10;">
                                                            -<%= percent %>%
                                                        </div>
                                                        <a href="/product/<%= product._id %>"
                                                            class="text-decoration-none">
                                                            <div class="product-img-wrapper">
                                                                <img src="/<%= product.cover_image %>"
                                                                    alt="<%= product.name %>" class="img-cover">
                                                            </div>
                                                        </a>
                                                        <div class="card-body text-center p-3">
                                                            <h6 class="card-title fw-bold text-dark text-truncate-2"
                                                                style="font-size: 0.9rem; min-height: 38px;">
                                                                <%= product.name %>
                                                            </h6>
                                                            <div class="text-muted text-decoration-line-through small">
                                                                <%= product.price.toLocaleString('vi-VN') %> đ
                                                            </div>
                                                            <div class="fw-bold text-danger fs-5 mb-2">
                                                                <%= product.discount_price.toLocaleString('vi-VN') %> đ
                                                            </div>

                                                            <div class="progress mb-2"
                                                                style="height: 18px; border-radius: 50px; background-color: #fef0cd;">
                                                                <% let stockPercent=(product.stock_quantity <=100) ?
                                                                    product.stock_quantity : 50; %>
                                                                    <div class="progress-bar bg-warning text-dark fw-bold"style="width: <%= stockPercent %>%; font-size: 0.7rem; line-height: 18px;">
                                                                        Còn <%= product.stock_quantity %>
                                                                    </div>
                                                            </div>

                                                            <div
                                                                class="d-flex justify-content-center align-items-center gap-2 mt-2">
                                                                <a href="javascript:void(0);"
                                                                    onclick="addToCart('<%= product._id %>')"
                                                                    class="text-tempi-green transition-zoom"
                                                                    title="Thêm vào giỏ hàng">
                                                                    <i class="fas fa-cart-plus fs-4"></i>
                                                                </a>
                                                                <a href="/cart/buy-now/<%= product._id %>"
                                                                    class="btn btn-warning flex-grow-1 text-dark rounded-pill text-decoration-none text-center fw-bold shadow-sm btn-sm">
                                                                    Mua ngay
                                                                </a>
                                                            </div>
                                                        </div>
                                                </div>
                                            </div>
                                            <% }) %>
                                    </div>
                                </div>
                                <% } %>
                                    <section class="container mb-4">
                                        <img src="/image/Banner/freecompress-trang-chu-moi-pc_202511132219189171.jpg"
                                            alt="Banner" class="img-fluid rounded shadow-sm w-100"
                                            style="object-fit: cover; max-height: 250px;">
                                    </section>

                                    <section class="container bg-light rounded-4 p-4" id="main-product-section">
                                        <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4 gap-3">
                                            <h4 class="fw-bold text-uppercase m-0">Dành cho bạn</h4>
                                            
                                            <div class="d-flex align-items-center gap-2 overflow-auto pb-2 pb-md-0 sort-container">
                                                <span class="text-muted small fw-bold text-nowrap"><i class="fas fa-sort me-1"></i>Sắp xếp:</span>
                                                <% 
                                                    const sortOptions = [
                                                        { label: 'Bán chạy', val: 'selling' },
                                                        { label: 'Mới nhất', val: 'newest' },
                                                        { label: 'Giá thấp', val: 'price-asc' },
                                                        { label: 'Giá cao', val: 'price-desc' }
                                                    ];
                                                %>
                                                <% sortOptions.forEach(opt => { %>
                                                    <a href="?<%= new URLSearchParams({...query, sort: opt.val, page: 1}).toString() %>" class="text-decoration-none ajax-filter-link">
                                                        <button class="btn btn-sm rounded-pill px-3 py-1 fw-semibold <%= activeSort === opt.val ? 'btn-tempi-green text-white' : 'btn-outline-secondary bg-white' %>" style="font-size: 0.8rem; white-space: nowrap;">
                                                            <%= opt.label %>
                                                        </button>
                                                    </a>
                                                <% }) %>
                                            </div>

                                            <span class="text-muted small">
                                                <%= products.length %> sản phẩm
                                            </span>
                                        </div>
                                        <div class="row bg-light rounded-4" id="product-list">
                                            <% if (products && products.length> 0) { %>
                                                <% products.forEach(product=> { %>
                                                    <div class="col-6 col-md-3 mb-4 p-3">
                                                        <div
                                                            class="card product-card h-100 border-1 shadow-md position-relative">
                                                            <% if (product.discount_price) { %>
                                                                <% let percent=Math.round(((product.price -
                                                                    product.discount_price) / product.price) * 100); %>
                                                                    <div class="badge-discount position-absolute top-0 end-0 m-2 bg-danger text-white px-2 py-1 rounded"
                                                                        style="z-index: 10;">
                                                                        -<%= percent %>%
                                                                    </div>
                                                                    <% } %>

                                                                        <a href="/product/<%= product._id %>"
                                                                            class="text-decoration-none">
                                                                            <div class="product-img-wrapper">
                                                                                <img src="/<%= product.cover_image %>"
                                                                                    alt="<%= product.name %>"
                                                                                    class="img-cover">
                                                                            </div>
                                                                        </a>

                                                                        <div class="card-body text-center">
                                                                            <a href="/product/<%= product._id %>"
                                                                                class="text-decoration-none">
                                                                                <h6 class="card-title fw-bold text-dark text-truncate-2"
                                                                                    style="min-height: 40px;">
                                                                                    <%= product.name %>
                                                                                </h6>
                                                                            </a>

                                                                            <% if (product.discount_price) { %>
                                                                                <div
                                                                                    class="text-muted text-decoration-line-through small">
                                                                                    <%= product.price.toLocaleString('vi-VN')
                                                                                        %> đ
                                                                                </div>
                                                                                <div class="fw-bold text-danger mb-2">
                                                                                    <%= product.discount_price.toLocaleString('vi-VN')
                                                                                        %> đ
                                                                                </div>
                                                                                <% } else { %>
                                                                                    <div class="text-muted small">&nbsp;
                                                                                    </div>
                                                                                    <div
                                                                                        class="fw-bold text-danger mb-2">
                                                                                        <%= product.price.toLocaleString('vi-VN')
                                                                                            %> đ
                                                                                    </div>
                                                                                    <% } %>

                                                                                        <div
                                                                                            class="d-flex justify-content-center align-items-center gap-3 mt-2">
                                                                                            <a href="javascript:void(0);"
                                                                                                onclick="addToCart('<%= product._id %>')"
                                                                                                class="text-tempi-green transition-zoom"
                                                                                                title="Thêm vào giỏ hàng">
                                                                                                <i
                                                                                                    class="fas fa-cart-plus fs-4"></i>
                                                                                            </a>
                                                                                            <a href="/cart/buy-now/<%= product._id %>"
                                                                                                class="btn btn-tempi-green flex-grow-1 text-white rounded-pill text-decoration-none text-center fw-bold shadow-sm btn-sm">
                                                                                                Mua ngay
                                                                                            </a>
                                                                                        </div>
                                                                        </div>
                                                        </div>
                                                    </div>
                                                    <% }) %>
                                                        <% } else { %>
                                                            <div class="col-12 text-center py-5">
                                                                <img src="https://cdn-icons-png.flaticon.com/512/2748/2748558.png"
                                                                    alt="Empty" width="100" class="mb-3 opacity-50">
                                                                <h5 class="text-muted">Danh mục này hiện chưa có sản
                                                                    phẩm
                                                                    nào.</h5>
                                                                <a href="/"
                                                                    class="btn btn-success mt-3 rounded-pill px-4">Quay
                                                                    lại
                                                                    mua sắm</a>
                                                            </div>
                                                            <% } %>
                                        </div>
                                    </section>

                                    <div class="text-center mt-4 ajax-pagination">
                                        <%- include('partials/pagination', { currentPage, totalPages, query: query }) %>
                                    </div>
        </div>
        <!-- Nội dung kết thúc --></div>
        </div>
        </div>
        <!-- Footer -->
        <%- include('partials/footer') %>
            <%- include('partials/modal') %>
                <%- include('partials/javascript') %>
                    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
                    <script>
                        let currentOffset = 8;

                        // PJAX-like filtering
                        function handleAjaxFilter() {
                            document.querySelectorAll('.ajax-filter-link, .ajax-pagination a').forEach(link => {
                                link.addEventListener('click', function(e) {
                                    e.preventDefault();
                                    const url = this.getAttribute('href');
                                    if (!url || url === '#') return;

                                    applyFilter(url);
                                });
                            });
                        }

                        function applyFilter(url) {
                            const container = document.getElementById('category-filter-area');
                            const overlay = document.getElementById('filter-loading-overlay');
                            
                            // Hiển thị overlay loading
                            overlay.classList.remove('d-none');
                            container.style.opacity = '0.7';

                            // Lưu lại vị trí cuộn của các thanh filter nằm ngang
                            const scrollPositions = Array.from(document.querySelectorAll('.filter-scroll-area')).map(el => el.scrollLeft);

                            fetch(url)
                                .then(response => response.text())
                                .then(html => {
                                    const parser = new DOMParser();
                                    const doc = parser.parseFromString(html, 'text/html');
                                    const newContent = doc.getElementById('category-filter-area').innerHTML;
                                    
                                    container.innerHTML = newContent;
                                    container.style.opacity = '1';
                                    
                                    // Cập nhật URL trình duyệt mà không load lại trang
                                    window.history.pushState({}, '', url);

                                    // Khôi phục vị trí cuộn của filter
                                    const newScrollAreas = document.querySelectorAll('.filter-scroll-area');
                                    scrollPositions.forEach((pos, i) => {
                                        if (newScrollAreas[i]) newScrollAreas[i].scrollLeft = pos;
                                    });

                                    // Gắn lại sự kiện cho các link mới
                                    handleAjaxFilter();
                                    
                                    // Reset offset cho load more
                                    currentOffset = 8;

                                    // Cuộn nhẹ xuống phần sản phẩm nếu ở mobile
                                    if (window.innerWidth < 768) {
                                        document.getElementById('main-product-section').scrollIntoView({ behavior: 'smooth', block: 'start' });
                                    }
                                })
                                .catch(err => {
                                    console.error('Lỗi lọc AJAX:', err);
                                    window.location.href = url; // Fallback nếu lỗi
                                });
                        }

                        // Xử lý nút back/forward của trình duyệt
                        window.addEventListener('popstate', function() {
                            window.location.reload();
                        });

                        function loadMoreCategory() {
                            const btn = document.getElementById('btn-load-more');
                            if (!btn) return;

                            const originalText = btn.innerHTML;
                            btn.innerHTML = '<span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span> Đang tải...';
                            btn.disabled = true;

                            const urlParams = new URLSearchParams(window.location.search);
                            const subcatId = urlParams.get('subcat') || '';
                            const brandId = urlParams.get('brand') || '';
                            const minPrice = urlParams.get('minPrice') || '';
                            const maxPrice = urlParams.get('maxPrice') || '';
                            const sort = urlParams.get('sort') || '';
                            const categorySlug = '<%= currentCategory.slug %>';

                            fetch(`/api/products/load-more?type=category&offset=${currentOffset}&categorySlug=${categorySlug}&subcat=${subcatId}&brand=${brandId}&minPrice=${minPrice}&maxPrice=${maxPrice}&sort=${sort}`)
                                .then(response => response.text())
                                .then(html => {
                                    if (html.trim() === '') {
                                        btn.innerHTML = 'Đã hết sản phẩm';
                                        btn.classList.replace('btn-outline-success', 'btn-secondary');
                                        btn.disabled = true;
                                    } else {
                                        document.getElementById('product-list').insertAdjacentHTML('beforeend', html);
                                        currentOffset += 8;
                                        btn.innerHTML = originalText;
                                        btn.disabled = false;
                                    }
                                })
                                .catch(error => {
                                    console.error('Error:', error);
                                    btn.innerHTML = originalText;
                                    btn.disabled = false;
                                });
                        }

                        document.addEventListener('DOMContentLoaded', handleAjaxFilter);
                    </script>
</body>

</html>
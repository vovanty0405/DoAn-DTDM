<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= currentCategory.name %> - Bách Hóa Pew
    </title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/style.css">
    <link href="http://127.0.0.1:3000/css/style.css" rel="stylesheet" />
    <style>
        .scroll-horizontal {
            display: flex;
            overflow-x: auto;
            gap: 15px;
            padding-bottom: 10px;
            scrollbar-width: none;
        }

        .scroll-horizontal::-webkit-scrollbar {
            display: none;
        }

        .subcat-item {
            min-width: 100px;
            text-align: center;
            cursor: pointer;
        }

        .subcat-img-wrapper {
            width: 90px;
            /* ĐÃ TĂNG SIZE TỪ 70px LÊN 90px */
            height: 90px;
            margin: 0 auto 10px auto;
            border-radius: 20px;
            background-color: #f1f3f5;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
            border: 2px solid #e9ecef;
            transition: 0.2s;
        }

        .subcat-img-wrapper img {
            width: 100%;
            height: 100%;
            object-fit: contain;
            padding: 5px;
        }

        /* Tô viền xanh cho Thể loại con đang được chọn */
        .subcat-item.active .subcat-img-wrapper {
            border-color: var(--tempi-green);
            background-color: #e6f2ee;
        }

        .subcat-item.active span {
            color: var(--tempi-green) !important;
            font-weight: bold;
        }

        .brand-btn {
            white-space: nowrap;
            border: 1px solid #e0e0e0;
            color: #333;
            background: white;
            transition: 0.2s;
        }

        .brand-btn:hover {
            border-color: var(--tempi-green);
            color: var(--tempi-green);
        }

        /* Tô nền xanh cho Hãng đang được chọn */
        .brand-btn.active {
            background-color: var(--tempi-green);
            color: white;
            border-color: var(--tempi-green);
        }
    </style>
</head>

<body>
    <!-- Header -->
    <%- include('partials/navbar') %>

        <div class="container my-3">
            <% if (subCategories && subCategories.length> 0) { %>
                <div class="scroll-horizontal mb-4 mt-3">
                    <a href="/category/<%= currentCategory.slug %>" class="text-decoration-none">
                        <div
                            class="subcat-item <%= !typeof activeSubcat !== 'undefined' && !activeSubcat ? 'active' : '' %>">
                            <div class="subcat-img-wrapper">
                                <img src="https://cdn-icons-png.flaticon.com/512/679/679821.png" alt="Tất cả">
                            </div>
                            <span class="small fw-semibold text-dark">Tất cả</span>
                        </div>
                    </a>

                    <% subCategories.forEach(sc=> { %>
                        <a href="/category/<%= currentCategory.slug %>?subcat=<%= sc._id %>"
                            class="text-decoration-none">
                            <div
                                class="subcat-item <%= (typeof activeSubcat !== 'undefined' && activeSubcat == sc._id) ? 'active' : '' %>">
                                <div class="subcat-img-wrapper">
                                    <img src="<%= sc.image ? '/' + sc.image : 'https://cdn-icons-png.flaticon.com/512/679/679821.png' %>"
                                        alt="<%= sc.name %>">
                                </div>
                                <span class="small fw-semibold text-dark text-truncate-2" style="font-size: 0.85rem;">
                                    <%= sc.name %>
                                </span>
                            </div>
                        </a>
                        <% }) %>
                </div>
                <% } %>

                    <% if (brands && brands.length> 0) { %>
                        <div class="d-flex align-items-center mb-4">
                            <i class="fas fa-filter text-muted me-3"></i>
                            <div class="scroll-horizontal flex-grow-1" style="padding-bottom: 0;">
                                <a href="/category/<%= currentCategory.slug %>" class="text-decoration-none">
                                    <button
                                        class="btn rounded-pill px-4 py-1 brand-btn fw-semibold shadow-sm <%= !typeof activeBrand !== 'undefined' && !activeBrand ? 'active' : '' %>">Tất
                                        cả</button>
                                </a>

                                <% brands.forEach(b=> { %>
                                    <a href="/category/<%= currentCategory.slug %>?brand=<%= b._id %>"
                                        class="text-decoration-none">
                                        <button
                                            class="btn rounded-pill px-4 py-1 brand-btn fw-semibold shadow-sm <%= (typeof activeBrand !== 'undefined' && activeBrand == b._id) ? 'active' : '' %>">
                                            <%= b.name %>
                                        </button>
                                    </a>
                                    <% }) %>
                            </div>
                        </div>
                        <% } %>

                            <!-- <% 
            // KHAI BÁO ẢNH BANNER THEO SLUG
            const catBanners = {
                'rau-cu': '/image/banner_raucu.jpg',
                'nuoc-ngot': '/image/banner_nuoc.jpg',
                'my-mien-chao-pho': '/image/Mỳ/cate-mobile-compressed_202603060835210894.jpg'              
            };
            // Nếu không có banner riêng, dùng banner mặc định này
            let bannerSrc = catBanners[currentCategory.slug] || 'https://via.placeholder.com/1200x200?text=Banner+Sieu+Giam+Gia';
        %> -->
                            <section class="container mb-4">
                                <img src="../../public/image/Banner/freecompress-trang-chu-moi-pc_202511132219189171.jpg"
                                    alt="Banner" class="img-fluid rounded shadow-sm w-100"
                                    style="object-fit: cover; max-height: 150px;">
                            </section>

                            <div class="mb-5 text-center">
                                <img src="<%= bannerSrc %>" alt="Banner <%= currentCategory.name %>"
                                    class="img-fluid rounded shadow-sm w-100"
                                    style="object-fit: cover; max-height: 250px;">
                            </div>

                            <% if (saleProducts && saleProducts.length> 0) { %>
                                <div class="bg-danger rounded-4 p-4 mb-5 shadow-lg position-relative">
                                    <div class="d-flex justify-content-between align-items-center mb-4">
                                        <h3 class="text-white fw-bold fst-italic m-0"><i
                                                class="fas fa-bolt text-warning me-2"></i> KHUYẾN MÃI SỐC</h3>
                                    </div>

                                    <div class="row">
                                        <% saleProducts.forEach(product=> { %>
                                            <div class="col-md-3 col-sm-6 mb-3">
                                                <div
                                                    class="card product-card h-100 border-0 shadow-sm position-relative">
                                                    <% let percent=Math.round(((product.price - product.discount_price)
                                                        / product.price) * 100); %>
                                                        <div class="badge-discount position-absolute top-0 end-0 m-2 bg-danger text-white px-2 py-1 rounded"
                                                            style="z-index: 10;">
                                                            -<%= percent %>%
                                                        </div>
                                                        <a href="/product/<%= product._id %>"
                                                            class="text-decoration-none">
                                                            <div class="product-img-wrapper">
                                                                <img src="/<%= product.cover_image %>"
                                                                    alt="<%= product.name %>" class="img-cover">
                                                            </div>
                                                        </a>
                                                        <div class="card-body text-center p-3">
                                                            <h6 class="card-title fw-bold text-dark text-truncate-2"
                                                                style="font-size: 0.9rem; min-height: 38px;">
                                                                <%= product.name %>
                                                            </h6>
                                                            <div class="text-muted text-decoration-line-through small">
                                                                <%= product.price.toLocaleString('vi-VN') %> đ
                                                            </div>
                                                            <div class="fw-bold text-danger fs-5 mb-2">
                                                                <%= product.discount_price.toLocaleString('vi-VN') %> đ
                                                            </div>

                                                            <div class="progress mb-2"
                                                                style="height: 18px; border-radius: 50px; background-color: #fef0cd;">
                                                                <% let stockPercent=(product.stock_quantity <=100) ?
                                                                    product.stock_quantity : 50; %>
                                                                    <div class="progress-bar bg-warning text-dark fw-bold"
                                                                        style="width: <%= stockPercent %>%; font-size: 0.7rem; line-height: 18px;">
                                                                        Còn <%= product.stock_quantity %>
                                                                    </div>
                                                            </div>

                                                            <div
                                                                class="d-flex justify-content-center align-items-center gap-2 mt-2">
                                                                <a href="javascript:void(0);"
                                                                    onclick="addToCart('<%= product._id %>')"
                                                                    class="text-tempi-green transition-zoom"
                                                                    title="Thêm vào giỏ hàng">
                                                                    <i class="fas fa-cart-plus fs-4"></i>
                                                                </a>
                                                                <a href="/cart/buy-now/<%= product._id %>"
                                                                    class="btn btn-warning flex-grow-1 text-dark rounded-pill text-decoration-none text-center fw-bold shadow-sm btn-sm">
                                                                    Mua ngay
                                                                </a>
                                                            </div>
                                                        </div>
                                                </div>
                                            </div>
                                            <% }) %>
                                    </div>
                                </div>
                                <% } %>

                                    <div class="d-flex justify-content-between align-items-center mb-4">
                                        <h4 class="fw-bold text-uppercase m-0">Dành cho bạn</h4>
                                        <span class="text-muted">
                                            <%= products.length %> sản phẩm
                                        </span>
                                    </div>
                                    <div class="row" id="product-list">
                                        <% if (products && products.length> 0) { %>
                                            <% products.forEach(product=> { %>
                                                <div class="col-md-3 col-sm-6 mb-4">
                                                    <div
                                                        class="card product-card h-100 border-0 shadow-sm position-relative">
                                                        <% if (product.discount_price) { %>
                                                            <% let percent=Math.round(((product.price -
                                                                product.discount_price) / product.price) * 100); %>
                                                                <div class="badge-discount position-absolute top-0 end-0 m-2 bg-danger text-white px-2 py-1 rounded"
                                                                    style="z-index: 10;">
                                                                    -<%= percent %>%
                                                                </div>
                                                                <% } %>

                                                                    <a href="/product/<%= product._id %>"
                                                                        class="text-decoration-none">
                                                                        <div class="product-img-wrapper">
                                                                            <img src="/<%= product.cover_image %>"
                                                                                alt="<%= product.name %>"
                                                                                class="img-cover">
                                                                        </div>
                                                                    </a>

                                                                    <div class="card-body text-center">
                                                                        <a href="/product/<%= product._id %>"
                                                                            class="text-decoration-none">
                                                                            <h6 class="card-title fw-bold text-dark text-truncate-2"
                                                                                style="min-height: 40px;">
                                                                                <%= product.name %>
                                                                            </h6>
                                                                        </a>

                                                                        <% if (product.discount_price) { %>
                                                                            <div
                                                                                class="text-muted text-decoration-line-through small">
                                                                                <%= product.price.toLocaleString('vi-VN')
                                                                                    %> đ
                                                                            </div>
                                                                            <div class="fw-bold text-danger mb-2">
                                                                                <%= product.discount_price.toLocaleString('vi-VN')
                                                                                    %> đ
                                                                            </div>
                                                                            <% } else { %>
                                                                                <div class="text-muted small">&nbsp;
                                                                                </div>
                                                                                <div class="fw-bold text-danger mb-2">
                                                                                    <%= product.price.toLocaleString('vi-VN')
                                                                                        %> đ
                                                                                </div>
                                                                                <% } %>

                                                                                    <div
                                                                                        class="d-flex justify-content-center align-items-center gap-3 mt-2">
                                                                                        <a href="javascript:void(0);"
                                                                                            onclick="addToCart('<%= product._id %>')"
                                                                                            class="text-tempi-green transition-zoom"
                                                                                            title="Thêm vào giỏ hàng">
                                                                                            <i
                                                                                                class="fas fa-cart-plus fs-4"></i>
                                                                                        </a>
                                                                                        <a href="/cart/buy-now/<%= product._id %>"
                                                                                            class="btn btn-tempi-green flex-grow-1 text-white rounded-pill text-decoration-none text-center fw-bold shadow-sm btn-sm">
                                                                                            Mua ngay
                                                                                        </a>
                                                                                    </div>
                                                                    </div>
                                                    </div>
                                                </div>
                                                <% }) %>
                                                    <% } else { %>
                                                        <div class="col-12 text-center py-5">
                                                            <img src="https://cdn-icons-png.flaticon.com/512/2748/2748558.png"
                                                                alt="Empty" width="100" class="mb-3 opacity-50">
                                                            <h5 class="text-muted">Danh mục này hiện chưa có sản phẩm
                                                                nào.</h5>
                                                            <a href="/"
                                                                class="btn btn-success mt-3 rounded-pill px-4">Quay lại
                                                                mua sắm</a>
                                                        </div>
                                                        <% } %>
                                    </div>

                                    <div class="text-center mt-4">
                                        <% let q={}; if (typeof activeSubcat !=='undefined' && activeSubcat)
                                            q.subcat=activeSubcat; if (typeof activeBrand !=='undefined' && activeBrand)
                                            q.brand=activeBrand; %>
                                            <%- include('partials/pagination', { currentPage, totalPages, query: q }) %>
                                    </div>
        </div>
        <!-- Nội dung kết thúc --></div>
        </div>
        </div>
        <!-- Footer -->
        <%- include('partials/footer') %>
            <%- include('partials/modal') %>
                <%- include('partials/javascript') %>
                    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
                    <script>
                        let currentOffset = 8;

                        function loadMoreCategory() {
                            const btn = document.getElementById('btn-load-more');
                            const originalText = btn.innerHTML;
                            btn.innerHTML = '<span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span> Đang tải...';
                            btn.disabled = true;

                            const urlParams = new URLSearchParams(window.location.search);
                            const subcatId = urlParams.get('subcat') || '';
                            const brandId = urlParams.get('brand') || '';
                            const categorySlug = '<%= currentCategory.slug %>';

                            fetch(`/api/products/load-more?type=category&offset=${currentOffset}&categorySlug=${categorySlug}&subcat=${subcatId}&brand=${brandId}`)
                                .then(response => response.text())
                                .then(html => {
                                    if (html.trim() === '') {
                                        btn.innerHTML = 'Đã hết sản phẩm';
                                        btn.classList.replace('btn-outline-success', 'btn-secondary');
                                        btn.disabled = true;
                                    } else {
                                        document.getElementById('product-list').insertAdjacentHTML('beforeend', html);
                                        currentOffset += 8;
                                        btn.innerHTML = originalText;
                                        btn.disabled = false;
                                    }
                                })
                                .catch(error => {
                                    console.error('Error:', error);
                                    btn.innerHTML = originalText;
                                    btn.disabled = false;
                                });
                        }
                    </script>
</body>

</html>
<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Giỏ hàng của bạn - Bách Hóa Pew</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/style.css">
    <link href="/css/style.css" rel="stylesheet" />
    <style>
        .qty-input {
            width: 60px;
            text-align: center;
        }

        .product-img {
            width: 80px;
            height: 80px;
            object-fit: contain;
            border: 1px solid #ddd;
            border-radius: 8px;
            padding: 5px;
            background: #fff;
        }

        .table> :not(caption)>*>* {
            vertical-align: middle;
        }
    </style>
</head>

<body class="bg-light">

    <!-- Header -->
    <%- include('partials/navbar') %>
        <!-- Giỏ hàng -->
        <div class="container my-5" style="min-height: 60vh;">
            <h2 class="fw-bold mb-4">Giỏ hàng của bạn</h2>

            <% if (cartItems && cartItems.length> 0) { %>
                <div class="row">
                    <div class="col-lg-8 mb-4">
                        <div class="card shadow-sm border-0">
                            <div class="card-body p-0">
                                <table class="table table-hover mb-0 text-center">
                                    <thead class="table-light">
                                        <tr>
                                            <th scope="col" width="5%"><input type="checkbox" id="checkAll"
                                                    class="form-check-input" checked></th>
                                            <th scope="col" width="45%" class="text-start">Sản phẩm</th>
                                            <th scope="col" width="15%">Đơn giá</th>
                                            <th scope="col" width="15%">Số lượng</th>
                                            <th scope="col" width="15%">Thành tiền</th>
                                            <th scope="col" width="5%"><i class="fas fa-trash-alt"></i></th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <% cartItems.forEach(item=> { %>
                                            <tr>
                                                <td>
                                                    <input type="checkbox" class="form-check-input item-check"
                                                        value="<%= item.product_id %>" checked>
                                                </td>
                                                <td class="text-start">
                                                    <div class="d-flex align-items-center">
                                                        <img src="/<%= item.cover_image %>" alt="<%= item.name %>"
                                                            class="product-img me-3">
                                                        <a href="/product/<%= item.product_id %>"
                                                            class="text-dark text-decoration-none fw-semibold">
                                                            <%= item.name %>
                                                        </a>
                                                    </div>
                                                </td>
                                                <td class="fw-bold price" data-price="<%= item.price %>">
                                                    <%= item.price.toLocaleString('vi-VN') %> đ
                                                </td>
                                                <td>
                                                    <input type="number" class="form-control qty-input mx-auto"
                                                        name="qty[<%= item.product_id %>]" value="<%= item.quantity %>"
                                                        min="1">
                                                </td>
                                                <td class="fw-bold text-danger item-total">
                                                    <%= (item.price * item.quantity).toLocaleString('vi-VN') %> đ
                                                </td>
                                                <td>
                                                    <a href="/cart/remove/<%= item.product_id %>"
                                                        class="text-danger fs-5"
                                                        onclick="return confirm('Bạn có chắc muốn xóa sản phẩm này?');"><i
                                                            class="fas fa-times-circle"></i></a>
                                                </td>
                                            </tr>
                                            <% }) %>
                                    </tbody>
                                </table>
                            </div>
                            <div class="d-flex justify-content-between mt-4 mb-3 px-4">
                                <a href="/" class="btn btn-outline-secondary"><i class="fas fa-arrow-left me-2"></i>Mua
                                    thêm</a>
                                <!-- <button type="submit" formaction="cart.php" name="update_cart" class="btn btn-outline-primary"><i class="fas fa-sync-alt me-2"></i>Cập nhật số lượng</button> -->
                            </div>
                        </div>
                    </div>

                    <div class="col-lg-4">
                        <div class="card shadow-sm border-0 sticky-top border-top border-warning border-4"
                            style="top: 100px;">
                            <div class="card-body p-4">
                                <h5 class="fw-bold mb-4 border-bottom pb-2">Tổng hóa đơn</h5>
                                <div class="d-flex justify-content-between mb-3">
                                    <span class="text-muted">Tạm tính (<span class="iitem-check">0</span> món) :</span>
                                    <span class="fw-semibold" id="temp-total">0 đ</span>
                                </div>
                                <div class="d-flex justify-content-between mb-3">
                                    <span class="text-muted">Giảm giá:</span>
                                    <span class="fw-semibold text-success">- 0 đ</span>
                                </div>
                                <div class="d-flex justify-content-between mb-3">
                                    <span class="text-muted">Phí giao hàng:</span>
                                    <span class="text-success fw-bold">Miễn phí</span>
                                </div>
                                <hr>
                                <div class="d-flex justify-content-between mb-4">
                                    <span class="fw-bold fs-5">Tổng cộng:</span>
                                    <span class="fw-bold fs-4 text-danger" id="final-total">0 đ</span>
                                </div>
                                <% if (typeof user !=='undefined' && user) { %>
                                    <a href="/checkout"
                                        class="btn btn-warning w-100 fw-bold py-2 fs-5 text-dark rounded-pill d-block text-center text-decoration-none shadow-sm">
                                        Tiến hành đặt hàng
                                    </a>
                                    <% } else { %>
                                        <button type="button"
                                            class="btn btn-warning w-100 fw-bold py-2 fs-5 text-dark rounded-pill shadow-sm"
                                            data-bs-toggle="modal" data-bs-target="#loginModal">
                                            Tiến hành đặt hàng
                                        </button>
                                        <% } %>
                                            <a href="/"
                                                class="btn btn-outline-secondary w-100 fw-bold py-2 mt-2 rounded-pill">Tiếp
                                                tục mua sắm</a>
                                            <div class="text-center mt-3 small text-muted">
                                                <i class="fas fa-shield-alt text-success me-1"></i> Thanh toán an toàn &
                                                bảo mật
                                            </div>
                            </div>
                        </div>
                    </div>
                </div>
                <% } else { %>
                    <div class="text-center py-5 bg-white rounded shadow-sm">
                        <img src="https://cdn-icons-png.flaticon.com/512/11329/11329060.png" alt="Empty Cart"
                            width="150" class="mb-4 opacity-50">
                        <h4 class="text-muted">Giỏ hàng của bạn đang trống</h4>
                        <p class="text-muted">Hãy chọn thêm sản phẩm để mua sắm nhé!</p>
                        <a href="/" class="btn btn-success px-4 py-2 mt-3 fw-bold rounded-pill">Về trang chủ</a>
                    </div>
                    <% } %>
        </div>
        <!-- Footer -->
        <%- include('partials/footer') %>
            <!-- Modal -->
            <%- include('partials/modal') %>
                <%- include('partials/javascript') %>
                    <script>
                        document.addEventListener('DOMContentLoaded', function () {
                            const checkAll = document.getElementById('checkAll');
                            const itemChecks = document.querySelectorAll('.item-check');
                            const qtyInputs = document.querySelectorAll('.qty-input');

                            // Hàm định dạng tiền tệ Việt Nam
                            function formatVND(amount) {
                                return amount.toLocaleString('vi-VN') + ' đ';
                            }

                            // Hàm tính toán tổng tiền
                            function calculateTotal() {
                                let tempTotal = 0;
                                itemChecks.forEach((checkbox, index) => {
                                    const row = checkbox.closest('tr');
                                    const price = parseInt(row.querySelector('.price').getAttribute('data-price'));
                                    const qty = parseInt(row.querySelector('.qty-input').value);
                                    const itemTotal = price * qty;

                                    row.querySelector('.item-total').innerText = formatVND(itemTotal);

                                    if (checkbox.checked) {
                                        tempTotal += itemTotal;
                                    }
                                });

                                document.getElementById('temp-total').innerText = formatVND(tempTotal);
                                document.getElementById('final-total').innerText = formatVND(tempTotal);
                            }

                            // Xử lý Checkbox "Chọn tất cả"
                            if (checkAll) {
                                checkAll.addEventListener('change', function () {
                                    itemChecks.forEach(check => check.checked = this.checked);
                                    calculateTotal();
                                });
                            }

                            // Xử lý Checkbox từng món
                            itemChecks.forEach(check => check.addEventListener('change', function () {
                                const allChecked = Array.from(itemChecks).every(i => i.checked);
                                if (allChecked) checkAll.checked = true;
                                else checkAll.checked = false;
                                calculateTotal();
                            }));

                            // Tự động tính lại và GỌI AJAX khi thay đổi số lượng
                            qtyInputs.forEach(q => {
                                q.addEventListener('change', function () {
                                    const productId = this.name.match(/\[(.*?)\]/)[1]; // Lấy ID sản phẩm từ name="qty[id]"
                                    const newQty = parseInt(this.value);

                                    // Gọi API Node.js bằng Fetch với chuẩn JSON
                                    fetch('/cart/update', {
                                        method: 'POST',
                                        headers: { 'Content-Type': 'application/json' },
                                        body: JSON.stringify({ product_id: productId, quantity: newQty })
                                    })
                                        .then(res => res.json())
                                        .then(data => console.log('Cập nhật:', data))
                                        .catch(err => console.error('Lỗi:', err));

                                    calculateTotal();
                                });
                                q.addEventListener('keyup', calculateTotal);
                            });

                            // Xử lý nút thanh toán - Chỉ thanh toán các món được chọn
                            const checkoutBtn = document.querySelector('a[href="/checkout"]');
                            if (checkoutBtn) {
                                checkoutBtn.addEventListener('click', function (e) {
                                    e.preventDefault();
                                    const selectedIds = Array.from(document.querySelectorAll('.item-check:checked'))
                                        .map(cb => cb.value);
                                    
                                    if (selectedIds.length === 0) {
                                        alert('Vui lòng chọn ít nhất một sản phẩm để thanh toán.');
                                        return;
                                    }
                                    
                                    // Chuyển hướng kèm theo danh sách ID sản phẩm
                                    window.location.href = `/checkout?items=${selectedIds.join(',')}`;
                                });
                            }

                            // Chạy tính toán lần đầu khi load trang
                            if (itemChecks.length > 0) calculateTotal();
                        });
                    </script>
</body>

</html>
<header class="header-bg sticky-top">
    <div class="container">
        <!-- Desktop Navbar -->
        <nav class="navbar navbar-expand-lg navbar-dark py-3 d-none d-lg-flex">
            <a class="navbar-brand fw-bold fs-3" href="/">Bách Hóa Pew</a>

            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav mx-auto align-items-center">
                    <li class="nav-item">
                        <a class="nav-link active-yellow" href="/">Trang chủ</a>
                    </li>
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" id="navbarDropdown" role="button"
                            data-bs-toggle="dropdown">
                            Danh mục
                        </a>
                        <ul class="dropdown-menu custom-dropdown" aria-labelledby="navbarDropdown">
                            <% if (typeof categories !=='undefined' && categories.length> 0) { %>
                                <% categories.forEach(cat=> { %>
                                    <li><a class="dropdown-item" href="/category/<%= cat.slug %>">
                                            <%= cat.name %>
                                        </a></li>
                                    <% }) %>
                                        <% } else { %>
                                            <li><a class="dropdown-item" href="#">Đang cập nhật...</a></li>
                                            <% } %>
                        </ul>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/about">Về chúng tôi</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/contact">Liên hệ</a>
                    </li>
                </ul>
                <!-- User -->
                <ul class="navbar-nav align-items-center">
                    <% if (typeof user !=='undefined' && user) { %>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle fw-bold text-warning" href="#" data-bs-toggle="dropdown">
                                <i class="fas fa-user-circle fs-5 me-1"></i>
                                <%= user.fullname || user.full_name %>
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end border-0 shadow">
                                <% if (user.role==1) { %>
                                    <li><a class="dropdown-item fw-bold text-success" href="/admin/products"><i
                                                class="fas fa-shield-alt me-2"></i> Vào trang Admin</a></li>
                                    <li>
                                        <hr class="dropdown-divider">
                                    </li>
                                    <% } %>
                                        <li><a class="dropdown-item" href="/profile"><i class="fas fa-user-cog me-2"></i> Tài khoản của tôi</a></li>
                                        <li><a class="dropdown-item" href="/orders"><i class="fas fa-box me-2"></i> Đơn
                                                hàng của tôi</a></li>
                                        <li><a class="dropdown-item text-danger" href="/logout"><i
                                                     class="fas fa-sign-out-alt me-2"></i> Đăng xuất</a></li>
                            </ul>
                        </li>
                        <% } else { %>
                            <li class="nav-item">
                                <a class="nav-link" href="#" data-bs-toggle="modal" data-bs-target="#loginModal">Đăng
                                    nhập</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" href="#" data-bs-toggle="modal" data-bs-target="#registerModal">Đăng
                                    ký</a>
                            </li>
                            <% } %>

                                <li class="nav-item ms-lg-2">
                                    <a href="#" class="nav-link text-white" data-bs-toggle="modal"
                                        data-bs-target="#searchModal" title="Tìm kiếm">
                                        <i class="fas fa-search fs-5"></i>
                                    </a>
                                </li>

                                <% if (typeof user !=='undefined' && user) { %>
                                    <!-- Icon Chuông Thông Báo -->
                                    <li class="nav-item ms-lg-2 position-relative" id="notificationBell">
                                        <a href="javascript:void(0);" class="nav-link text-white position-relative"
                                            id="bellToggle" title="Thông báo">
                                            <i class="fas fa-bell fs-5"></i>
                                            <span id="noti-badge"
                                                class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger"
                                                style="font-size: 0.55rem; display: none;">
                                                0
                                            </span>
                                        </a>
                                        <!-- Dropdown Thông báo -->
                                        <div id="notiDropdown"
                                            class="position-absolute bg-white shadow-lg rounded text-start"
                                            style="top: 100%; right: 0; z-index: 9999; display: none; width: 340px; max-height: 400px; overflow-y: auto; border: 1px solid #ddd; margin-top: 8px;">
                                            <div
                                                class="d-flex justify-content-between align-items-center p-3 border-bottom bg-light">
                                                <strong class="text-dark"><i class="fas fa-bell me-1 text-warning"></i>
                                                    Thông báo</strong>
                                                <a href="javascript:void(0);" id="markAllRead"
                                                    class="text-success small text-decoration-none fw-bold">Đánh dấu đã
                                                    đọc</a>
                                            </div>
                                            <div id="notiList">
                                                <div class="p-3 text-center text-muted small">Đang tải...</div>
                                            </div>
                                        </div>
                                    </li>
                                    <% } %>

                                        <li class="nav-item ms-lg-3 mt-2 mt-lg-0">
                                            <a href="/cart" class="cart-icon position-relative text-white">
                                                <i class="fas fa-shopping-cart fs-5"></i>
                                                <span id="cart-badge"
                                                    class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger"
                                                    style="font-size: 0.6rem;">
                                                    <%= typeof cartCount !=='undefined' ? cartCount : 0 %>
                                                </span>
                                            </a>
                                        </li>
                </ul>
            </div>
        </nav>

        <!-- Mobile Navbar (Tiki Style) -->
        <div class="mobile-navbar d-flex d-lg-none align-items-center py-2 gap-2">
            <button class="btn text-white p-0 border-0 shadow-none" type="button" data-bs-toggle="offcanvas" data-bs-target="#mobileMenu">
                <i class="fas fa-bars fs-4"></i>
            </button>
            
            <div class="flex-grow-1 position-relative mx-1">
                <input type="text" class="form-control rounded-pill border-0 ps-5" placeholder="Bạn tìm gì hôm nay?" 
                    data-bs-toggle="modal" data-bs-target="#searchModal" readonly style="height: 38px; background-color: rgba(255,255,255,0.95);">
                <i class="fas fa-search position-absolute top-50 translate-middle-y ms-3 text-muted"></i>
            </div>

            <a href="/cart" class="text-white position-relative p-1">
                <i class="fas fa-shopping-cart fs-4"></i>
                <span id="cart-badge-mobile" class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" style="font-size: 0.5rem;">
                    <%= typeof cartCount !=='undefined' ? cartCount : 0 %>
                </span>
            </a>
        </div>
    </div>
</header>

<!-- Mobile Offcanvas Menu -->
<div class="offcanvas offcanvas-start mobile-offcanvas" tabindex="-1" id="mobileMenu" aria-labelledby="mobileMenuLabel">
    <div class="offcanvas-header user-header d-flex align-items-center">
        <% if (typeof user !== 'undefined' && user) { %>
            <div class="user-info-wrapper d-flex align-items-center w-100">
                <div class="avatar-circle me-3">
                    <i class="fas fa-user-circle fs-1 text-white"></i>
                </div>
                <div class="user-details text-white">
                    <div class="fw-bold fs-5 text-truncate" style="max-width: 180px;"><%= user.fullname || user.full_name %></div>
                    <div class="small opacity-75">Thành viên Pew</div>
                </div>
                <a href="/profile" class="ms-auto text-white"><i class="fas fa-chevron-right"></i></a>
            </div>
        <% } else { %>
            <div class="login-prompt-wrapper d-flex align-items-center w-100" data-bs-toggle="modal" data-bs-target="#loginModal">
                <div class="avatar-circle me-3">
                    <i class="fas fa-user-circle fs-1 text-white opacity-50"></i>
                </div>
                <div class="user-details text-white">
                    <div class="fw-bold fs-5">Đăng nhập</div>
                    <div class="small opacity-75">Nhận nhiều ưu đãi hơn</div>
                </div>
                <i class="fas fa-chevron-right ms-auto text-white"></i>
            </div>
        <% } %>
    </div>
    <div class="offcanvas-body p-0">
        <div class="list-group list-group-flush border-0">
            <a href="/" class="list-group-item list-group-item-action d-flex align-items-center py-3 border-0">
                <i class="fas fa-home me-3 fs-5 text-primary"></i> Trang chủ
            </a>
            <a href="javascript:void(0);" class="list-group-item list-group-item-action d-flex align-items-center py-3 border-0" data-bs-toggle="collapse" data-bs-target="#mobileCatCollapse">
                <i class="fas fa-th-list me-3 fs-5 text-success"></i> Danh sách ngành hàng
                <i class="fas fa-chevron-down ms-auto small"></i>
            </a>
            <div class="collapse bg-light" id="mobileCatCollapse">
                <% if (typeof categories !== 'undefined' && categories.length > 0) { %>
                    <% categories.forEach(cat => { %>
                        <a href="/category/<%= cat.slug %>" class="list-group-item list-group-item-action ps-5 py-2 border-0 bg-transparent">
                            <%= cat.name %>
                        </a>
                    <% }) %>
                <% } %>
            </div>
            <a href="/profile" class="list-group-item list-group-item-action d-flex align-items-center py-3 border-0">
                <i class="fas fa-user-cog me-3 fs-5 text-info"></i> Quản lý tài khoản
            </a>
            <a href="/orders" class="list-group-item list-group-item-action d-flex align-items-center py-3 border-0">
                <i class="fas fa-bell me-3 fs-5 text-warning"></i> Thông báo
                <% if (typeof user !== 'undefined' && user) { %>
                    <span class="badge rounded-pill bg-danger ms-auto noti-count-badge" style="display: none;">0</span>
                <% } %>
            </a>

            <div class="divider-mobile" style="height: 8px; background-color: #f5f5fa;"></div>
            <div class="px-3 py-2 text-muted small fw-bold text-uppercase">Khuyến mãi hot</div>
            <a href="javascript:void(0);" class="list-group-item list-group-item-action d-flex align-items-center py-3 border-0">
                <i class="fas fa-fire me-3 fs-5 text-danger"></i> Pew Deal
            </a>
            <a href="javascript:void(0);" class="list-group-item list-group-item-action d-flex align-items-center py-3 border-0">
                <i class="fas fa-gift me-3 fs-5 text-danger"></i> Phiếu quà tặng
            </a>
            <a href="javascript:void(0);" class="list-group-item list-group-item-action d-flex align-items-center py-3 border-0">
                <i class="fas fa-credit-card me-3 fs-5 text-primary"></i> Ưu đãi cho chủ thẻ
            </a>

            <div class="divider-mobile" style="height: 8px; background-color: #f5f5fa;"></div>
            <div class="px-3 py-2 text-muted small fw-bold text-uppercase">Hỗ trợ</div>
            <div class="list-group-item py-3 border-0">
                <div class="text-dark d-flex align-items-center">
                    <i class="fas fa-headset me-3 fs-5 text-secondary"></i>
                    <div>
                        <div class="fw-bold">HOTLINE: <span class="text-primary">1900 - 6035</span></div>
                        <div class="small text-muted">(1000đ/phút)</div>
                    </div>
                </div>
            </div>
            <a href="/contact" class="list-group-item list-group-item-action d-flex align-items-center py-3 border-0">
                <i class="fas fa-question-circle me-3 fs-5 text-secondary"></i> Hỗ trợ khách hàng <i class="fas fa-chevron-right ms-auto small"></i>
            </a>
            
            <% if (typeof user !== 'undefined' && user) { %>
                <div class="p-3 mt-3">
                    <a href="/logout" class="btn btn-outline-danger w-100 rounded-pill">Đăng xuất</a>
                </div>
            <% } %>
        </div>
    </div>
</div>

<script>
    function addToCart(productId) {
        fetch(`/api/cart/add?id=${productId}`)
            .then(response => response.json())
            .then(data => {
                if (data.status === 'success') {
                    let badge = document.getElementById('cart-badge');
                    let badgeMobile = document.getElementById('cart-badge-mobile');
                    if (badge) {
                        badge.innerText = data.cart_count;
                        badge.style.transform = 'scale(1.5)';
                        setTimeout(() => badge.style.transform = 'scale(1)', 200);
                    }
                    if (badgeMobile) {
                        badgeMobile.innerText = data.cart_count;
                        badgeMobile.style.transform = 'scale(1.5)';
                        setTimeout(() => badgeMobile.style.transform = 'scale(1)', 200);
                    }
                } else {
                    alert(data.message || 'Không thể thêm sản phẩm vào giỏ hàng.');
                }
            })
            .catch(error => console.error('Lỗi khi gọi API giỏ hàng:', error));
    }

    document.addEventListener('DOMContentLoaded', function () {
        const bellToggle = document.getElementById('bellToggle');
        const notiDropdown = document.getElementById('notiDropdown');
        const notiList = document.getElementById('notiList');
        const markAllRead = document.getElementById('markAllRead');

        function fetchNotiCount() {
            fetch('/api/notifications/count')
                .then(r => r.json())
                .then(data => {
                    const badges = [document.getElementById('noti-badge'), document.querySelector('.noti-count-badge')];
                    badges.forEach(b => {
                        if (b) {
                            if (data.count > 0) {
                                b.innerText = data.count > 99 ? '99+' : data.count;
                                b.style.display = '';
                            } else {
                                b.style.display = 'none';
                            }
                        }
                    });
                })
                .catch(() => { });
        }

        function fetchNotiList() {
            fetch('/api/notifications')
                .then(r => r.json())
                .then(notifications => {
                    if (!notiList) return;
                    if (notifications.length === 0) {
                        notiList.innerHTML = '<div class="p-3 text-center text-muted small">Chưa có thông báo nào.</div>';
                        return;
                    }
                    let html = '';
                    notifications.forEach(n => {
                        const icon = n.type === 'stock' ? '🔔' : '📦';
                        const bgClass = n.is_read ? '' : 'bg-light';
                        const time = new Date(n.createdAt).toLocaleString('vi-VN');
                        html += `
                            <div class="p-2 px-3 border-bottom ${bgClass}" style="font-size: 0.85rem; transition: background 0.2s; cursor: default;">
                                <div class="d-flex align-items-start gap-2">
                                    <span style="font-size: 1.2rem;">${icon}</span>
                                    <div>
                                        <div class="text-dark ${n.is_read ? '' : 'fw-bold'}">${n.message}</div>
                                        <small class="text-muted">${time}</small>
                                    </div>
                                </div>
                            </div>
                        `;
                    });
                    notiList.innerHTML = html;
                })
                .catch(() => { });
        }

        if (bellToggle) {
            bellToggle.addEventListener('click', function (e) {
                e.stopPropagation();
                if (notiDropdown.style.display === 'none' || !notiDropdown.style.display) {
                    notiDropdown.style.display = 'block';
                    fetchNotiList();
                } else {
                    notiDropdown.style.display = 'none';
                }
            });

            document.addEventListener('click', function (e) {
                if (notiDropdown && !notiDropdown.contains(e.target) && !bellToggle.contains(e.target)) {
                    notiDropdown.style.display = 'none';
                }
            });

            if (markAllRead) {
                markAllRead.addEventListener('click', function () {
                    fetch('/api/notifications/mark-read', { method: 'POST' })
                        .then(r => r.json())
                        .then(() => {
                            fetchNotiCount();
                            fetchNotiList();
                        });
                });
            }

            fetchNotiCount();
            setInterval(fetchNotiCount, 30000);
        }
    });
</script>
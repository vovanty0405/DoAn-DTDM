<header class="header-bg sticky-top">
    <div class="container">
        <nav class="navbar navbar-expand-lg navbar-dark py-3">
            <a class="navbar-brand fw-bold fs-3" href="/">Bách Hóa Pew</a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav mx-auto align-items-center">
                    <li class="nav-item">
                        <a class="nav-link active-yellow" href="/">Trang chủ</a>
                    </li>
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" id="navbarDropdown" role="button"
                            data-bs-toggle="dropdown">
                            Danh mục
                        </a>
                        <ul class="dropdown-menu custom-dropdown" aria-labelledby="navbarDropdown">
                            <% if (typeof categories !=='undefined' && categories.length> 0) { %>
                                <% categories.forEach(cat=> { %>
                                    <li><a class="dropdown-item" href="/category/<%= cat.slug %>">
                                            <%= cat.name %>
                                        </a></li>
                                    <% }) %>
                                        <% } else { %>
                                            <li><a class="dropdown-item" href="#">Đang cập nhật...</a></li>
                                            <% } %>
                        </ul>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/about">Về chúng tôi</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/contact">Liên hệ</a>
                    </li>
                </ul>
                <!-- User -->
                <ul class="navbar-nav align-items-center">
                    <% if (typeof user !=='undefined' && user) { %>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle fw-bold text-warning" href="#" data-bs-toggle="dropdown">
                                <i class="fas fa-user-circle fs-5 me-1"></i>
                                <%= user.fullname || user.full_name %>
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end border-0 shadow">
                                <% if (user.role==1) { %>
                                    <li><a class="dropdown-item fw-bold text-success" href="/admin/products"><i
                                                class="fas fa-shield-alt me-2"></i> Vào trang Admin</a></li>
                                    <li>
                                        <hr class="dropdown-divider">
                                    </li>
                                    <% } %>
                                        <li><a class="dropdown-item" href="/profile"><i class="fas fa-user-cog me-2"></i> Tài khoản của tôi</a></li>
                                        <li><a class="dropdown-item" href="/orders"><i class="fas fa-box me-2"></i> Đơn
                                                hàng của tôi</a></li>
                                        <li><a class="dropdown-item text-danger" href="/logout"><i
                                                    class="fas fa-sign-out-alt me-2"></i> Đăng xuất</a></li>
                            </ul>
                        </li>
                        <% } else { %>
                            <li class="nav-item">
                                <a class="nav-link" href="#" data-bs-toggle="modal" data-bs-target="#loginModal">Đăng
                                    nhập</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" href="#" data-bs-toggle="modal" data-bs-target="#registerModal">Đăng
                                    ký</a>
                            </li>
                            <% } %>

                                <li class="nav-item ms-lg-2">
                                    <a href="#" class="nav-link text-white" data-bs-toggle="modal"
                                        data-bs-target="#searchModal" title="Tìm kiếm">
                                        <i class="fas fa-search fs-5"></i>
                                    </a>
                                </li>

                                <% if (typeof user !=='undefined' && user) { %>
                                    <!-- Icon Chuông Thông Báo -->
                                    <li class="nav-item ms-lg-2 position-relative" id="notificationBell">
                                        <a href="javascript:void(0);" class="nav-link text-white position-relative"
                                            id="bellToggle" title="Thông báo">
                                            <i class="fas fa-bell fs-5"></i>
                                            <span id="noti-badge"
                                                class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger"
                                                style="font-size: 0.55rem; display: none;">
                                                0
                                            </span>
                                        </a>
                                        <!-- Dropdown Thông báo -->
                                        <div id="notiDropdown"
                                            class="position-absolute bg-white shadow-lg rounded text-start"
                                            style="top: 100%; right: 0; z-index: 9999; display: none; width: 340px; max-height: 400px; overflow-y: auto; border: 1px solid #ddd; margin-top: 8px;">
                                            <div
                                                class="d-flex justify-content-between align-items-center p-3 border-bottom bg-light">
                                                <strong class="text-dark"><i class="fas fa-bell me-1 text-warning"></i>
                                                    Thông báo</strong>
                                                <a href="javascript:void(0);" id="markAllRead"
                                                    class="text-success small text-decoration-none fw-bold">Đánh dấu đã
                                                    đọc</a>
                                            </div>
                                            <div id="notiList">
                                                <div class="p-3 text-center text-muted small">Đang tải...</div>
                                            </div>
                                        </div>
                                    </li>
                                    <% } %>

                                        <li class="nav-item ms-lg-3 mt-2 mt-lg-0">
                                            <a href="/cart" class="cart-icon position-relative text-white">
                                                <i class="fas fa-shopping-cart fs-5"></i>
                                                <span id="cart-badge"
                                                    class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger"
                                                    style="font-size: 0.6rem;">
                                                    <%= typeof cartCount !=='undefined' ? cartCount : 0 %>
                                                </span>
                                            </a>
                                        </li>
                </ul>
            </div>
        </nav>
    </div>
</header>
<script>
    function addToCart(productId) {
        // Gửi request ngầm lên API đã viết trong ApiController
        fetch(`/api/cart/add?id=${productId}`)
            .then(response => response.json())
            .then(data => {
                if (data.status === 'success') {
                    // Cập nhật con số trên icon giỏ hàng đỏ đỏ
                    let badge = document.getElementById('cart-badge');
                    if (badge) {
                        badge.innerText = data.cart_count;

                        // Hiệu ứng giật giật nhẹ cho đẹp mắt (tuỳ chọn)
                        badge.style.transform = 'scale(1.5)';
                        setTimeout(() => badge.style.transform = 'scale(1)', 200);
                    }
                } else {
                    alert(data.message || 'Không thể thêm sản phẩm vào giỏ hàng.');
                }
            })
            .catch(error => console.error('Lỗi khi gọi API giỏ hàng:', error));
    }

    document.addEventListener('DOMContentLoaded', function () {

        // ===== NOTIFICATION BELL LOGIC =====
        const bellToggle = document.getElementById('bellToggle');
        const notiDropdown = document.getElementById('notiDropdown');
        const notiBadge = document.getElementById('noti-badge');
        const notiList = document.getElementById('notiList');
        const markAllRead = document.getElementById('markAllRead');

        // Lấy số thông báo chưa đọc
        function fetchNotiCount() {
            fetch('/api/notifications/count')
                .then(r => r.json())
                .then(data => {
                    if (notiBadge) {
                        if (data.count > 0) {
                            notiBadge.innerText = data.count > 99 ? '99+' : data.count;
                            notiBadge.style.display = '';
                        } else {
                            notiBadge.style.display = 'none';
                        }
                    }
                })
                .catch(() => { });
        }

        // Lấy danh sách thông báo
        function fetchNotiList() {
            fetch('/api/notifications')
                .then(r => r.json())
                .then(notifications => {
                    if (!notiList) return;
                    if (notifications.length === 0) {
                        notiList.innerHTML = '<div class="p-3 text-center text-muted small">Chưa có thông báo nào.</div>';
                        return;
                    }
                    let html = '';
                    notifications.forEach(n => {
                        const icon = n.type === 'stock' ? '🔔' : '📦';
                        const bgClass = n.is_read ? '' : 'bg-light';
                        const time = new Date(n.createdAt).toLocaleString('vi-VN');
                        html += `
                            <div class="p-2 px-3 border-bottom ${bgClass}" style="font-size: 0.85rem; transition: background 0.2s; cursor: default;">
                                <div class="d-flex align-items-start gap-2">
                                    <span style="font-size: 1.2rem;">${icon}</span>
                                    <div>
                                        <div class="text-dark ${n.is_read ? '' : 'fw-bold'}">${n.message}</div>
                                        <small class="text-muted">${time}</small>
                                    </div>
                                </div>
                            </div>
                        `;
                    });
                    notiList.innerHTML = html;
                })
                .catch(() => { });
        }

        if (bellToggle) {
            // Toggle dropdown
            bellToggle.addEventListener('click', function (e) {
                e.stopPropagation();
                if (notiDropdown.style.display === 'none' || !notiDropdown.style.display) {
                    notiDropdown.style.display = 'block';
                    fetchNotiList();
                } else {
                    notiDropdown.style.display = 'none';
                }
            });

            // Đóng dropdown khi click bên ngoài
            document.addEventListener('click', function (e) {
                if (notiDropdown && !notiDropdown.contains(e.target) && !bellToggle.contains(e.target)) {
                    notiDropdown.style.display = 'none';
                }
            });

            // Đánh dấu tất cả đã đọc
            if (markAllRead) {
                markAllRead.addEventListener('click', function () {
                    fetch('/api/notifications/mark-read', { method: 'POST' })
                        .then(r => r.json())
                        .then(() => {
                            fetchNotiCount();
                            fetchNotiList();
                        });
                });
            }

            // Tự động lấy badge count khi load trang + mỗi 30 giây
            fetchNotiCount();
            setInterval(fetchNotiCount, 30000);
        }
    });
</script>
<style>
    .noti-item:hover {
        background-color: #f8f9fa;
    }
    .noti-item .btn-mark-read, .noti-item .btn-delete-noti {
        opacity: 0.6;
        transition: opacity 0.2s, transform 0.2s;
    }
    .noti-item:hover .btn-mark-read, .noti-item:hover .btn-delete-noti {
        opacity: 1;
    }
    .noti-item .btn-mark-read:hover { transform: scale(1.1); color: #198754 !important; }
    .noti-item .btn-delete-noti:hover { transform: scale(1.1); color: #dc3545 !important; }
    
    @media (max-width: 576px) {
        .noti-item .btn-mark-read, .noti-item .btn-delete-noti {
            opacity: 1; /* Hiển thị luôn trên mobile */
        }
    }
</style>

<script>
    function addToCart(productId) {
        fetch(`/api/cart/add?id=${productId}`)
            .then(response => response.json())
            .then(data => {
                if (data.status === 'success') {
                    let badge = document.getElementById('cart-badge');
                    let badgeMobile = document.getElementById('cart-badge-mobile');
                    if (badge) {
                        badge.innerText = data.cart_count;
                        badge.style.transform = 'scale(1.5)';
                        setTimeout(() => badge.style.transform = 'scale(1)', 200);
                    }
                    if (badgeMobile) {
                        badgeMobile.innerText = data.cart_count;
                        badgeMobile.style.transform = 'scale(1.5)';
                        setTimeout(() => badgeMobile.style.transform = 'scale(1)', 200);
                    }
                } else {
                    alert(data.message || 'Không thể thêm sản phẩm vào giỏ hàng.');
                }
            })
            .catch(error => console.error('Lỗi khi gọi API giỏ hàng:', error));
    }

    document.addEventListener('DOMContentLoaded', function () {
        const bellToggle = document.getElementById('bellToggle');
        const notiDropdown = document.getElementById('notiDropdown');
        const notiList = document.getElementById('notiList');
        const markAllRead = document.getElementById('markAllRead');

        function fetchNotiCount() {
            fetch('/api/notifications/count')
                .then(r => r.json())
                .then(data => {
                    const badges = [document.getElementById('noti-badge'), document.querySelector('.noti-count-badge')];
                    badges.forEach(b => {
                        if (b) {
                            if (data.count > 0) {
                                b.innerText = data.count > 99 ? '99+' : data.count;
                                b.style.display = '';
                            } else {
                                b.style.display = 'none';
                            }
                        }
                    });
                })
                .catch(() => { });
        }

        function fetchNotiList() {
            fetch('/api/notifications')
                .then(r => r.json())
                .then(notifications => {
                    const containers = [document.getElementById('notiList'), document.getElementById('mobileNotiList')];
                    
                    containers.forEach(container => {
                        if (!container) return;
                        if (notifications.length === 0) {
                            container.innerHTML = '<div class="p-3 text-center text-muted small">Chưa có thông báo nào.</div>';
                            return;
                        }
                        let html = '';
                        notifications.forEach(n => {
                            const icon = n.type === 'stock' ? '🔔' : '📦';
                            const bgClass = n.is_read ? '' : 'bg-light';
                            const time = new Date(n.createdAt).toLocaleString('vi-VN');
                            
                            html += `
                                <div class="p-3 border-bottom ${bgClass} position-relative noti-item" data-id="${n._id}" style="font-size: 0.85rem; transition: background 0.2s;">
                                    <div class="d-flex align-items-start gap-2 pe-5">
                                        <span style="font-size: 1.2rem;">${icon}</span>
                                        <div>
                                            <div class="text-dark ${n.is_read ? '' : 'fw-bold'}">${n.message}</div>
                                            <small class="text-muted d-block mt-1">${time}</small>
                                        </div>
                                    </div>
                                    <div class="position-absolute top-50 translate-middle-y end-0 me-2 d-flex flex-column gap-1">
                                        ${!n.is_read ? `
                                            <button class="btn btn-sm btn-light p-1 border shadow-sm text-success btn-mark-read" title="Đã đọc" onclick="markReadSingle('${n._id}')">
                                                <i class="fas fa-check"></i>
                                            </button>
                                        ` : ''}
                                        <button class="btn btn-sm btn-light p-1 border shadow-sm text-danger btn-delete-noti" title="Xóa" onclick="deleteNoti('${n._id}')">
                                            <i class="fas fa-trash-alt"></i>
                                        </button>
                                    </div>
                                </div>
                            `;
                        });
                        container.innerHTML = html;
                    });
                })
                .catch(() => { });
        }

        window.markReadSingle = function(id) {
            fetch(`/api/notifications/mark-read/${id}`, { method: 'POST' })
                .then(r => r.json())
                .then(data => {
                    if (data.status === 'success') {
                        fetchNotiCount();
                        fetchNotiList();
                    }
                });
        };

        window.deleteNoti = function(id) {
            if (!confirm('Bạn muốn xóa thông báo này?')) return;
            fetch(`/api/notifications/${id}`, { method: 'DELETE' })
                .then(r => r.json())
                .then(data => {
                    if (data.status === 'success') {
                        fetchNotiCount();
                        fetchNotiList();
                    }
                });
        };

        if (bellToggle) {
            bellToggle.addEventListener('click', function (e) {
                e.stopPropagation();
                if (notiDropdown.style.display === 'none' || !notiDropdown.style.display) {
                    notiDropdown.style.display = 'block';
                    fetchNotiList();
                } else {
                    notiDropdown.style.display = 'none';
                }
            });

            document.addEventListener('click', function (e) {
                if (notiDropdown && !notiDropdown.contains(e.target) && !bellToggle.contains(e.target)) {
                    notiDropdown.style.display = 'none';
                }
            });

            if (markAllRead) {
                markAllRead.addEventListener('click', function () {
                    fetch('/api/notifications/mark-read', { method: 'POST' })
                        .then(r => r.json())
                        .then(() => {
                            fetchNotiCount();
                            fetchNotiList();
                        });
                });
            }

            const markAllReadMobile = document.getElementById('markAllReadMobile');
            if (markAllReadMobile) {
                markAllReadMobile.addEventListener('click', function () {
                    fetch('/api/notifications/mark-read', { method: 'POST' })
                        .then(r => r.json())
                        .then(() => {
                            fetchNotiCount();
                            fetchNotiList();
                        });
                });
            }

            // Mở modal thông báo trên mobile thì fetch list
            const mobileNotiModal = document.getElementById('mobileNotiModal');
            if (mobileNotiModal) {
                mobileNotiModal.addEventListener('show.bs.modal', function () {
                    fetchNotiList();
                });
            }

            fetchNotiCount();
            setInterval(fetchNotiCount, 30000);
        }
    });
</script>

<!-- Mobile Notification Modal -->

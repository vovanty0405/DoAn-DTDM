<% products.forEach(product => { %>
    <% 
        // Tính toán trước để tránh lỗi linter đỏ trong style/class
        const isOutOfStock = product.stock_quantity <= 0;
        const discountPercent = product.discount_price ? Math.round(((product.price - product.discount_price) / product.price) * 100) : 0;
        
        // Tạo các chuỗi attribute hoàn chỉnh để linter không soi được nội dung CSS/JS bên trong
        const imgStyleAttr = isOutOfStock ? 'style="opacity: 0.5;"' : '';
        const cardClass = "card product-card h-100 shadow-sm position-relative overflow-hidden " + (isOutOfStock ? "border-0" : "border");
    %>
    <div class="col-6 col-md-3 mb-4 p-2 p-md-3">
        <div class="<%- cardClass %>">
            <% if (product.discount_price) { %>
                <div class="badge-discount position-absolute top-0 end-0 m-2 bg-danger text-white px-2 py-1 rounded" style="z-index: 10; font-size: 0.75rem; font-weight: bold;">
                    -<%= discountPercent %>%
                </div>
            <% } %>

            <% if (isOutOfStock) { %>
                <div class="position-absolute top-0 start-0 m-2 badge bg-dark text-white px-2 py-1 rounded" style="z-index: 10; font-size: 0.7rem;">
                    <i class="fas fa-exclamation-circle me-1"></i>Hết hàng
                </div>
            <% } %>

            <a href="/product/<%= product._id %>" class="text-decoration-none">
                <div class="product-img-wrapper" <%- imgStyleAttr %>>
                    <img src="/<%= product.cover_image %>" alt="<%= product.name %>" class="img-cover p-2">
                </div>
            </a>

            <div class="card-body text-center p-2 p-md-3">
                <a href="/product/<%= product._id %>" class="text-decoration-none">
                    <h6 class="card-title fw-bold text-dark text-truncate-2 mb-2" style="min-height: 38px; font-size: 0.9rem;">
                        <%= product.name %>
                    </h6>
                </a>

                <% if (product.discount_price) { %>
                    <div class="text-muted text-decoration-line-through small" style="font-size: 0.75rem;">
                        <%= product.price.toLocaleString('vi-VN') %> đ
                    </div>
                    <div class="fw-bold text-danger mb-2" style="font-size: 1rem;">
                        <%= product.discount_price.toLocaleString('vi-VN') %> đ
                    </div>
                <% } else { %>
                    <div class="text-muted small" style="font-size: 0.75rem;">&nbsp;</div>
                    <div class="fw-bold text-dark mb-2" style="font-size: 1rem;">
                        <%= product.price.toLocaleString('vi-VN') %> đ
                    </div>
                <% } %>

                <% if (typeof type !== 'undefined' && type === 'sale') { %>
                    <% 
                        const stock = product.stock_quantity; 
                        const stockPercent = (stock <= 100) ? stock : 50; 
                        const progressStyle = `style="width: ${stockPercent}%; border-radius: 50px;"`;
                    %>
                    <div class="text-center fw-bold mb-1 mt-1" style="font-size: 0.65rem; color: #ff7f00;">Tối đa 5 sp/đơn</div>
                    <div class="position-relative mb-3 mx-auto" style="max-width: 100%;">
                        <div class="progress" style="height: 16px; border-radius: 50px; background-color: #fef0cd;">
                            <div class="progress-bar bg-warning" role="progressbar" <%- progressStyle %>></div>
                        </div>
                        <div class="position-absolute top-50 start-50 translate-middle w-100 text-center" style="font-size: 0.65rem; font-weight: 700; color: #333; line-height: 16px;">
                            Còn <%= stock %> suất
                        </div>
                    </div>
                <% } %>

                <div class="d-flex justify-content-center align-items-center gap-2 mt-auto">
                    <% if (product.stock_quantity > 0) { %>
                        <a href="javascript:void(0);" onclick="addToCart('<%= product._id %>')" class="text-tempi-green transition-zoom p-1" title="Thêm vào giỏ hàng">
                            <i class="fas fa-cart-plus fs-5"></i>
                        </a>
                        <a href="/cart/buy-now/<%= product._id %>" class="btn btn-tempi-green btn-sm flex-grow-1 text-white rounded-pill fw-bold shadow-sm" style="font-size: 0.75rem;">
                            Mua ngay
                        </a>
                    <% } else { %>
                        <a href="/product/<%= product._id %>" class="btn btn-secondary btn-sm flex-grow-1 rounded-pill text-white fw-bold opacity-75" style="font-size: 0.75rem;">
                            <i class="fas fa-clock me-1"></i> Chi tiết
                        </a>
                    <% } %>
                </div>
            </div>
        </div>
    </div>
<% }) %>
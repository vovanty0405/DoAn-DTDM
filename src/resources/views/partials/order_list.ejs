<% 
    // Lọc đơn hàng theo Tab hiển thị
    let filteredOrders = orders;
    if (filterStatus !== 'all') {
        filteredOrders = orders.filter(o => filterStatus.includes(o.status));
    }
%>

<% if (filteredOrders && filteredOrders.length > 0) { %>
    <% filteredOrders.forEach(order => { %>
        <div class="order-card">
            <div class="order-header">
                <div>
                    <span class="fw-bold text-dark">Mã đơn: #<%= order._id.toString().slice(-8).toUpperCase() %></span>
                    <small class="text-muted ms-3"><i class="far fa-clock"></i> <%= new Date(order.createdAt).toLocaleString('vi-VN') %></small>
                </div>
                <div>
                    <% if (order.status === 0) { %>
                        <span class="status-badge bg-status-0"><i class="fas fa-box me-1"></i> Mới đặt</span>
                    <% } else if (order.status === 1) { %>
                        <span class="status-badge bg-status-1"><i class="fas fa-boxes me-1"></i> Đang chuẩn bị</span>
                    <% } else if (order.status === 2) { %>
                        <span class="status-badge bg-status-2"><i class="fas fa-truck me-1"></i> Đang giao hàng</span>
                    <% } else if (order.status === 3) { %>
                        <span class="status-badge bg-status-3"><i class="fas fa-check-circle me-1"></i> Hoàn thành</span>
                    <% } %>
                </div>
            </div>
            
            <div class="order-body">
                <% if (order.items && order.items.length > 0) { %>
                    <% order.items.forEach(item => { %>
                        <div class="order-item">
                            <img src="/<%= item.product_id ? item.product_id.cover_image : 'image/default.png' %>" class="item-img" alt="Product">
                            <div class="item-details">
                                <h6 class="fw-bold mb-1">
                                    <a href="/product/<%= item.product_id ? item.product_id._id : '#' %>" class="text-dark text-decoration-none">
                                        <%= item.product_id ? item.product_id.name : 'Sản phẩm không còn tồn tại' %>
                                    </a>
                                </h6>
                                <p class="text-muted small mb-2">Phân loại: Gói tiêu chuẩn</p>
                                <div class="d-flex justify-content-between align-items-center">
                                    <span class="text-dark">x<%= item.quantity %></span>
                                    <span class="fw-semibold text-danger"><%= item.price.toLocaleString('vi-VN') %> đ</span>
                                </div>
                            </div>
                        </div>
                    <% }) %>
                <% } else { %>
                    <p class="text-muted mb-0">Đơn hàng cũ không lưu chi tiết món.</p>
                <% } %>
            </div>
            
            <div class="order-footer">
                <div class="d-flex justify-content-between align-items-center">
                    <div class="text-start">
                        <small class="text-muted d-block">Hình thức thanh toán: <%= order.payment_method === 'cod' ? 'Thanh toán tiền mặt (COD)' : order.payment_method %></small>
                        <small class="text-muted d-block">Giao đến: <%= order.address %></small>
                    </div>
                    <div class="text-end">
                        <span class="text-muted me-2">Thành tiền:</span>
                        <span class="fs-4 fw-bold text-tempi-green"><%= order.total_money.toLocaleString('vi-VN') %> đ</span>
                    </div>
                </div>
            </div>
        </div>
    <% }) %>
<% } else { %>
    <div class="text-center p-5 bg-white border rounded shadow-sm">
        <img src="/image/empty-cart.png" alt="Empty" style="width: 150px; opacity: 0.5;" class="mb-3" onerror="this.src='https://cdn-icons-png.flaticon.com/512/2038/2038854.png'">
        <h5 class="text-muted fw-bold">Chưa có đơn hàng nào</h5>
        <p class="text-muted mb-4">Bạn chưa có đơn hàng nào trong trạng thái này.</p>
        <a href="/" class="btn btn-warning fw-bold px-4">Tiếp tục mua sắm</a>
    </div>
<% } %>

<% 
    // Lọc đơn hàng theo Tab hiển thị
    let filteredOrders = orders;
    if (filterStatus !== 'all') {
        filteredOrders = orders.filter(o => filterStatus.includes(o.status));
    }
%>

<% if (filteredOrders && filteredOrders.length > 0) { %>
    <% filteredOrders.forEach(order => { %>
        <div class="order-card">
            <div class="order-header">
                <div>
                    <span class="fw-bold text-dark">Mã đơn: #<%= order._id.toString().slice(-8).toUpperCase() %></span>
                    <small class="text-muted ms-3"><i class="far fa-clock"></i> <%= new Date(order.createdAt).toLocaleString('vi-VN') %></small>
                </div>
                <div>
                    <% if (order.status === 0) { %>
                        <span class="status-badge bg-status-0"><i class="fas fa-box me-1"></i> Mới đặt</span>
                    <% } else if (order.status === 1) { %>
                        <span class="status-badge bg-status-1"><i class="fas fa-boxes me-1"></i> Đang chuẩn bị</span>
                    <% } else if (order.status === 2) { %>
                        <span class="status-badge bg-status-2"><i class="fas fa-truck me-1"></i> Đang giao hàng</span>
                    <% } else if (order.status === 3) { %>
                        <span class="status-badge bg-status-3"><i class="fas fa-check-circle me-1"></i> Hoàn thành</span>
                    <% } %>
                    <button type="button" class="btn btn-sm btn-outline-info border-0 ms-2" onclick="showDeliveryMap('<%= order.address %>', <%= order.status %>)">
                        <i class="fas fa-map-marked-alt text-info"></i> <span class="fw-medium">Xem lộ trình</span>
                    </button>
                </div>
            </div>
            
            <div class="order-body">
                <!-- Order Timeline Stepper -->
                <div class="position-relative mb-4 mt-2 px-md-4">
                    <div class="progress" style="height: 4px; position: absolute; top: 15px; left: 10%; right: 10%; width: 80%; z-index: 1;">
                        <div class="progress-bar bg-success" role="progressbar" style="width: <%= order.status === 0 ? '0%' : (order.status === 1 ? '33%' : (order.status === 2 ? '66%' : '100%')) %>" aria-valuenow="50" aria-valuemin="0" aria-valuemax="100"></div>
                    </div>
                    <div class="d-flex justify-content-between position-relative z-index-2" style="z-index: 2;">
                        <!-- Step 1 -->
                        <div class="text-center" style="width: 25%;">
                            <div class="rounded-circle d-flex align-items-center justify-content-center mx-auto mb-2 <%= order.status >= 0 ? 'bg-success text-white' : 'bg-light text-muted border' %>" style="width: 35px; height: 35px; box-shadow: 0 0 0 4px #fff;">
                                <i class="fas fa-file-invoice"></i>
                            </div>
                            <small class="<%= order.status >= 0 ? 'fw-bold text-success' : 'text-muted' %>">Đã đặt hàng</small>
                        </div>
                        <!-- Step 2 -->
                        <div class="text-center" style="width: 25%;">
                            <div class="rounded-circle d-flex align-items-center justify-content-center mx-auto mb-2 <%= order.status >= 1 ? 'bg-success text-white' : 'bg-light text-muted border' %>" style="width: 35px; height: 35px; box-shadow: 0 0 0 4px #fff;">
                                <i class="fas fa-box-open"></i>
                            </div>
                            <small class="<%= order.status >= 1 ? 'fw-bold text-success' : 'text-muted' %>">Đang xử lý</small>
                        </div>
                        <!-- Step 3 -->
                        <div class="text-center" style="width: 25%;">
                            <div class="rounded-circle d-flex align-items-center justify-content-center mx-auto mb-2 <%= order.status >= 2 ? 'bg-success text-white' : 'bg-light text-muted border' %>" style="width: 35px; height: 35px; box-shadow: 0 0 0 4px #fff;">
                                <i class="fas fa-truck"></i>
                            </div>
                            <small class="<%= order.status >= 2 ? 'fw-bold text-success' : 'text-muted' %>">Đang giao</small>
                        </div>
                        <!-- Step 4 -->
                        <div class="text-center" style="width: 25%;">
                            <div class="rounded-circle d-flex align-items-center justify-content-center mx-auto mb-2 <%= order.status >= 3 ? 'bg-success text-white' : 'bg-light text-muted border' %>" style="width: 35px; height: 35px; box-shadow: 0 0 0 4px #fff;">
                                <i class="fas fa-check"></i>
                            </div>
                            <small class="<%= order.status >= 3 ? 'fw-bold text-success' : 'text-muted' %>">Hoàn thành</small>
                        </div>
                    </div>
                </div>
                <hr class="text-muted border-dashed mb-3">

                <% if (order.items && order.items.length > 0) { %>
                    <% order.items.forEach(item => { %>
                        <div class="order-item">
                            <img src="/<%= item.product_id ? item.product_id.cover_image : 'image/default.png' %>" class="item-img" alt="Product">
                            <div class="item-details">
                                <h6 class="fw-bold mb-1">
                                    <a href="/product/<%= item.product_id ? item.product_id._id : '#' %>" class="text-dark text-decoration-none">
                                        <%= item.product_id ? item.product_id.name : 'Sản phẩm không còn tồn tại' %>
                                    </a>
                                </h6>
                                <p class="text-muted small mb-2">Phân loại: Gói tiêu chuẩn</p>
                                <div class="d-flex justify-content-between align-items-center">
                                    <span class="text-dark">x<%= item.quantity %></span>
                                    <span class="fw-semibold text-danger"><%= item.price.toLocaleString('vi-VN') %> đ</span>
                                </div>
                            </div>
                        </div>
                    <% }) %>
                <% } else { %>
                    <p class="text-muted mb-0">Đơn hàng cũ không lưu chi tiết món.</p>
                <% } %>
            </div>
            
            <div class="order-footer">
                <div class="d-flex justify-content-between align-items-center">
                    <div class="text-start">
                        <small class="text-muted d-block">Hình thức thanh toán: <%= order.payment_method === 'cod' ? 'Thanh toán tiền mặt (COD)' : order.payment_method %></small>
                        <small class="text-muted d-block">Giao đến: <%= order.address %></small>
                    </div>
                    <div class="text-end">
                        <span class="text-muted me-2">Thành tiền:</span>
                        <span class="fs-4 fw-bold text-tempi-green"><%= order.total_money.toLocaleString('vi-VN') %> đ</span>
                    </div>
                </div>
            </div>
        </div>
    <% }) %>
<% } else { %>
    <div class="text-center p-5 bg-white border rounded shadow-sm">
        <img src="/image/empty-cart.png" alt="Empty" style="width: 150px; opacity: 0.5;" class="mb-3" onerror="this.src='https://cdn-icons-png.flaticon.com/512/2038/2038854.png'">
        <h5 class="text-muted fw-bold">Chưa có đơn hàng nào</h5>
        <p class="text-muted mb-4">Bạn chưa có đơn hàng nào trong trạng thái này.</p>
        <a href="/" class="btn btn-warning fw-bold px-4">Tiếp tục mua sắm</a>
    </div>
<% } %>

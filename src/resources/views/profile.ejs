<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Bách Hóa Pew</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/style.css">
    <link href="/css/style.css" rel="stylesheet" />
</head>

<body class="bg-light">

    <!-- Header -->
    <%- include('partials/navbar') %>

        <section class="container my-5">
            <div class="row justify-content-center">
                <div class="col-lg-8">
                    <div class="card border-0 shadow-sm rounded-4">
                        <div class="card-header bg-white border-bottom p-4">
                            <h4 class="mb-0 fw-bold text-tempi-green">
                                <i class="fas fa-user-cog me-2"></i> Tài khoản của tôi
                            </h4>
                        </div>
                        <div class="card-body p-4 p-md-5">
                            <% if (typeof message !=='undefined' && message) { %>
                                <div class="alert alert-success mt-2 mb-4"><i class="fas fa-check-circle me-1"></i>
                                    <%= message %>
                                </div>
                                <% } %>
                                    <% if (typeof error !=='undefined' && error) { %>
                                        <div class="alert alert-danger mt-2 mb-4"><i
                                                class="fas fa-exclamation-circle me-1"></i>
                                            <%= error %>
                                        </div>
                                        <% } %>

                                            <form action="/profile/update" method="POST">
                                                <h5 class="fw-bold mb-3 text-secondary">Thông tin cá nhân</h5>

                                                <div class="mb-3">
                                                    <label class="form-label fw-bold">Họ và tên</label>
                                                    <input type="text" name="fullname"
                                                        class="form-control form-control-lg bg-light"
                                                        value="<%= user.fullname %>" required>
                                                </div>

                                                <div class="mb-3">
                                                    <label class="form-label fw-bold">Email</label>
                                                    <input type="email"
                                                        class="form-control form-control-lg bg-light text-muted"
                                                        value="<%= user.email %>" readonly disabled>
                                                    <small class="text-muted">Email không thể thay đổi sau khi đăng
                                                        ký.</small>
                                                </div>

                                                <div class="mb-3">
                                                    <label class="form-label fw-bold">Số điện thoại</label>
                                                    <input type="text"
                                                        class="form-control form-control-lg bg-light text-muted"
                                                        value="<%= user.phone %>" readonly disabled>
                                                    <small class="text-muted">Số điện thoại không thể thay đổi.</small>
                                                </div>

                                                <div class="mb-4">
                                                    <label class="form-label fw-bold">Địa chỉ giao hàng</label>
                                                    <input type="text" name="address"
                                                        class="form-control form-control-lg bg-light"
                                                        value="<%= user.address || '' %>" required>
                                                </div>

                                                <hr class="my-4">

                                                <h5 class="fw-bold mb-3 text-secondary">Đổi mật khẩu <small
                                                        class="text-muted fw-normal fs-6">(Bỏ trống nếu không muốn
                                                        đổi)</small></h5>

                                                <div class="mb-3">
                                                    <label class="form-label fw-bold">Mật khẩu hiện tại</label>
                                                    <input type="password" name="current_password"
                                                        class="form-control form-control-lg bg-light"
                                                        placeholder="Nhập để xác thực việc đổi mật khẩu">
                                                </div>

                                                <div class="row">
                                                    <div class="col-md-6 mb-3">
                                                        <label class="form-label fw-bold">Mật khẩu mới</label>
                                                        <input type="password" name="new_password"
                                                            class="form-control form-control-lg bg-light"
                                                            placeholder="Ít nhất 6 ký tự" minlength="6">
                                                    </div>
                                                    <div class="col-md-6 mb-4">
                                                        <label class="form-label fw-bold">Xác nhận mật khẩu mới</label>
                                                        <input type="password" name="confirm_password"
                                                            class="form-control form-control-lg bg-light"
                                                            placeholder="Nhập lại mật khẩu mới" minlength="6">
                                                    </div>
                                                </div>

                                                <div class="text-end">
                                                    <button type="submit"
                                                        class="btn btn-tempi-green text-white px-5 py-2 fw-bold rounded-pill shadow-sm">
                                                        <i class="fas fa-save me-1"></i> LƯU THAY ĐỔI
                                                    </button>
                                                </div>
                                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Footer -->
        <%- include('partials/footer') %>

            <!-- Modal -->
            <%- include('partials/modal') %>

                <%- include('partials/javascript') %>
</body>

</html>

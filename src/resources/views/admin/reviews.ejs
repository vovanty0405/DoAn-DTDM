<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Quản lý Đánh Giá - Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        .sidebar {
            min-height: 100vh;
            background-color: #005a3c;
        }

        .sidebar a {
            color: #fff;
            text-decoration: none;
            padding: 12px 20px;
            display: block;
            transition: 0.3s;
        }

        .sidebar a:hover,
        .sidebar a.active {
            background-color: #00452d;
            border-left: 4px solid #f9b612;
        }
    </style>
</head>

<body class="bg-light">
    <div class="container-fluid">
        <div class="row">
            <div class="col-md-2 p-0 sidebar text-white">
                <div class="p-4 text-center border-bottom border-secondary">
                    <h4 class="fw-bold text-warning mb-0">BÁCH HÓA PEW</h4>
                    <div class="mt-2 small opacity-75">
                        <i class="fas fa-user-shield"></i> Quản trị viên<br>
                        <span style="font-size: 0.8em;">ID: ADMIN</span>
                    </div>
                </div>
                <div class="mt-3">
                    <a href="/admin/categories"><i class="fas fa-list me-2"></i> Danh Mục Gốc</a>
                    <a href="/admin/sub_categories"><i class="fas fa-tags me-2"></i> Thể Loại Con</a>
                    <a href="/admin/brands"><i class="fas fa-copyright me-2"></i> Hãng Sản Xuất</a>
                    <a href="/admin/products"><i class="fas fa-box me-2"></i> Sản Phẩm</a>
                    <a href="/admin/customers"><i class="fas fa-users me-2"></i> Khách Hàng</a>
                    <a href="/admin/orders"><i class="fas fa-file-invoice-dollar me-2"></i> Đơn Hàng</a>
                    <a href="/admin/contacts"><i class="fas fa-envelope me-2"></i> Liên Hệ</a>
                    <a href="/admin/reviews" class="active"><i class="fas fa-star me-2"></i> Đánh Giá</a>
                    <a href="/admin/promotions"><i class="fas fa-percent me-2"></i> Khuyến Mãi</a>
                    <a href="/logout" class="text-danger mt-5"><i class="fas fa-sign-out-alt me-2"></i> Đăng xuất</a>
                </div>
            </div>

            <div class="col-md-10 p-5">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h2 class="fw-bold">Quản lý Đánh Giá Sản Phẩm</h2>
                </div>

                <!-- Bộ lọc tìm kiếm -->
                <div class="card shadow-sm border-0 mb-4">
                    <div class="card-body">
                        <form action="/admin/reviews" method="GET" class="row g-2 align-items-end">
                            <div class="col-md-4">
                                <label class="form-label small fw-bold">Tìm kiếm (Người đánh giá / Sản phẩm)</label>
                                <input type="text" name="keyword" class="form-control" placeholder="Nhập tên người dùng hoặc sản phẩm..." value="<%= (typeof query !== 'undefined' && query.keyword) ? query.keyword : '' %>">
                            </div>
                            <div class="col-md-3">
                                <label class="form-label small fw-bold">Từ ngày</label>
                                <input type="date" name="from_date" class="form-control" value="<%= (typeof query !== 'undefined' && query.from_date) ? query.from_date : '' %>">
                            </div>
                            <div class="col-md-3">
                                <label class="form-label small fw-bold">Đến ngày</label>
                                <input type="date" name="to_date" class="form-control" value="<%= (typeof query !== 'undefined' && query.to_date) ? query.to_date : '' %>">
                            </div>
                            <div class="col-md-1">
                                <button type="submit" class="btn btn-primary w-100"><i class="fas fa-search"></i></button>
                            </div>
                            <div class="col-md-1">
                                <a href="/admin/reviews" class="btn btn-secondary w-100" title="Xóa lọc"><i class="fas fa-times"></i></a>
                            </div>
                        </form>
                    </div>
                </div>

                <div class="card shadow-sm border-0">
                    <div class="card-body">
                        <table class="table table-hover align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th>Thời gian</th>
                                    <th>Người Đánh Giá</th>
                                    <th>Sản phẩm</th>
                                    <th>Sao</th>
                                    <th>Nội dung</th>
                                    <th>Phản hồi</th>
                                    <th>Trạng thái</th>
                                    <th class="text-center">Thao tác</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% if (typeof reviews !=='undefined' && reviews.length > 0) { %>
                                    <% reviews.forEach(review => { %>
                                        <tr>
                                            <td><small>
                                                    <%= new Date(review.createdAt).toLocaleString('vi-VN') %>
                                                </small></td>
                                            <td>
                                                <strong>
                                                    <%= review.user_id ? review.user_id.fullname : 'Khách ẩn danh' %>
                                                </strong>
                                                <% if (review.user_id && review.user_id.role === 1) { %>
                                                    <br><span class="badge bg-warning text-dark" style="font-size: 0.65rem;"><i class="fas fa-shield-alt me-1"></i>Admin</span>
                                                <% } %>
                                            </td>
                                            <td>
                                                <a href="/product/<%= review.product_id ? review.product_id._id : '' %>"
                                                    target="_blank" class="text-decoration-none">
                                                    <%= review.product_id ? review.product_id.name : 'Sản phẩm đã xóa' %>
                                                </a>
                                            </td>
                                            <td class="text-warning">
                                                <% for(let i=0; i < (review.rating || 0); i++) { %><i class="fas fa-star"></i>
                                                    <% } %>
                                                <% for(let i=0; i < (5 - (review.rating || 0)); i++) { %><i class="far fa-star text-muted"></i>
                                                    <% } %>
                                            </td>
                                            <td style="max-width: 200px;" class="text-truncate"
                                                title="<%= review.comment %>">
                                                <%= review.comment %>
                                            </td>
                                            <td>
                                                <% 
                                                    let replyCount = 0;
                                                    if (review.childReplies) replyCount += review.childReplies.length;
                                                    if (review.replies) replyCount += review.replies.length;
                                                %>
                                                <% if (replyCount > 0) { %>
                                                    <span class="badge bg-info"><%= replyCount %> phản hồi</span>
                                                <% } else { %>
                                                    <span class="text-muted small">—</span>
                                                <% } %>
                                            </td>
                                            <td>
                                                <form action="/admin/reviews/update" method="POST" class="d-inline">
                                                    <input type="hidden" name="id" value="<%= review._id %>">
                                                    <select name="status"
                                                        class="form-select form-select-sm d-inline w-auto"
                                                        onchange="this.form.submit()">
                                                        <option value="1" <%=review.status===1 ? 'selected' : '' %>>Đã duyệt</option>
                                                        <option value="2" <%=review.status===2 ? 'selected' : '' %>>Từ chối</option>
                                                    </select>
                                                </form>
                                            </td>
                                            <td class="text-center">
                                                <button type="button" class="btn btn-sm btn-info text-white me-1" data-bs-toggle="modal" data-bs-target="#replyModal<%= review._id %>" title="Xem & Phản hồi">
                                                    <i class="fas fa-reply"></i>
                                                </button>
                                                <a href="/admin/reviews/delete/<%= review._id %>"
                                                    class="btn btn-sm btn-danger"
                                                    onclick="return confirm('Xóa đánh giá này và tất cả phản hồi?');" title="Xóa">
                                                    <i class="fas fa-trash"></i>
                                                </a>

                                                <!-- Modal Phản hồi (Nâng cấp) -->
                                                <div class="modal fade text-start" id="replyModal<%= review._id %>" tabindex="-1" aria-hidden="true">
                                                    <div class="modal-dialog modal-lg">
                                                        <div class="modal-content">
                                                            <div class="modal-header bg-light">
                                                                <h5 class="modal-title">
                                                                    <i class="fas fa-comments me-2 text-primary"></i>
                                                                    Đánh giá của <%= review.user_id ? review.user_id.fullname : 'Khách' %>
                                                                </h5>
                                                                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                                            </div>
                                                            <div class="modal-body">
                                                                <!-- Đánh giá gốc -->
                                                                <div class="p-3 bg-light rounded border mb-3">
                                                                    <div class="d-flex justify-content-between align-items-center mb-2">
                                                                        <strong class="text-dark">
                                                                            <i class="fas fa-user-circle me-1 text-success"></i>
                                                                            <%= review.user_id ? review.user_id.fullname : 'Khách' %>
                                                                        </strong>
                                                                        <small class="text-muted"><%= new Date(review.createdAt).toLocaleString('vi-VN') %></small>
                                                                    </div>
                                                                    <div class="text-warning mb-2">
                                                                        <% for(let i=0; i < (review.rating || 0); i++) { %><i class="fas fa-star"></i><% } %>
                                                                    </div>
                                                                    <p class="mb-0"><%= review.comment || '(Không có bình luận)' %></p>
                                                                </div>

                                                                <!-- Danh sách phản hồi hiện có -->
                                                                <% 
                                                                    let allExistingReplies = [];
                                                                    if (review.childReplies) { 
                                                                        review.childReplies.forEach(r => allExistingReplies.push(r));
                                                                    }
                                                                %>
                                                                <% if (allExistingReplies.length > 0) { %>
                                                                    <h6 class="fw-bold text-muted mb-2"><i class="fas fa-stream me-1"></i> Phản hồi (<%= allExistingReplies.length %>)</h6>
                                                                    <% allExistingReplies.forEach(reply => { %>
                                                                        <div class="ms-3 mb-2 p-2 border-start border-3 rounded bg-white" style="border-color: <%= (reply.user_id && reply.user_id.role === 1) ? '#198754' : '#0d6efd' %> !important;">
                                                                            <div class="d-flex justify-content-between align-items-center">
                                                                                <div>
                                                                                    <strong style="color: <%= (reply.user_id && reply.user_id.role === 1) ? '#198754' : '#0d6efd' %>;">
                                                                                        <i class="fas fa-reply me-1"></i>
                                                                                        <%= reply.user_id ? reply.user_id.fullname : 'Khách' %>
                                                                                    </strong>
                                                                                    <% if (reply.user_id && reply.user_id.role === 1) { %>
                                                                                        <span class="badge bg-success ms-1" style="font-size: 0.6rem;">Quản trị viên</span>
                                                                                    <% } %>
                                                                                </div>
                                                                                <small class="text-muted"><%= new Date(reply.createdAt).toLocaleString('vi-VN') %></small>
                                                                            </div>
                                                                            <p class="mb-0 mt-1 small"><%= reply.comment %></p>
                                                                        </div>
                                                                    <% }) %>
                                                                <% } %>

                                                                <!-- Form gửi phản hồi từ Admin -->
                                                                <hr>
                                                                <form action="/admin/reviews/reply/<%= review._id %>" method="POST">
                                                                    <div class="mb-3">
                                                                        <label class="form-label fw-bold">
                                                                            <i class="fas fa-pen-fancy me-1 text-primary"></i> Phản hồi từ Quản trị viên
                                                                        </label>
                                                                        <textarea name="reply_comment" class="form-control" rows="3" required placeholder="Nhập câu trả lời cho khách hàng..."></textarea>
                                                                    </div>
                                                                    <div class="d-flex justify-content-end gap-2">
                                                                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Đóng</button>
                                                                        <button type="submit" class="btn btn-primary"><i class="fas fa-paper-plane me-1"></i> Gửi phản hồi</button>
                                                                    </div>
                                                                </form>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                            </td>
                                        </tr>
                                        <% }) %>
                                            <% } else { %>
                                                <tr>
                                                    <td colspan="8" class="text-center py-4 text-muted">Không tìm thấy dữ liệu phù hợp.</td>
                                                </tr>
                                                <% } %>
                            </tbody>
                        </table>
                    </div>
                    <%- include('../partials/pagination', { currentPage, totalPages, query: query || {} }) %>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>
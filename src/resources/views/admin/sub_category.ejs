<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Quản lý Thể Loại Con - Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        .sidebar {
            min-height: 100vh;
            background-color: #005a3c;
        }

        .sidebar a {
            color: #fff;
            text-decoration: none;
            padding: 12px 20px;
            display: block;
            transition: 0.3s;
        }

        .sidebar a:hover,
        .sidebar a.active {
            background-color: #00452d;
            border-left: 4px solid #f9b612;
        }
    </style>
</head>

<body class="bg-light">
    <div class="container-fluid">
        <div class="row">
            <div class="col-md-2 p-0 sidebar text-white">
                <div class="p-4 text-center border-bottom border-secondary">
                    <h4 class="fw-bold text-warning mb-0">BÁCH HÓA PEW</h4>
                    <div class="mt-2 small opacity-75">
                        <i class="fas fa-user-shield"></i> Quản trị viên<br>
                        <span style="font-size: 0.8em;">ID: ADMIN</span>
                    </div>
                </div>
                <div class="mt-3">
                    <a href="/admin/categories"><i class="fas fa-list me-2"></i> Danh Mục Gốc</a>
                    <a href="/admin/sub_categories" class="active"><i class="fas fa-tags me-2"></i> Thể Loại Con</a>
                    <a href="/admin/brands"><i class="fas fa-copyright me-2"></i> Hãng Sản Xuất</a>
                    <a href="/admin/products"><i class="fas fa-box me-2"></i> Sản Phẩm</a>
                    <a href="/admin/customers"><i class="fas fa-users me-2"></i> Khách Hàng</a>
                    <a href="/admin/orders"><i class="fas fa-file-invoice-dollar me-2"></i> Đơn Hàng</a>
                    <a href="/admin/reviews"><i class="fas fa-star me-2"></i> Đánh Giá</a>
                    <a href="/admin/contacts"><i class="fas fa-envelope me-2"></i> Liên Hệ</a>
                    <a href="/admin/promotions"><i class="fas fa-percent me-2"></i> Khuyến Mãi Hàng Loạt</a>
                    <a href="/admin/vouchers"><i class="fas fa-ticket-alt me-2"></i> Mã Giảm Giá</a>
                    <a href="/admin/dashboard"><i class="fas fa-chart-line me-2"></i> Dashboard</a>
                    <a href="/logout" class="text-danger mt-5"><i class="fas fa-sign-out-alt me-2"></i> Đăng xuất</a>
                </div>
            </div>

            <div class="col-md-10 p-5">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h2 class="fw-bold">Quản lý Thể Loại Con</h2>
                    <div>
                        <a href="/admin/sub_categories/export" class="btn btn-outline-success me-2">
                            <i class="fas fa-file-excel"></i> Xuất Excel
                        </a>
                        <button class="btn btn-outline-primary me-2" data-bs-toggle="modal"
                            data-bs-target="#importModal">
                            <i class="fas fa-file-import"></i> Nhập Excel
                        </button>
                        <button class="btn btn-success" data-bs-toggle="modal" data-bs-target="#addModal"><i
                                class="fas fa-plus"></i> Thêm thể loại</button>
                    </div>
                </div>

                <div class="card shadow-sm border-0">
                    <div class="card-body">
                        <table class="table table-hover align-middle text-center">
                            <thead class="table-light">
                                <tr>
                                    <th>Hình Ảnh</th>
                                    <th>Tên Thể Loại Con</th>
                                    <th>Thuộc Danh Mục Gốc</th>
                                    <th>Hành Động</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% if (typeof sub_categories !=='undefined' && sub_categories.length> 0) { %>
                                    <% sub_categories.forEach(sc=> { %>
                                        <tr>
                                            <td>
                                                <% if (sc.image) { %>
                                                    <img src="/<%= sc.image %>" alt="Img"
                                                        style="width: 50px; height: 50px; object-fit: contain; border-radius: 5px;">
                                                    <% } else { %>
                                                        <span class="text-muted small">Chưa có</span>
                                                        <% } %>
                                            </td>
                                            <td class="fw-bold">
                                                <%= sc.name %>
                                            </td>
                                            <td>
                                                <span class="badge bg-primary">
                                                    <%= sc.category_id ? sc.category_id.name : 'Không có' %>
                                                </span>
                                            </td>
                                            <td>
                                                <button class="btn btn-sm btn-warning" data-bs-toggle="modal"
                                                    data-bs-target="#editModal<%= sc._id %>"><i
                                                        class="fas fa-edit"></i></button>
                                                <a href="/admin/sub_categories/delete/<%= sc._id %>"
                                                    class="btn btn-sm btn-danger"
                                                    onclick="return confirm('Xóa thể loại này?');"><i
                                                        class="fas fa-trash"></i></a>
                                            </td>
                                        </tr>

                                        <div class="modal fade" id="editModal<%= sc._id %>" tabindex="-1">
                                            <div class="modal-dialog">
                                                <div class="modal-content text-start">
                                                    <div class="modal-header bg-warning text-dark">
                                                        <h5 class="modal-title fw-bold">Sửa Thể Loại Con</h5>
                                                        <button type="button" class="btn-close"
                                                            data-bs-dismiss="modal"></button>
                                                    </div>
                                                    <form action="/admin/sub_categories/update" method="POST"
                                                        enctype="multipart/form-data">
                                                        <div class="modal-body">
                                                            <input type="hidden" name="id" value="<%= sc._id %>">
                                                            <div class="mb-3">
                                                                <label class="form-label">Thuộc danh mục gốc</label>
                                                                <select class="form-select" name="category_id" required>
                                                                    <% categories.forEach(cat=> { %>
                                                                        <option value="<%= cat._id %>"
                                                                            <%=(sc.category_id &&
                                                                            sc.category_id._id.toString()==cat._id.toString())
                                                                            ? 'selected' : '' %>>
                                                                            <%= cat.name %>
                                                                        </option>
                                                                        <% }) %>
                                                                </select>
                                                            </div>
                                                            <div class="mb-3">
                                                                <label class="form-label">Tên thể loại con</label>
                                                                <input type="text" class="form-control" name="name"
                                                                    value="<%= sc.name %>" required>
                                                            </div>
                                                            <div class="mb-3">
                                                                <label class="form-label">Đổi hình ảnh (Tùy
                                                                    chọn)</label>
                                                                <input type="file" class="form-control" name="image"
                                                                    accept="image/*">
                                                            </div>
                                                        </div>
                                                        <div class="modal-footer">
                                                            <button type="button" class="btn btn-secondary"
                                                                data-bs-dismiss="modal">Đóng</button>
                                                            <button type="submit" class="btn btn-warning fw-bold">Cập
                                                                nhật</button>
                                                        </div>
                                                    </form>
                                                </div>
                                            </div>
                                        </div>
                                        <% }) %>
                                            <% } else { %>
                                                <tr>
                                                    <td colspan="4" class="py-4 text-muted">Chưa có thể loại con nào.
                                                    </td>
                                                </tr>
                                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="modal fade" id="addModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header bg-success text-white">
                    <h5 class="modal-title fw-bold">Thêm Thể Loại Con</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <form action="/admin/sub_categories/store" method="POST" enctype="multipart/form-data">
                    <div class="modal-body">
                        <div class="mb-3">
                            <label class="form-label">Chọn Danh Mục Gốc</label>
                            <select class="form-select" name="category_id" required>
                                <option value="">-- Chọn danh mục --</option>
                                <% categories.forEach(cat=> { %>
                                    <option value="<%= cat._id %>">
                                        <%= cat.name %>
                                    </option>
                                    <% }) %>
                            </select>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Tên Thể Loại Con (VD: Mì ly, Phở gói...)</label>
                            <input type="text" class="form-control" name="name" required>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Hình ảnh đại diện</label>
                            <input type="file" class="form-control" name="image" accept="image/*">
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                        <button type="submit" class="btn btn-success fw-bold">Lưu lại</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Modal Import Excel -->
    <div class="modal fade" id="importModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header bg-primary text-white">
                    <h5 class="modal-title fw-bold">Nhập Dữ Liệu Thể Loại Con</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <form action="/admin/sub_categories/import" method="POST" enctype="multipart/form-data">
                    <div class="modal-body">
                        <div class="mb-3">
                            <label class="form-label">Chọn file Excel (.xlsx)</label>
                            <input type="file" class="form-control" name="excel_file" accept=".xlsx, .xls" required>
                        </div>
                        <p class="text-muted small">Lưu ý: Hệ thống sẽ tự động bỏ qua các bản ghi bị trùng tên.</p>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Đóng</button>
                        <button type="submit" class="btn btn-primary fw-bold">Tải lên</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>
<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Quản lý Mã Giảm Giá</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: #f4f6f9;
        }

        .sidebar {
            min-height: 100vh;
            background-color: #005a3c;
        }

        .sidebar a {
            color: #fff;
            text-decoration: none;
            padding: 12px 20px;
            display: block;
            transition: 0.3s;
        }

        .sidebar a:hover,
        .sidebar a.active {
            background-color: #00452d;
            border-left: 4px solid #f9b612;
        }

        .main-content {
            padding: 30px;
        }

        .table-custom {
            background-color: #fff;
            border-radius: 8px;
            overflow: hidden;
            box-shadow: 0 4px 6px rgba(0, 0, 0, 0.05);
        }
        
        .table-custom th {
            background-color: #f8f9fa;
            font-weight: 600;
        }
    </style>
</head>

<body>
    <div class="container-fluid">
        <div class="row">
            <!-- Sidebar -->
            <div class="col-md-2 p-0 sidebar text-white">
                <div class="p-4 text-center border-bottom border-secondary">
                    <h4 class="fw-bold text-warning mb-0">BÁCH HÓA PEW</h4>
                    <div class="mt-2 small opacity-75">
                        <i class="fas fa-user-shield"></i> Quản trị viên<br>
                        <span style="font-size: 0.8em;">ID: ADMIN</span>
                    </div>
                </div>
                <div class="mt-3">
                    <a href="/admin/categories"><i class="fas fa-list me-2"></i> Danh Mục Gốc</a>
                    <a href="/admin/sub_categories"><i class="fas fa-tags me-2"></i> Thể Loại Con</a>
                    <a href="/admin/brands"><i class="fas fa-copyright me-2"></i> Hãng Sản Xuất</a>
                    <a href="/admin/products"><i class="fas fa-box me-2"></i> Sản Phẩm</a>
                    <a href="/admin/customers"><i class="fas fa-users me-2"></i> Khách Hàng</a>
                    <a href="/admin/orders"><i class="fas fa-file-invoice-dollar me-2"></i> Đơn Hàng</a>
                    <a href="/admin/contacts"><i class="fas fa-envelope me-2"></i> Liên Hệ</a>
                    <a href="/admin/reviews"><i class="fas fa-star me-2"></i> Đánh Giá</a>
                    <a href="/admin/promotions"><i class="fas fa-percent me-2"></i> Khuyến Mãi Hàng Loạt</a>
                    <a href="/admin/vouchers" class="active"><i class="fas fa-ticket-alt me-2"></i> Mã Giảm Giá</a>
                    <a href="/admin/dashboard"><i class="fas fa-chart-line me-2"></i> Dashboard</a>
                    <a href="/logout" class="text-danger mt-5"><i class="fas fa-sign-out-alt me-2"></i> Đăng xuất</a>
                </div>
            </div>

            <!-- Main Content -->
            <div class="col-md-10 main-content">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h2 class="fw-bold text-dark"><i class="fas fa-ticket-alt me-2 text-warning"></i> Quản lý Mã Giảm Giá</h2>
                    <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#addVoucherModal">
                        <i class="fas fa-plus me-1"></i> Thêm Voucher
                    </button>
                </div>

                <div class="table-custom">
                    <table class="table table-hover mb-0 align-middle">
                        <thead>
                            <tr>
                                <th>Tiêu đề</th>
                                <th>Mã Code</th>
                                <th>Loại & Giá trị</th>
                                <th>Phạm vi</th>
                                <th>Hạn sử dụng</th>
                                <th>Lượt dùng</th>
                                <th>Trạng thái</th>
                                <th>Thao tác</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% vouchers.forEach(v => { %>
                                <tr>
                                    <td class="fw-bold text-primary"><%= v.title %></td>
                                    <td><span class="badge bg-dark"><%= v.code %></span></td>
                                    <td>
                                        <% if(v.discount_type === 'percent') { %>
                                            Giảm <%= v.discount_value %>% <br>
                                            <small class="text-muted">Tối đa <%= v.max_discount_amount.toLocaleString('vi-VN') %>đ</small>
                                        <% } else { %>
                                            Giảm <%= v.discount_value.toLocaleString('vi-VN') %>đ
                                        <% } %><br>
                                        <small class="text-danger">Đơn tối thiểu: <%= v.min_order_value.toLocaleString('vi-VN') %>đ</small>
                                    </td>
                                    <td>
                                        <%= v.category_id ? v.category_id.name : 'Toàn sàn' %>
                                    </td>
                                    <td>
                                        <small>Từ: <%= new Date(v.start_date).toLocaleDateString('vi-VN') %></small><br>
                                        <small class="text-danger">Đến: <%= new Date(v.expiry_date).toLocaleDateString('vi-VN') %></small>
                                    </td>
                                    <td>
                                        <%= v.used_count %> / <%= v.usage_limit === 0 ? '∞' : v.usage_limit %>
                                    </td>
                                    <td>
                                        <% if(v.status) { %>
                                            <span class="badge bg-success">Hoạt động</span>
                                        <% } else { %>
                                            <span class="badge bg-secondary">Tạm ngưng</span>
                                        <% } %>
                                    </td>
                                    <td>
                                        <button class="btn btn-sm btn-warning" data-bs-toggle="modal" data-bs-target="#editVoucherModal<%= v._id %>"><i class="fas fa-edit"></i></button>
                                        <a href="/admin/vouchers/delete/<%= v._id %>" class="btn btn-sm btn-danger" onclick="return confirm('Bạn có chắc muốn xóa mã này?')"><i class="fas fa-trash"></i></a>
                                    </td>
                                </tr>

                                <!-- Edit Modal -->
                                <div class="modal fade" id="editVoucherModal<%= v._id %>" tabindex="-1" aria-hidden="true">
                                    <div class="modal-dialog modal-lg">
                                        <div class="modal-content">
                                            <div class="modal-header bg-warning">
                                                <h5 class="modal-title fw-bold">Chỉnh sửa Voucher</h5>
                                                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                            </div>
                                            <form action="/admin/vouchers/update" method="POST">
                                                <div class="modal-body">
                                                    <input type="hidden" name="id" value="<%= v._id %>">
                                                    <div class="row">
                                                        <div class="col-md-6 mb-3">
                                                            <label class="form-label">Tiêu đề (Hiển thị cho khách)</label>
                                                            <input type="text" name="title" class="form-control" value="<%= v.title %>" required>
                                                        </div>
                                                        <div class="col-md-6 mb-3">
                                                            <label class="form-label">Mã Code (Chữ in hoa, viết liền)</label>
                                                            <input type="text" name="code" class="form-control text-uppercase" value="<%= v.code %>" required>
                                                        </div>
                                                        
                                                        <div class="col-md-4 mb-3">
                                                            <label class="form-label">Loại giảm giá</label>
                                                            <select name="discount_type" class="form-select" required>
                                                                <option value="percent" <%= v.discount_type === 'percent' ? 'selected' : '' %>>Theo %</option>
                                                                <option value="fixed" <%= v.discount_type === 'fixed' ? 'selected' : '' %>>Số tiền cố định</option>
                                                            </select>
                                                        </div>
                                                        <div class="col-md-4 mb-3">
                                                            <label class="form-label">Mức giảm (%, hoặc VNĐ)</label>
                                                            <input type="number" name="discount_value" class="form-control" value="<%= v.discount_value %>" required>
                                                        </div>
                                                        <div class="col-md-4 mb-3">
                                                            <label class="form-label">Giảm tối đa (Nếu chọn %)</label>
                                                            <input type="number" name="max_discount_amount" class="form-control" value="<%= v.max_discount_amount %>">
                                                        </div>

                                                        <div class="col-md-6 mb-3">
                                                            <label class="form-label">Đơn tối thiểu áp dụng (VNĐ)</label>
                                                            <input type="number" name="min_order_value" class="form-control" value="<%= v.min_order_value %>" required>
                                                        </div>
                                                        <div class="col-md-6 mb-3">
                                                            <label class="form-label">Phạm vi Danh mục</label>
                                                            <select name="category_id" class="form-select">
                                                                <option value="all">-- Toàn sàn --</option>
                                                                <% categories.forEach(cat => { %>
                                                                    <option value="<%= cat._id %>" <%= v.category_id && v.category_id._id.toString() === cat._id.toString() ? 'selected' : '' %>><%= cat.name %></option>
                                                                <% }) %>
                                                            </select>
                                                        </div>

                                                        <div class="col-md-6 mb-3">
                                                            <label class="form-label">Ngày bắt đầu</label>
                                                            <input type="date" name="start_date" class="form-control" value="<%= new Date(v.start_date).toISOString().split('T')[0] %>" required>
                                                        </div>
                                                        <div class="col-md-6 mb-3">
                                                            <label class="form-label">Ngày kết thúc</label>
                                                            <input type="date" name="expiry_date" class="form-control" value="<%= new Date(v.expiry_date).toISOString().split('T')[0] %>" required>
                                                        </div>

                                                        <div class="col-md-6 mb-3">
                                                            <label class="form-label">Giới hạn số lượng (0 = không giới hạn)</label>
                                                            <input type="number" name="usage_limit" class="form-control" value="<%= v.usage_limit %>">
                                                        </div>
                                                        <div class="col-md-6 mb-3">
                                                            <label class="form-label">Trạng thái</label>
                                                            <div class="form-check form-switch mt-2">
                                                                <input class="form-check-input" type="checkbox" name="status" <%= v.status ? 'checked' : '' %>>
                                                                <label class="form-check-label">Hoạt động</label>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                                <div class="modal-footer">
                                                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Đóng</button>
                                                    <button type="submit" class="btn btn-warning">Lưu thay đổi</button>
                                                </div>
                                            </form>
                                        </div>
                                    </div>
                                </div>

                            <% }) %>
                            <% if(vouchers.length === 0) { %>
                                <tr>
                                    <td colspan="8" class="text-center py-4">Chưa có mã giảm giá nào.</td>
                                </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>

                <div class="mt-4">
                    <%- include('../partials/pagination', { currentPage, totalPages, query: {} }) %>
                </div>

            </div>
        </div>
    </div>

    <!-- Add Modal -->
    <div class="modal fade" id="addVoucherModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header bg-primary text-white">
                    <h5 class="modal-title fw-bold">Thêm Voucher Mới</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <form action="/admin/vouchers/store" method="POST">
                    <div class="modal-body">
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Tiêu đề (Hiển thị cho khách)</label>
                                <input type="text" name="title" class="form-control" placeholder="VD: Giảm 20K đơn 100K" required>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Mã Code (Chữ in hoa, viết liền)</label>
                                <input type="text" name="code" class="form-control text-uppercase" placeholder="VD: PEW20K" required>
                            </div>
                            
                            <div class="col-md-4 mb-3">
                                <label class="form-label">Loại giảm giá</label>
                                <select name="discount_type" class="form-select" required>
                                    <option value="percent">Theo %</option>
                                    <option value="fixed">Số tiền cố định</option>
                                </select>
                            </div>
                            <div class="col-md-4 mb-3">
                                <label class="form-label">Mức giảm (%, hoặc VNĐ)</label>
                                <input type="number" name="discount_value" class="form-control" value="0" required>
                            </div>
                            <div class="col-md-4 mb-3">
                                <label class="form-label">Giảm tối đa (Nếu chọn %)</label>
                                <input type="number" name="max_discount_amount" class="form-control" value="0">
                            </div>

                            <div class="col-md-6 mb-3">
                                <label class="form-label">Đơn tối thiểu áp dụng (VNĐ)</label>
                                <input type="number" name="min_order_value" class="form-control" value="0" required>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Phạm vi Danh mục</label>
                                <select name="category_id" class="form-select">
                                    <option value="all">-- Toàn sàn --</option>
                                    <% categories.forEach(cat => { %>
                                        <option value="<%= cat._id %>"><%= cat.name %></option>
                                    <% }) %>
                                </select>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label class="form-label">Ngày bắt đầu</label>
                                <input type="date" name="start_date" class="form-control" required>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Ngày kết thúc</label>
                                <input type="date" name="expiry_date" class="form-control" required>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label class="form-label">Giới hạn số lượng (0 = không giới hạn)</label>
                                <input type="number" name="usage_limit" class="form-control" value="0">
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Đóng</button>
                        <button type="submit" class="btn btn-primary">Lưu mã</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>

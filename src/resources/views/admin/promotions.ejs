<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Quản lý Khuyến Mãi Hàng Loạt</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: #f4f6f9;
        }

        .sidebar {
            min-height: 100vh;
            background-color: #005a3c;
        }

        .sidebar a {
            color: #fff;
            text-decoration: none;
            padding: 12px 20px;
            display: block;
            transition: 0.3s;
        }

        .sidebar a:hover,
        .sidebar a.active {
            background-color: #00452d;
            border-left: 4px solid #f9b612;
        }

        .main-content {
            padding: 30px;
        }

        .promo-card {
            border-radius: 10px;
            border: none;
            box-shadow: 0 4px 6px rgba(0, 0, 0, 0.05);
        }

        .promo-header {
            border-top-left-radius: 10px;
            border-top-right-radius: 10px;
            padding: 20px;
        }

        .bg-gradient-warning {
            background: linear-gradient(135deg, #f6d365 0%, #fda085 100%);
            color: white;
        }

        .bg-gradient-info {
            background: linear-gradient(135deg, #84fab0 0%, #8fd3f4 100%);
            color: #333;
        }
    </style>
</head>

<body>
    <div class="container-fluid">
        <div class="row">
            <!-- Sidebar -->
            <div class="col-md-2 p-0 sidebar text-white">
                <div class="p-4 text-center border-bottom border-secondary">
                    <h4 class="fw-bold text-warning mb-0">BÁCH HÓA PEW</h4>
                    <div class="mt-2 small opacity-75">
                        <i class="fas fa-user-shield"></i>Quản trị viên<br>
                        <span style="font-size: 0.8em;">ID: ADMIN</span>
                    </div>
                </div>
                <div class="mt-3">
                    <a href="/admin/categories"><i class="fas fa-list me-2"></i> Danh Mục Gốc</a>
                    <a href="/admin/sub_categories"><i class="fas fa-tags me-2"></i> Thể Loại Con</a>
                    <a href="/admin/brands"><i class="fas fa-copyright me-2"></i> Hãng Sản Xuất</a>
                    <a href="/admin/products"><i class="fas fa-box me-2"></i> Sản Phẩm</a>
                    <a href="/admin/customers"><i class="fas fa-users me-2"></i> Khách Hàng</a>
                    <a href="/admin/orders"><i class="fas fa-file-invoice-dollar me-2"></i> Đơn Hàng</a>
                    <a href="/admin/contacts"><i class="fas fa-envelope me-2"></i> Liên Hệ</a>
                    <a href="/admin/reviews"><i class="fas fa-star me-2"></i> Đánh Giá</a>
                    <a href="/admin/promotions" class="active"><i class="fas fa-percent me-2"></i> Khuyến Mãi Hàng
                        Loạt</a>
                    <a href="/admin/vouchers"><i class="fas fa-ticket-alt me-2"></i> Mã Giảm Giá</a>
                    <a href="/admin/dashboard"><i class="fas fa-chart-line me-2"></i> Dashboard</a>
                    <a href="/logout" class="text-danger mt-5"><i class="fas fa-sign-out-alt me-2"></i> Đăng xuất</a>
                </div>
            </div>

            <!-- Main Content -->
            <div class="col-md-10 main-content">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h2 class="fw-bold text-dark"><i class="fas fa-percent me-2 text-primary"></i> Quản Lý Khuyến Mãi
                        Hàng Loạt</h2>
                </div>

                <% if (successMsg) { %>
                    <div class="alert alert-success alert-dismissible fade show" role="alert">
                        <%= successMsg %>
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                    <% } %>

                        <% if (errorMsg) { %>
                            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                                <%= errorMsg %>
                                    <button type="button" class="btn-close" data-bs-dismiss="alert"
                                        aria-label="Close"></button>
                            </div>
                            <% } %>

                                <div class="row mb-4">
                                    <div class="col-12">
                                        <div class="alert alert-info">
                                            <i class="fas fa-info-circle me-2"></i> Chức năng này cho phép bạn lên chiến
                                            dịch Sale tự động. Hệ thống sẽ thay đổi giá Sale cho <strong>Toàn bộ Sản
                                                phẩm</strong> trong Danh mục bạn chọn. Tên danh mục cũng sẽ được cập
                                            nhật tự động ra ngoài trang khách hàng.
                                        </div>
                                    </div>
                                </div>

                                <div class="row">
                                    <!-- SLOT 1: Siêu Sale -->
                                    <div class="col-md-6 mb-4">
                                        <div class="card promo-card h-100">
                                            <div class="promo-header bg-gradient-warning mb-3">
                                                <h4 class="mb-0 fw-bold"><i class="fas fa-fire me-2"></i> Slot 1: Siêu
                                                    Sale Cuối Tuần (Banner)</h4>
                                            </div>
                                            <div class="card-body px-4 pb-4">
                                                <form action="/admin/promotions/slot1" method="POST">
                                                    <div class="mb-3">
                                                        <label class="form-label fw-bold">Danh mục được ưu đãi:</label>
                                                        <select name="category_id" class="form-select border-2"
                                                            required>
                                                            <option value="">-- Chọn danh mục --</option>
                                                            <% categories.forEach(cat=> { %>
                                                                <% let isSelected=(config && config.promo1_category_id
                                                                    &&
                                                                    config.promo1_category_id.toString()===cat._id.toString())
                                                                    ? 'selected' : '' ; %>
                                                                    <option value="<%= cat._id %>" <%=isSelected %>><%=
                                                                            cat.name %>
                                                                    </option>
                                                                    <% }) %>
                                                        </select>
                                                    </div>
                                                    <div class="mb-4">
                                                        <label class="form-label fw-bold">Phần trăm giảm giá
                                                            (%):</label>
                                                        <div class="input-group">
                                                            <span
                                                                class="input-group-text bg-white border-2 border-end-0"><i
                                                                    class="fas fa-tag text-muted"></i></span>
                                                            <input type="number" name="percent"
                                                                class="form-control border-2 border-start-0" min="1"
                                                                max="99"
                                                                value="<%= config ? config.promo1_percent : 0 %>"
                                                                required>
                                                            <span class="input-group-text border-2">%</span>
                                                        </div>
                                                    </div>
                                                    <div class="d-flex gap-2">
                                                        <button type="submit" name="action" value="apply"
                                                            class="btn btn-warning fw-bold text-dark flex-grow-1 shadow-sm">
                                                            <i class="fas fa-save me-1"></i> Áp dụng Sale
                                                        </button>
                                                        <button type="submit" name="action" value="cancel"
                                                            class="btn btn-outline-danger fw-bold shadow-sm"
                                                            onclick="return confirm('Bạn có chắc muốn hủy sale Slot này và dẹp luôn giá sale của món đồ này?');">
                                                            <i class="fas fa-ban me-1"></i> Hủy Sale
                                                        </button>
                                                    </div>
                                                </form>
                                            </div>
                                        </div>
                                    </div>

                                    <!-- SLOT 2: Ưu đãi độc quyền -->
                                    <div class="col-md-6 mb-4">
                                        <div class="card promo-card h-100">
                                            <div class="promo-header bg-gradient-info mb-3">
                                                <h4 class="mb-0 fw-bold"><i class="fas fa-gem me-2"></i> Slot 2: Ưu đãi
                                                    độc quyền (Box ngang 6 món)</h4>
                                            </div>
                                            <div class="card-body px-4 pb-4">
                                                <form action="/admin/promotions/slot2" method="POST">
                                                    <div class="mb-3">
                                                        <label class="form-label fw-bold">Danh mục được ưu đãi:</label>
                                                        <select name="category_id" class="form-select border-2"
                                                            required>
                                                            <option value="">-- Chọn danh mục --</option>
                                                            <% categories.forEach(cat=> { %>
                                                                <% let isSelected=(config && config.promo2_category_id
                                                                    &&
                                                                    config.promo2_category_id.toString()===cat._id.toString())
                                                                    ? 'selected' : '' ; %>
                                                                    <option value="<%= cat._id %>" <%=isSelected %>><%=
                                                                            cat.name %>
                                                                    </option>
                                                                    <% }) %>
                                                        </select>
                                                    </div>
                                                    <div class="mb-4">
                                                        <label class="form-label fw-bold">Phần trăm giảm giá
                                                            (%):</label>
                                                        <div class="input-group">
                                                            <span
                                                                class="input-group-text bg-white border-2 border-end-0"><i
                                                                    class="fas fa-tag text-muted"></i></span>
                                                            <input type="number" name="percent"
                                                                class="form-control border-2 border-start-0" min="1"
                                                                max="99"
                                                                value="<%= config ? config.promo2_percent : 0 %>"
                                                                required>
                                                            <span class="input-group-text border-2">%</span>
                                                        </div>
                                                    </div>
                                                    <div class="d-flex gap-2">
                                                        <button type="submit" name="action" value="apply"
                                                            class="btn btn-info fw-bold text-dark flex-grow-1 shadow-sm">
                                                            <i class="fas fa-save me-1"></i> Áp dụng Sale
                                                        </button>
                                                        <button type="submit" name="action" value="cancel"
                                                            class="btn btn-outline-danger fw-bold shadow-sm"
                                                            onclick="return confirm('Bạn có chắc muốn hủy sale Slot này và dẹp luôn giá sale của món đồ này?');">
                                                            <i class="fas fa-ban me-1"></i> Hủy Sale
                                                        </button>
                                                    </div>
                                                </form>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <!-- SLOT 3: Banner Danh Mục -->
                                <div class="row">
                                    <div class="col-md-12 mb-4">
                                        <div class="card promo-card">
                                            <div class="promo-header bg-dark text-white mb-3">
                                                <h4 class="mb-0 fw-bold"><i class="fas fa-image me-2"></i> Banner Danh
                                                    Mục (Hiển thị trang chủ)</h4>
                                            </div>
                                            <div class="card-body px-4 pb-4">
                                                <form action="/admin/promotions/banner" method="POST"
                                                    enctype="multipart/form-data">
                                                    <div class="row">
                                                        <div class="col-md-6 mb-3">
                                                            <label class="form-label fw-bold">Danh mục liên kết khi bấm
                                                                vào Banner:</label>
                                                            <select name="banner_category_id"
                                                                class="form-select border-2" required>
                                                                <option value="">-- Chọn danh mục --</option>
                                                                <% categories.forEach(cat=> { %>
                                                                    <% let isSelected=(config &&
                                                                        config.banner_category_id &&
                                                                        config.banner_category_id.toString()===cat._id.toString())
                                                                        ? 'selected' : '' ; %>
                                                                        <option value="<%= cat._id %>" <%=isSelected %>>
                                                                            <%= cat.name %>
                                                                        </option>
                                                                        <% }) %>
                                                            </select>
                                                        </div>
                                                        <div class="col-md-6 mb-3">
                                                            <label class="form-label fw-bold">Hình ảnh Banner:</label>
                                                            <input type="file" name="banner_image"
                                                                class="form-control border-2" accept="image/*">
                                                            <% if (config && config.banner_image) { %>
                                                                <div class="mt-2 text-muted small">
                                                                    <i class="fas fa-check-circle text-success"></i> Đã
                                                                    có banner (Tải lên ảnh mới sẽ ghi đè ảnh cũ)
                                                                </div>
                                                                <% } %>
                                                        </div>
                                                    </div>
                                                    <button type="submit" class="btn btn-dark fw-bold shadow-sm px-4">
                                                        <i class="fas fa-save me-1"></i> Lưu Banner
                                                    </button>
                                                </form>
                                                <% if (config && config.banner_image) { %>
                                                    <div class="mt-3">
                                                        <label class="fw-bold mb-2">Ảnh đang hiển thị:</label><br>
                                                        <img src="/<%= config.banner_image %>" alt="Banner hiện tại"
                                                            class="img-thumbnail" style="max-height: 150px;">
                                                    </div>
                                                    <% } %>
                                            </div>
                                        </div>
                                    </div>
                                </div>

            </div>
        </div>
    </div>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>
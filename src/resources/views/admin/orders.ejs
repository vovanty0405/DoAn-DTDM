<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Quản lý Đơn Hàng - Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        .sidebar {
            min-height: 100vh;
            background-color: #005a3c;
        }

        .sidebar a {
            color: #fff;
            text-decoration: none;
            padding: 12px 20px;
            display: block;
            transition: 0.3s;
        }

        .sidebar a:hover,
        .sidebar a.active {
            background-color: #00452d;
            border-left: 4px solid #f9b612;
        }
    </style>
</head>

<body class="bg-light">
    <div class="container-fluid">
        <div class="row">
            <div class="col-md-2 p-0 sidebar text-white">
                <div class="p-4 text-center border-bottom border-secondary">
                    <h4 class="fw-bold text-warning mb-0">BÁCH HÓA PEW</h4>
                    <div class="mt-2 small opacity-75">
                        <i class="fas fa-user-shield"></i> Quản trị viên<br>
                        <span style="font-size: 0.8em;">ID: ADMIN</span>
                    </div>
                </div>
                <div class="mt-3">
                    <a href="/admin/categories"><i class="fas fa-list me-2"></i> Danh Mục Gốc</a>
                    <a href="/admin/sub_categories"><i class="fas fa-tags me-2"></i> Thể Loại Con</a>
                    <a href="/admin/brands"><i class="fas fa-copyright me-2"></i> Hãng Sản Xuất</a>
                    <a href="/admin/products"><i class="fas fa-box me-2"></i> Sản Phẩm</a>
                    <a href="/admin/customers"><i class="fas fa-users me-2"></i> Khách Hàng</a>
                    <a href="/admin/orders" class="active"><i class="fas fa-file-invoice-dollar me-2"></i> Đơn Hàng</a>
                    <a href="/admin/contacts"><i class="fas fa-envelope me-2"></i> Liên Hệ</a>
                    <a href="/admin/reviews"><i class="fas fa-star me-2"></i> Đánh Giá</a>
                    <a href="/admin/promotions"><i class="fas fa-percent me-2"></i> Khuyến Mãi</a>
                    <a href="/admin/dashboard"><i class="fas fa-chart-line me-2"></i> Dashboard</a>
                    <a href="/logout" class="text-danger mt-5"><i class="fas fa-sign-out-alt me-2"></i> Đăng xuất</a>
                </div>
            </div>

            <div class="col-md-10 p-5">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h2 class="fw-bold">Quản lý Đơn Hàng</h2>
                </div>

                <!-- Bộ lọc -->
                <div class="card shadow-sm border-0 mb-4">
                    <div class="card-body">
                        <form action="/admin/orders" method="GET" class="row g-2 align-items-end">
                            <div class="col-md-3">
                                <label class="form-label small fw-bold">Tìm theo tên KH</label>
                                <input type="text" name="keyword" class="form-control"
                                    placeholder="Nhập tên khách hàng..."
                                    value="<%= (typeof query !== 'undefined' && query.keyword) ? query.keyword : '' %>">
                            </div>
                            <div class="col-md-2">
                                <label class="form-label small fw-bold">Từ ngày</label>
                                <input type="date" name="from_date" class="form-control"
                                    value="<%= (typeof query !== 'undefined' && query.from_date) ? query.from_date : '' %>">
                            </div>
                            <div class="col-md-2">
                                <label class="form-label small fw-bold">Đến ngày</label>
                                <input type="date" name="to_date" class="form-control"
                                    value="<%= (typeof query !== 'undefined' && query.to_date) ? query.to_date : '' %>">
                            </div>
                            <div class="col-md-2">
                                <label class="form-label small fw-bold">Trạng thái</label>
                                <select name="status" class="form-select">
                                    <option value="">Tất cả</option>
                                    <option value="0" <%=(typeof query !=='undefined' && query.status==='0' )
                                        ? 'selected' : '' %>>Mới đặt</option>
                                    <option value="1" <%=(typeof query !=='undefined' && query.status==='1' )
                                        ? 'selected' : '' %>>Đang xử lý</option>
                                    <option value="2" <%=(typeof query !=='undefined' && query.status==='2' )
                                        ? 'selected' : '' %>>Đang giao</option>
                                    <option value="3" <%=(typeof query !=='undefined' && query.status==='3' )
                                        ? 'selected' : '' %>>Hoàn thành</option>
                                    <option value="4" <%=(typeof query !=='undefined' && query.status==='4' )
                                        ? 'selected' : '' %>>Đã hủy</option>
                                </select>
                            </div>
                            <div class="col-md-1">
                                <label class="form-label small fw-bold">Sắp xếp</label>
                                <select name="sort" class="form-select">
                                    <option value="">Mới nhất</option>
                                    <option value="money_desc" <%=(typeof query !=='undefined' &&
                                        query.sort==='money_desc' ) ? 'selected' : '' %>>Tiền ↓</option>
                                    <option value="money_asc" <%=(typeof query !=='undefined' &&
                                        query.sort==='money_asc' ) ? 'selected' : '' %>>Tiền ↑</option>
                                </select>
                            </div>
                            <div class="col-md-1">
                                <button type="submit" class="btn btn-primary w-100"><i
                                        class="fas fa-filter"></i></button>
                            </div>
                            <div class="col-md-1">
                                <a href="/admin/orders" class="btn btn-secondary w-100" title="Xóa lọc"><i
                                        class="fas fa-times"></i></a>
                            </div>
                        </form>
                    </div>
                </div>

                <div class="card shadow-sm border-0">
                    <div class="card-body">
                        <table class="table table-hover align-middle text-center">
                            <thead class="table-light">
                                <tr>
                                    <th>Mã ĐH</th>
                                    <th>Ngày đặt</th>
                                    <th class="text-start">Thông tin người nhận</th>
                                    <th>Tổng tiền</th>
                                    <th>Thanh toán</th>
                                    <th>Trạng thái</th>
                                    <th>Hành Động</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% if (typeof orders !=='undefined' && orders.length> 0) { %>
                                    <% orders.forEach(order=> { %>
                                        <tr>
                                            <td class="fw-bold text-uppercase text-secondary">#<%=
                                                    order._id.toString().slice(-6) %>
                                            </td>
                                            <td>
                                                <%= order.createdAt.toLocaleString('vi-VN') %>
                                            </td>
                                            <td class="text-start">
                                                <strong>
                                                    <%= order.fullname %>
                                                </strong><br>
                                                <small class="text-muted"><i class="fas fa-phone fa-sm"></i>
                                                    <%= order.phone %>
                                                </small>
                                            </td>
                                            <td class="fw-bold text-danger">
                                                <%= order.total_money.toLocaleString('vi-VN') %> đ
                                            </td>
                                            <td><span class="badge bg-light text-dark border">
                                                    <%= order.payment_method %>
                                                </span></td>
                                            <td>
                                                <% if(order.status==0) { %><span class="badge bg-secondary">Mới
                                                        đặt</span>
                                                    <% } %>
                                                        <% if(order.status==1) { %><span class="badge bg-primary">Đang
                                                                xử lý</span>
                                                            <% } %>
                                                                <% if(order.status==2) { %><span
                                                                        class="badge bg-warning text-dark">Đang
                                                                        giao</span>
                                                                    <% } %>
                                                                        <% if(order.status==3) { %><span
                                                                                class="badge bg-success">Hoàn
                                                                                thành</span>
                                                                            <% } %>
                                                                                <% if(order.status==4) { %><span
                                                                                        class="badge bg-danger">Đã
                                                                                        hủy</span>
                                                                                    <% } %>
                                            </td>
                                            <td>
                                                <a href="/admin/orders/detail/<%= order._id %>"
                                                    class="btn btn-sm btn-info text-white"
                                                    title="Xem chi tiết & In hóa đơn">
                                                    <i class="fas fa-eye"></i>
                                                </a>
                                                <button class="btn btn-sm btn-warning" data-bs-toggle="modal"
                                                    data-bs-target="#editModal<%= order._id %>"
                                                    title="Cập nhật trạng thái">
                                                    <i class="fas fa-edit"></i>
                                                </button>
                                                <a href="/admin/orders/delete/<%= order._id %>"
                                                    class="btn btn-sm btn-danger"
                                                    onclick="return confirm('Bạn có chắc muốn xóa đơn hàng này?');"
                                                    title="Xóa đơn hàng">
                                                    <i class="fas fa-trash"></i>
                                                </a>
                                            </td>
                                        </tr>

                                        <div class="modal fade" id="editModal<%= order._id %>" tabindex="-1">
                                            <div class="modal-dialog">
                                                <div class="modal-content text-start">
                                                    <div class="modal-header bg-warning text-dark">
                                                        <h5 class="modal-title fw-bold">Cập nhật trạng thái ĐH #<%=
                                                                order._id.toString().slice(-6).toUpperCase() %>
                                                        </h5>
                                                        <button type="button" class="btn-close"
                                                            data-bs-dismiss="modal"></button>
                                                    </div>
                                                    <form action="/admin/orders/update" method="POST">
                                                        <div class="modal-body">
                                                            <input type="hidden" name="id" value="<%= order._id %>">
                                                            <div class="mb-3">
                                                                <label class="form-label fw-bold">Chọn trạng thái
                                                                    mới</label>
                                                                <select class="form-select" name="status">
                                                                    <option value="0" <%=order.status==0 ? 'selected'
                                                                        : '' %>>Mới đặt</option>
                                                                    <option value="1" <%=order.status==1 ? 'selected'
                                                                        : '' %>>Đang xử lý</option>
                                                                    <option value="2" <%=order.status==2 ? 'selected'
                                                                        : '' %>>Đang giao</option>
                                                                    <option value="3" <%=order.status==3 ? 'selected'
                                                                        : '' %>>Hoàn thành</option>
                                                                    <option value="4" <%=order.status==4 ? 'selected'
                                                                        : '' %>>Đã hủy</option>
                                                                </select>
                                                            </div>
                                                        </div>
                                                        <div class="modal-footer">
                                                            <button type="button" class="btn btn-secondary"
                                                                data-bs-dismiss="modal">Đóng</button>
                                                            <button type="submit" class="btn btn-warning fw-bold">Cập
                                                                nhật</button>
                                                        </div>
                                                    </form>
                                                </div>
                                            </div>
                                        </div>
                                        <% }) %>
                                            <% } else { %>
                                                <tr>
                                                    <td colspan="7" class="py-5 text-muted">
                                                        <i class="fas fa-box-open fs-2 mb-3 opacity-50"></i><br>
                                                        Không tìm thấy dữ liệu phù hợp.
                                                    </td>
                                                </tr>
                                                <% } %>
                            </tbody>
                        </table>
                    </div>
                    <%- include('../partials/pagination', { currentPage, totalPages, query: query || {} }) %>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>
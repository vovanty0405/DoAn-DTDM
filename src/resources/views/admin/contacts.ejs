<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Quản lý Liên Hệ - Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        .sidebar {
            min-height: 100vh;
            background-color: #005a3c;
        }

        .sidebar a {
            color: #fff;
            text-decoration: none;
            padding: 12px 20px;
            display: block;
            transition: 0.3s;
        }

        .sidebar a:hover,
        .sidebar a.active {
            background-color: #00452d;
            border-left: 4px solid #f9b612;
        }
    </style>
</head>

<body class="bg-light">
    <div class="container-fluid">
        <div class="row">
            <div class="col-md-2 p-0 sidebar text-white">
                <div class="p-4 text-center border-bottom border-secondary">
                    <h4 class="fw-bold text-warning mb-0">BÁCH HÓA PEW</h4>
                    <div class="mt-2 small opacity-75">
                        <i class="fas fa-user-shield"></i> Quản trị viên<br>
                        <span style="font-size: 0.8em;">ID: ADMIN</span>
                    </div>
                </div>
                <div class="mt-3">
                    <a href="/admin/categories"><i class="fas fa-list me-2"></i> Danh Mục Gốc</a>
                    <a href="/admin/sub_categories"><i class="fas fa-tags me-2"></i> Thể Loại Con</a>
                    <a href="/admin/brands"><i class="fas fa-copyright me-2"></i> Hãng Sản Xuất</a>
                    <a href="/admin/products"><i class="fas fa-box me-2"></i> Sản Phẩm</a>
                    <a href="/admin/customers"><i class="fas fa-users me-2"></i> Khách Hàng</a>
                    <a href="/admin/orders"><i class="fas fa-file-invoice-dollar me-2"></i> Đơn Hàng</a>
                    <a href="/admin/contacts" class="active"><i class="fas fa-envelope me-2"></i> Liên Hệ</a>
                    <a href="/admin/reviews"><i class="fas fa-star me-2"></i> Đánh Giá</a>
                    <a href="/admin/promotions"><i class="fas fa-percent me-2"></i> Khuyến Mãi</a>
                    <a href="/admin/dashboard"><i class="fas fa-chart-line me-2"></i> Dashboard</a>
                    <a href="/logout" class="text-danger mt-5"><i class="fas fa-sign-out-alt me-2"></i> Đăng xuất</a>
                </div>
            </div>

            <div class="col-md-10 p-5">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h2 class="fw-bold">Quản lý Liên Hệ Khách Hàng</h2>
                </div>

                <div class="card shadow-sm border-0">
                    <div class="card-body">
                        <table class="table table-hover align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th>Thời gian</th>
                                    <th>Khách hàng</th>
                                    <th>Tiêu đề</th>
                                    <th>Trạng thái</th>
                                    <th class="text-center">Thao tác</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% if (typeof contacts !=='undefined' && contacts.length> 0) { %>
                                    <% contacts.forEach(contact=> { %>
                                        <tr>
                                            <td><small>
                                                    <%= new Date(contact.createdAt).toLocaleString('vi-VN') %>
                                                </small></td>
                                            <td>
                                                <strong>
                                                    <%= contact.name %>
                                                </strong><br>
                                                <small class="text-muted">
                                                    <%= contact.email %>
                                                </small>
                                            </td>
                                            <td>
                                                <span class="fw-semibold">
                                                    <%= contact.title %>
                                                </span>
                                            </td>
                                            <td>
                                                <form action="/admin/contacts/update" method="POST" class="d-inline">
                                                    <input type="hidden" name="id" value="<%= contact._id %>">
                                                    <select name="status"
                                                        class="form-select form-select-sm d-inline w-auto"
                                                        onchange="this.form.submit()">
                                                        <option value="0" <%=contact.status===0 ? 'selected' : '' %>
                                                            >Chưa xử lý</option>
                                                        <option value="1" <%=contact.status===1 ? 'selected' : '' %>>Đã
                                                            xử lý</option>
                                                    </select>
                                                </form>
                                            </td>
                                            <td class="text-center">
                                                <button class="btn btn-sm btn-info text-white" data-bs-toggle="modal"
                                                    data-bs-target="#viewModal<%= contact._id %>" title="Xem nội dung">
                                                    <i class="fas fa-eye"></i>
                                                </button>
                                                <a href="/admin/contacts/delete/<%= contact._id %>"
                                                    class="btn btn-sm btn-danger"
                                                    onclick="return confirm('Xóa liên hệ này?');" title="Xóa">
                                                    <i class="fas fa-trash"></i>
                                                </a>
                                            </td>
                                        </tr>

                                        <!-- Modal View Content -->
                                        <div class="modal fade" id="viewModal<%= contact._id %>" tabindex="-1">
                                            <div class="modal-dialog">
                                                <div class="modal-content text-start">
                                                    <div class="modal-header bg-info text-white">
                                                        <h5 class="modal-title fw-bold">Nội dung liên hệ</h5>
                                                        <button type="button" class="btn-close"
                                                            data-bs-dismiss="modal"></button>
                                                    </div>
                                                    <div class="modal-body">
                                                        <p><strong>Người gửi:</strong>
                                                            <%= contact.name %> (<%= contact.email %>)
                                                        </p>
                                                        <p><strong>Tiêu đề:</strong>
                                                            <%= contact.title %>
                                                        </p>
                                                        <hr>
                                                        <p><strong>Nội dung:</strong></p>
                                                        <p class="text-break">
                                                            <%= contact.content %>
                                                        </p>
                                                    </div>
                                                    <div class="modal-footer">
                                                        <button type="button" class="btn btn-secondary"
                                                            data-bs-dismiss="modal">Đóng</button>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                        <% }) %>
                                            <% } else { %>
                                                <tr>
                                                    <td colspan="5" class="text-center py-4 text-muted">Chưa có liên hệ
                                                        nào.</td>
                                                </tr>
                                                <% } %>
                            </tbody>
                        </table>
                    </div>
                    <%- include('../partials/pagination', { currentPage, totalPages, query: {} }) %>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>
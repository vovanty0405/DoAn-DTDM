<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Quản lý Sản Phẩm - Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        .sidebar {
            min-height: 100vh;
            background-color: #005a3c;
        }

        .sidebar a {
            color: #fff;
            text-decoration: none;
            padding: 12px 20px;
            display: block;
            transition: 0.3s;
        }

        .sidebar a:hover,
        .sidebar a.active {
            background-color: #00452d;
            border-left: 4px solid #f9b612;
        }
    </style>
</head>

<body class="bg-light">
    <div class="container-fluid">
        <div class="row">
            <div class="col-md-2 p-0 sidebar text-white">
                <div class="p-4 text-center border-bottom border-secondary">
                    <h4 class="fw-bold text-warning mb-0">BÁCH HÓA PEW</h4>
                    <div class="mt-2 small opacity-75">
                        <i class="fas fa-user-shield"></i>Quản trị viên<br>
                        <span style="font-size: 0.8em;">ID: ADMIN</span>
                    </div>
                </div>
                <div class="mt-3">
                    <a href="/admin/categories"><i class="fas fa-list me-2"></i> Danh Mục Gốc</a>
                    <a href="/admin/sub_categories"><i class="fas fa-tags me-2"></i> Thể Loại Con</a>
                    <a href="/admin/brands"><i class="fas fa-copyright me-2"></i> Hãng Sản Xuất</a>
                    <a href="/admin/products" class="active"><i class="fas fa-box me-2"></i> Sản Phẩm</a>
                    <a href="/admin/customers"><i class="fas fa-users me-2"></i> Khách Hàng</a>
                    <a href="/admin/orders"><i class="fas fa-file-invoice-dollar me-2"></i> Đơn Hàng</a>
                    <a href="/admin/reviews"><i class="fas fa-star me-2"></i> Đánh Giá</a>
                    <a href="/admin/contacts"><i class="fas fa-envelope me-2"></i> Liên Hệ</a>
                    <a href="/admin/promotions"><i class="fas fa-percent me-2"></i> Khuyến Mãi</a>
                    <a href="/admin/dashboard"><i class="fas fa-chart-line me-2"></i> Dashboard</a>
                    <a href="/logout" class="text-danger mt-5"><i class="fas fa-sign-out-alt me-2"></i> Đăng xuất</a>
                </div>
            </div>

            <div class="col-md-10 p-5">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h2 class="fw-bold">Quản lý Sản Phẩm</h2>
                    <div>
                        <a href="/admin/products/export" class="btn btn-outline-success me-2">
                            <i class="fas fa-file-excel"></i> Xuất Excel
                        </a>
                        <button class="btn btn-outline-primary me-2" data-bs-toggle="modal"
                            data-bs-target="#importModal">
                            <i class="fas fa-file-import"></i> Nhập Excel
                        </button>
                        <button class="btn btn-success" data-bs-toggle="modal" data-bs-target="#addModal">
                            <i class="fas fa-plus"></i> Thêm sản phẩm
                        </button>
                    </div>
                </div>

                <div class="card shadow-sm border-0 mb-4">
                    <div class="card-body">
                        <form action="/admin/products" method="GET" class="row g-2 align-items-center">
                            <div class="col-md-4">
                                <input type="text" name="keyword" class="form-control"
                                    placeholder="Tìm theo tên sản phẩm..."
                                    value="<%= (typeof query !== 'undefined' && query.keyword) ? query.keyword : '' %>">
                            </div>
                            <div class="col-md-3">
                                <select name="category_id" class="form-select">
                                    <option value="">-- Tất cả danh mục --</option>
                                    <% categories.forEach(cat=> { %>
                                        <option value="<%= cat._id %>" <%=(typeof query !=='undefined' &&
                                            query.category_id==cat._id) ? 'selected' : '' %>><%= cat.name %>
                                        </option>
                                        <% }) %>
                                </select>
                            </div>
                            <div class="col-md-2">
                                <button type="submit" class="btn btn-primary w-100"><i class="fas fa-search"></i>
                                    Lọc</button>
                            </div>
                            <div class="col-md-2">
                                <a href="/admin/products" class="btn btn-secondary w-100">Xóa lọc</a>
                            </div>
                        </form>
                    </div>
                </div>

                <div class="card shadow-sm border-0">
                    <div class="card-body">
                        <table class="table table-hover align-middle text-center">
                            <thead class="table-light">
                                <tr>
                                    <th>Hình Ảnh</th>
                                    <th>Tên Sản Phẩm</th>
                                    <th>Danh Mục</th>
                                    <th>Thể Loại Con</th>
                                    <th>Giá bán</th>
                                    <th>Trạng Thái</th>
                                    <th>Hành Động</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% if (typeof products !=='undefined' && products.length> 0) { %>
                                    <% products.forEach(prod=> { %>
                                        <tr>
                                            <td>
                                                <% if (prod.cover_image) { %>
                                                    <img src="/<%= prod.cover_image %>" alt="Img"
                                                        style="width: 50px; height: 50px; object-fit: cover; border-radius: 5px;">
                                                    <% } else { %>
                                                        <span class="text-muted small">No Image</span>
                                                        <% } %>
                                            </td>
                                            <td class="fw-bold text-start">
                                                <%= prod.name %>
                                            </td>
                                            <td>
                                                <%= prod.category_id ? prod.category_id.name : 'Trống' %>
                                            </td>
                                            <td><span class="badge bg-info text-dark">
                                                    <%= prod.sub_category_id ? prod.sub_category_id.name
                                                        : 'Chưa phân loại' %>
                                                </span></td>
                                            <td><strong class="text-danger">
                                                    <%= prod.price.toLocaleString() %> đ
                                                </strong></td>
                                            <td>
                                                <% if (prod.status==1) { %>
                                                    <span class="badge bg-success">Đang bán</span>
                                                    <% } else { %>
                                                        <span class="badge bg-secondary">Ngừng bán</span>
                                                        <% } %>
                                            </td>
                                            <td>
                                                <button class="btn btn-sm btn-warning" data-bs-toggle="modal"
                                                    data-bs-target="#editModal<%= prod._id %>">
                                                    <i class="fas fa-edit"></i>
                                                </button>
                                                <a href="/admin/products/delete/<%= prod._id %>"
                                                    class="btn btn-sm btn-danger"
                                                    onclick="return confirm('Xóa sản phẩm này?');">
                                                    <i class="fas fa-trash"></i>
                                                </a>
                                            </td>
                                        </tr>

                                        <div class="modal fade" id="editModal<%= prod._id %>" tabindex="-1">
                                            <div class="modal-dialog">
                                                <div class="modal-content text-start">
                                                    <div class="modal-header bg-warning text-dark">
                                                        <h5 class="modal-title fw-bold">Sửa Sản Phẩm</h5>
                                                        <button type="button" class="btn-close"
                                                            data-bs-dismiss="modal"></button>
                                                    </div>
                                                    <form action="/admin/products/update" method="POST"
                                                        enctype="multipart/form-data">
                                                        <div class="modal-body">
                                                            <input type="hidden" name="id" value="<%= prod._id %>">
                                                            <div class="mb-3">
                                                                <label class="form-label">Tên sản phẩm</label>
                                                                <input type="text" class="form-control" name="name"
                                                                    value="<%= prod.name %>" required>
                                                            </div>
                                                            <div class="mb-3">
                                                                <label class="form-label">Đổi ảnh đại diện (Để trống nếu
                                                                    giữ ảnh cũ)</label>
                                                                <input type="file" class="form-control"
                                                                    name="cover_image" accept="image/*">
                                                            </div>
                                                            <div class="mb-3">
                                                                <label class="form-label">Tải lên ảnh phụ mới (Để trống
                                                                    nếu giữ ảnh cũ, có thể chọn nhiều ảnh để đổi mới
                                                                    Image Slider)</label>
                                                                <input type="file" class="form-control" name="images"
                                                                    accept="image/*" multiple>
                                                            </div>
                                                            <div class="row">
                                                                <div class="col-6 mb-3">
                                                                    <label class="form-label">Giá bán (VNĐ)</label>
                                                                    <input type="number"
                                                                        class="form-control price-input" name="price"
                                                                        min="0" value="<%= prod.price %>" required>
                                                                    <div class="invalid-feedback">Giá bán không được âm!
                                                                    </div>
                                                                </div>
                                                                <div class="col-6 mb-3">
                                                                    <label class="form-label">Giá khuyến mãi</label>
                                                                    <input type="number"
                                                                        class="form-control price-input"
                                                                        name="discount_price" min="0"
                                                                        value="<%= prod.discount_price %>">
                                                                    <div class="invalid-feedback">Giá khuyến mãi không
                                                                        được âm!</div>
                                                                </div>
                                                                <div class="col-12 mb-3">
                                                                    <label class="form-label">Tồn kho</label>
                                                                    <input type="number" class="form-control"
                                                                        name="stock_quantity"
                                                                        value="<%= prod.stock_quantity %>">
                                                                </div>
                                                            </div>
                                                            <div class="row">
                                                                <div class="col-6 mb-3">
                                                                    <label class="form-label">Danh mục Gốc</label>
                                                                    <select class="form-select" name="category_id"
                                                                        onchange="updateSubCatDropdown(this, 'edit_subcat_<%= prod._id %>')">
                                                                        <option value="">-- Chọn danh mục --</option>
                                                                        <% categories.forEach(cat=> { %>
                                                                            <option value="<%= cat._id %>"
                                                                                <%=(prod.category_id &&
                                                                                prod.category_id._id.toString()==cat._id.toString())
                                                                                ? 'selected' : '' %>><%= cat.name %>
                                                                            </option>
                                                                            <% }) %>
                                                                    </select>
                                                                </div>
                                                                <div class="col-6 mb-3">
                                                                    <label class="form-label">Thể Loại Con</label>
                                                                    <select class="form-select" name="sub_category_id"
                                                                        id="edit_subcat_<%= prod._id %>">
                                                                        <option value="">-- Chọn (Tùy chọn) --</option>
                                                                        <% /* Lọc thủ công bằng EJS: Chỉ in ra những Thể
                                                                            loại con CÙNG danh mục gốc với sản phẩm này
                                                                            */ let filteredSC=subCategories.filter(sc=>
                                                                            prod.category_id && sc.category_id &&
                                                                            sc.category_id._id.toString() ==
                                                                            prod.category_id._id.toString());
                                                                            filteredSC.forEach(sc => {
                                                                            %>
                                                                            <option value="<%= sc._id %>"
                                                                                <%=(prod.sub_category_id &&
                                                                                prod.sub_category_id._id.toString()==sc._id.toString())
                                                                                ? 'selected' : '' %>>
                                                                                <%= sc.name %>
                                                                            </option>
                                                                            <% }) %>
                                                                    </select>
                                                                </div>
                                                            </div>
                                                            <div class="row">
                                                                <div class="col-6 mb-3">
                                                                    <label class="form-label">Hãng sản xuất</label>
                                                                    <select class="form-select" name="brand_id">
                                                                        <option value="">-- Chọn hãng --</option>
                                                                        <% brands.forEach(b=> { %>
                                                                            <option value="<%= b._id %>"
                                                                                <%=(prod.brand_id &&
                                                                                prod.brand_id._id.toString()==b._id.toString())
                                                                                ? 'selected' : '' %>><%= b.name %>
                                                                            </option>
                                                                            <% }) %>
                                                                    </select>
                                                                </div>
                                                                <div class="col-12 mb-3">
                                                                    <label class="form-label">Mô tả sản phẩm</label>
                                                                    <textarea class="form-control editor"
                                                                        name="description"><%= prod.description || '' %></textarea>
                                                                </div>
                                                                <div class="col-6 mb-3">
                                                                    <label class="form-label">Trạng thái</label>
                                                                    <select class="form-select" name="status">
                                                                        <option value="1" <%=prod.status==1 ? 'selected'
                                                                            : '' %>>Đang bán</option>
                                                                        <option value="0" <%=prod.status==0 ? 'selected'
                                                                            : '' %>>Ngừng bán</option>
                                                                    </select>
                                                                </div>
                                                            </div>
                                                        </div>
                                                        <div class="modal-footer">
                                                            <button type="button" class="btn btn-secondary"
                                                                data-bs-dismiss="modal">Đóng</button>
                                                            <button type="submit" class="btn btn-warning fw-bold">Cập
                                                                nhật</button>
                                                        </div>
                                                    </form>
                                                </div>
                                            </div>
                                        </div>
                                        <% }) %>
                                            <% } else { %>
                                                <tr>
                                                    <td colspan="7" class="py-4 text-muted">Chưa có sản phẩm nào.</td>
                                                </tr>
                                                <% } %>
                            </tbody>
                        </table>
                    </div>
                    <%- include('../partials/pagination', { currentPage, totalPages, query: query || {} }) %>
                </div>
            </div>
        </div>
    </div>

    <div class="modal fade" id="addModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header bg-success text-white">
                    <h5 class="modal-title fw-bold">Thêm Sản Phẩm Mới</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <form action="/admin/products/store" method="POST" enctype="multipart/form-data">
                    <div class="modal-body">
                        <div class="mb-3">
                            <label class="form-label">Tên sản phẩm</label>
                            <input type="text" class="form-control" name="name" required>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Hình ảnh đại diện (Ảnh cover)</label>
                            <input type="file" class="form-control" name="cover_image" accept="image/*" required>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Hình ảnh phụ (Có thể chọn nhiều ảnh, để tạo Image Slider cho chi
                                tiết SP)</label>
                            <input type="file" class="form-control" name="images" accept="image/*" multiple>
                        </div>
                        <div class="row">
                            <div class="col-6 mb-3">
                                <label class="form-label">Giá bán (VNĐ)</label>
                                <input type="number" class="form-control price-input" min="0" name="price" required>
                                <div class="invalid-feedback">Giá bán không được âm!</div>
                            </div>
                            <div class="col-6 mb-3">
                                <label class="form-label">Giá khuyến mãi</label>
                                <input type="number" class="form-control price-input" min="0" name="discount_price">
                                <div class="invalid-feedback">Giá khuyến mãi không được âm!</div>
                            </div>
                            <div class="col-12 mb-3">
                                <label class="form-label">Tồn kho</label>
                                <input type="number" class="form-control" min="0" name="stock_quantity" value="0">
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-6 mb-3">
                                <label class="form-label">Danh mục Gốc</label>
                                <select class="form-select" name="category_id"
                                    onchange="updateSubCatDropdown(this, 'add_subcat')">
                                    <option value="">-- Chọn danh mục --</option>
                                    <% categories.forEach(cat=> { %>
                                        <option value="<%= cat._id %>">
                                            <%= cat.name %>
                                        </option>
                                        <% }) %>
                                </select>
                            </div>
                            <div class="col-6 mb-3">
                                <label class="form-label">Thể Loại Con</label>
                                <select class="form-select" name="sub_category_id" id="add_subcat">
                                    <option value="">-- Chọn (Tùy chọn) --</option>
                                </select>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-6 mb-3">
                                <label class="form-label">Hãng sản xuất</label>
                                <select class="form-select" name="brand_id">
                                    <option value="">-- Chọn hãng --</option>
                                    <% brands.forEach(b=> { %>
                                        <option value="<%= b._id %>">
                                            <%= b.name %>
                                        </option>
                                        <% }) %>
                                </select>
                            </div>
                            <div class="col-12 mb-3">
                                <label class="form-label">Mô tả sản phẩm</label>
                                <textarea class="form-control editor" name="description"></textarea>
                            </div>
                            <div class="col-12 mb-3">
                                <label class="form-label">Trạng thái</label>
                                <select class="form-select" name="status">
                                    <option value="1">Đang bán</option>
                                    <option value="0">Ngừng bán</option>
                                </select>
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                        <button type="submit" class="btn btn-success fw-bold">Lưu lại</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Modal Import Excel -->
    <div class="modal fade" id="importModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header bg-primary text-white">
                    <h5 class="modal-title fw-bold">Nhập Dữ Liệu Sản Phẩm</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <form action="/admin/products/import" method="POST" enctype="multipart/form-data">
                    <div class="modal-body">
                        <div class="mb-3">
                            <label class="form-label">Chọn file Excel (.xlsx)</label>
                            <input type="file" class="form-control" name="excel_file" accept=".xlsx, .xls" required>
                        </div>
                        <p class="text-muted small">Lưu ý: Hệ thống sẽ tự động bỏ qua các bản ghi bị trùng tên.</p>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Đóng</button>
                        <button type="submit" class="btn btn-primary fw-bold">Tải lên</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <script>
        // Lấy cục dữ liệu Thể loại con từ Node.js nhét sang Javascript
        const allSubCats = '<% - JSON.stringify(subCategories) %>';

        // Hàm này sẽ chạy mỗi khi thẻ select Danh Mục Gốc bị thay đổi (onchange)
        function updateSubCatDropdown(catSelectElement, subCatSelectId) {
            const catId = catSelectElement.value; // Lấy ID của danh mục đang chọn
            const subCatSelect = document.getElementById(subCatSelectId); // Tìm đúng ô Thể loại con tương ứng

            // Bước 1: Xóa trắng ô Thể loại con cũ
            subCatSelect.innerHTML = '<option value="">-- Chọn (Tùy chọn) --</option>';

            // Bước 2: Nếu người dùng chọn "-- Chọn danh mục --" thì thoát, không làm gì cả
            if (!catId) return;

            // Bước 3: Lọc ra những Thể loại con nào có category_id khớp với catId vừa chọn
            const filteredSubCats = allSubCats.filter(sc => sc.category_id && sc.category_id._id === catId);

            // Bước 4: Chèn các Thể loại con đã lọc vào dropdown
            filteredSubCats.forEach(sc => {
                subCatSelect.innerHTML += `<option value="${sc._id}">${sc.name}</option>`;
            });
        }
    </script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <script src="https://cdn.ckeditor.com/ckeditor5/36.0.1/classic/ckeditor.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            // CKEditor
            document.querySelectorAll('.editor').forEach(el => {
                ClassicEditor.create(el).catch(err => console.error(err));
            });

            // === RÀNG BUỘC GIÁ BÁN & GIÁ KHUYẾN MÃI KHÔNG ĐƯỢC ÂM ===
            document.querySelectorAll('.price-input').forEach(input => {
                // Kiểm tra ngay khi người dùng nhập (real-time)
                input.addEventListener('input', function () {
                    const val = parseFloat(this.value);
                    if (this.value !== '' && val < 0) {
                        this.classList.add('is-invalid');
                        this.classList.remove('is-valid');
                    } else if (this.value !== '') {
                        this.classList.remove('is-invalid');
                        this.classList.add('is-valid');
                    } else {
                        this.classList.remove('is-invalid', 'is-valid');
                    }
                });
            });

            // Chặn submit form nếu có giá âm
            document.querySelectorAll('form').forEach(form => {
                form.addEventListener('submit', function (e) {
                    const priceInputs = this.querySelectorAll('.price-input');
                    let hasError = false;
                    priceInputs.forEach(input => {
                        const val = parseFloat(input.value);
                        if (input.value !== '' && val < 0) {
                            input.classList.add('is-invalid');
                            hasError = true;
                        }
                    });
                    if (hasError) {
                        e.preventDefault();
                        alert('Giá bán và giá khuyến mãi không được nhập số âm!');
                    }
                });
            });
        });
    </script>
</body>


</html>
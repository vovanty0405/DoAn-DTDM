<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Chi tiết Đơn Hàng - Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        /* CSS cho menu trái */
        .sidebar {
            min-height: 100vh;
            background-color: #005a3c;
        }

        .sidebar a {
            color: #fff;
            text-decoration: none;
            padding: 12px 20px;
            display: block;
            transition: 0.3s;
        }

        .sidebar a:hover,
        .sidebar a.active {
            background-color: #00452d;
            border-left: 4px solid #f9b612;
        }

        /* CSS cho ảnh sản phẩm trong bảng */
        .product-img {
            width: 60px;
            height: 60px;
            object-fit: contain;
            border: 1px solid #ddd;
            border-radius: 8px;
            padding: 3px;
            background: #fff;
        }

        /* ĐIỀU KỲ DIỆU Ở ĐÂY: Khi bấm In (Ctrl+P), tự động ẩn Sidebar và Nút bấm, chỉ in phần Hóa Đơn */
        @media print {
            body * {
                visibility: hidden;
            }

            .sidebar,
            .no-print {
                display: none !important;
            }

            #print-area,
            #print-area * {
                visibility: visible;
            }

            #print-area {
                position: absolute;
                left: 0;
                top: 0;
                width: 100%;
                padding: 20px;
            }
        }
    </style>
</head>

<body class="bg-light">
    <div class="container-fluid">
        <div class="row">
            <div class="col-md-2 p-0 sidebar text-white no-print">
                <div class="p-4 text-center border-bottom border-secondary">
                    <h4 class="fw-bold text-warning mb-0">BÁCH HÓA PEW</h4>
                    <div class="mt-2 small opacity-75">
                        <i class="fas fa-user-shield"></i> Quản trị viên<br>
                        <span style="font-size: 0.8em;">ID: ADMIN</span>
                    </div>
                </div>
                <div class="mt-3">
                    <a href="/admin/categories"><i class="fas fa-list me-2"></i> Danh Mục Gốc</a>
                    <a href="/admin/sub_categories"><i class="fas fa-tags me-2"></i> Thể Loại Con</a>
                    <a href="/admin/brands"><i class="fas fa-copyright me-2"></i> Hãng Sản Xuất</a>
                    <a href="/admin/products"><i class="fas fa-box me-2"></i> Sản Phẩm</a>
                    <a href="/admin/customers"><i class="fas fa-users me-2"></i> Khách Hàng</a>
                    <a href="/admin/orders" class="active"><i class="fas fa-file-invoice-dollar me-2"></i> Đơn Hàng</a>
                    <a href="/admin/reviews"><i class="fas fa-star me-2"></i> Đánh Giá</a>
                    <a href="/admin/contacts"><i class="fas fa-envelope me-2"></i> Liên Hệ</a>
                    <a href="/admin/reviews"><i class="fas fa-star me-2"></i> Đánh Giá</a>
                    <a href="/admin/promotions"><i class="fas fa-percent me-2"></i> Khuyến Mãi</a>
                    <a href="/admin/dashboard"><i class="fas fa-chart-line me-2"></i> Dashboard</a>
                    <a href="/logout" class="text-danger mt-5"><i class="fas fa-sign-out-alt me-2"></i> Đăng xuất</a>
                </div>
            </div>

            <div class="col-md-10 p-4 p-md-5">

                <div class="d-flex justify-content-between align-items-center mb-4 no-print">
                    <h2 class="fw-bold">Chi tiết Đơn Hàng #<span class="text-danger">
                            <%= order._id.toString().slice(-6).toUpperCase() %>
                        </span></h2>
                    <div>
                        <a href="/admin/orders" class="btn btn-secondary"><i class="fas fa-arrow-left"></i> Quay lại</a>
                        <button onclick="window.print()" class="btn btn-primary ms-2"><i class="fas fa-print"></i> In
                            Hóa Đơn</button>
                    </div>
                </div>

                <div id="print-area">
                    <div class="row mb-4">
                        <div class="col-md-6 mb-3 mb-md-0">
                            <div class="card shadow-sm border-0 h-100">
                                <div class="card-header bg-white fw-bold text-uppercase border-bottom-0 pt-4 pb-0">
                                    <i class="fas fa-user-circle me-2 text-success fs-5"></i>Thông tin khách hàng
                                </div>
                                <div class="card-body">
                                    <p class="mb-2"><strong>Họ và tên:</strong>
                                        <%= order.fullname %>
                                    </p>
                                    <p class="mb-2"><strong>Điện thoại:</strong>
                                        <%= order.phone %>
                                    </p>
                                    <p class="mb-0"><strong>Địa chỉ:</strong>
                                        <%= order.address %>
                                    </p>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="card shadow-sm border-0 h-100">
                                <div class="card-header bg-white fw-bold text-uppercase border-bottom-0 pt-4 pb-0">
                                    <i class="fas fa-info-circle me-2 text-primary fs-5"></i>Thông tin đơn hàng
                                </div>
                                <div class="card-body">
                                    <p class="mb-2"><strong>Ngày đặt:</strong>
                                        <%= order.createdAt.toLocaleString('vi-VN') %>
                                    </p>
                                    <p class="mb-2"><strong>Thanh toán:</strong> <span
                                            class="badge bg-light text-dark border">
                                            <%= order.payment_method %>
                                        </span></p>
                                    <p class="mb-0"><strong>Trạng thái:</strong>
                                        <% if(order.status==0) { %><span class="badge bg-secondary">Mới đặt</span>
                                            <% } %>
                                                <% if(order.status==1) { %><span class="badge bg-primary">Đang xử
                                                        lý</span>
                                                    <% } %>
                                                        <% if(order.status==2) { %><span
                                                                class="badge bg-warning text-dark">Đang giao</span>
                                                            <% } %>
                                                                <% if(order.status==3) { %><span
                                                                        class="badge bg-success">Hoàn thành</span>
                                                                    <% } %>
                                    </p>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="card shadow-sm border-0">
                        <div class="card-body p-0">
                            <div class="table-responsive">
                                <table class="table table-hover align-middle text-center mb-0">
                                    <thead class="table-light">
                                        <tr>
                                            <th width="5%">STT</th>
                                            <th width="15%">Hình ảnh</th>
                                            <th width="35%" class="text-start">Tên sản phẩm</th>
                                            <th width="15%">Đơn giá</th>
                                            <th width="10%">Số lượng</th>
                                            <th width="20%">Thành tiền</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <% if (order.items && order.items.length> 0) { %>
                                            <% order.items.forEach((item, index)=> { %>
                                                <tr>
                                                    <td>
                                                        <%= index + 1 %>
                                                    </td>
                                                    <td>
                                                        <% if (item.product_id && item.product_id.cover_image) { %>
                                                            <img src="/<%= item.product_id.cover_image %>" alt="Img"
                                                                class="product-img">
                                                            <% } else { %>
                                                                <span class="text-muted"><i
                                                                        class="fas fa-box fs-2 opacity-50"></i></span>
                                                                <% } %>
                                                    </td>
                                                    <td class="text-start fw-semibold">
                                                        <%= item.product_id ? item.product_id.name
                                                            : 'Sản phẩm đã bị xóa' %>
                                                    </td>
                                                    <td class="text-muted">
                                                        <%= item.price ? item.price.toLocaleString('vi-VN') : 0 %> đ
                                                    </td>
                                                    <td><strong>x<%= item.quantity %></strong></td>
                                                    <td class="fw-bold text-danger">
                                                        <%= (item.price * item.quantity).toLocaleString('vi-VN') %> đ
                                                    </td>
                                                </tr>
                                                <% }) %>
                                                    <% } else { %>
                                                        <tr>
                                                            <td colspan="6" class="py-5 text-muted">Không có sản phẩm
                                                                trong đơn hàng này.</td>
                                                        </tr>
                                                        <% } %>
                                    </tbody>
                                    <tfoot class="table-light">
                                        <tr>
                                            <td colspan="5" class="text-end fw-bold fs-5 pt-3 pb-3">TỔNG CỘNG:</td>
                                            <td class="text-danger fw-bold fs-4 pt-3 pb-3">
                                                <%= order.total_money.toLocaleString('vi-VN') %> đ
                                            </td>
                                        </tr>
                                    </tfoot>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>
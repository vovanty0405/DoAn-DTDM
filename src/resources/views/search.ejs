<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Tìm kiếm: <%= keyword %> - Bách Hóa Pew</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/style.css"> 
   <link href="http://127.0.0.1:3000/css/style.css" rel="stylesheet" />
<body>
    <!-- Header -->
    <header class="header-bg sticky-top">
        <div class="container">
            <nav class="navbar navbar-expand-lg navbar-dark py-3">
                <a class="navbar-brand fw-bold fs-3" href="/">Bách Hóa Pew</a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav mx-auto align-items-center">
                        <li class="nav-item">
                            <a class="nav-link active-yellow" href="/">Trang chủ</a>
                        </li>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" id="navbarDropdown" role="button" data-bs-toggle="dropdown">
                                Danh mục
                            </a>
                            <ul class="dropdown-menu custom-dropdown" aria-labelledby="navbarDropdown">
                                <% if (typeof categories !== 'undefined' && categories.length > 0) { %>
                                    <% categories.forEach(cat => { %>
                                        <li><a class="dropdown-item" href="/category/<%= cat.slug %>"><%= cat.name %></a></li>
                                    <% }) %>
                                <% } else { %>
                                    <li><a class="dropdown-item" href="#">Đang cập nhật...</a></li>
                                <% } %>
                            </ul>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="#">Về chúng tôi</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="#">Liện hệ</a>
                        </li>
                    </ul>

                    <ul class="navbar-nav align-items-center">
                        <% if (typeof user !== 'undefined' && user) { %>
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle fw-bold text-warning" href="#" data-bs-toggle="dropdown">
                                    <i class="fas fa-user-circle fs-5 me-1"></i> <%= user.fullname || user.full_name %>
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end border-0 shadow">
                                    <% if (user.role == 1) { %>
                                        <li><a class="dropdown-item fw-bold text-success" href="/admin/products"><i class="fas fa-shield-alt me-2"></i> Vào trang Admin</a></li>
                                        <li><hr class="dropdown-divider"></li>
                                    <% } %>
                                    <li><a class="dropdown-item" href="/orders"><i class="fas fa-box me-2"></i> Đơn hàng của tôi</a></li>
                                    <li><a class="dropdown-item text-danger" href="/logout"><i class="fas fa-sign-out-alt me-2"></i> Đăng xuất</a></li>
                                </ul>
                            </li>
                        <% } else { %>
                            <li class="nav-item">
                                <a class="nav-link" href="#" data-bs-toggle="modal" data-bs-target="#loginModal">Đăng nhập</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" href="#" data-bs-toggle="modal" data-bs-target="#registerModal">Đăng ký</a>
                            </li>
                        <% } %>
                        
                        <li class="nav-item ms-lg-2">
                            <a href="#" class="nav-link text-white" data-bs-toggle="modal" data-bs-target="#searchModal" title="Tìm kiếm">
                                <i class="fas fa-search fs-5"></i>
                            </a>
                        </li>

                        <li class="nav-item ms-lg-3 mt-2 mt-lg-0">
                            <a href="/cart" class="cart-icon position-relative text-white">
                                <i class="fas fa-shopping-cart fs-5"></i>
                                <span id="cart-badge" class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" style="font-size: 0.6rem;">
                                    <%= typeof cartCount !== 'undefined' ? cartCount : 0 %>
                                </span>
                            </a>
                        </li>
                    </ul>
                </div>
            </nav>
        </div>
    </header>
    <div class="container my-4" style="min-height: 60vh;">
        <div class="d-flex justify-content-between align-items-end border-bottom pb-3 mb-4">
            <h3 class="fw-bold m-0 text-dark">Kết quả tìm kiếm cho: <span class="text-success">"<%= keyword %>"</span></h3>
            <span class="text-muted fw-semibold small">Tìm thấy <%= products.length %> sản phẩm</span>
        </div>

        <div class="row">
            <% if (products && products.length > 0) { %>
                <% products.forEach(product => { %>
                    <div class="col-md-3 col-sm-6 mb-4">
                        <div class="card product-card h-100 border-0 shadow-sm position-relative">
                            <% if (product.discount_price) { %>
                                <% let percent = Math.round(((product.price - product.discount_price) / product.price) * 100); %>
                                <div class="badge-discount position-absolute top-0 end-0 m-2 bg-danger text-white px-2 py-1 rounded" style="z-index: 10;">
                                    -<%= percent %>%
                                </div>
                            <% } %>

                            <a href="/product/<%= product._id %>" class="text-decoration-none">
                                <div class="product-img-wrapper">
                                    <img src="/<%= product.cover_image %>" alt="<%= product.name %>" class="img-cover p-2 w-100" style="height: 200px; object-fit: contain;">
                                </div>
                            </a>

                            <div class="card-body text-center p-3">
                                <a href="/product/<%= product._id %>" class="text-decoration-none">
                                    <h6 class="card-title fw-bold text-dark text-truncate-2" style="min-height: 40px; font-size: 0.9rem;">
                                        <%= product.name %>
                                    </h6>
                                </a>

                                <% if (product.discount_price) { %>
                                    <div class="text-muted text-decoration-line-through small"><%= product.price.toLocaleString('vi-VN') %> đ</div>
                                    <div class="fw-bold text-danger mb-2 fs-5"><%= product.discount_price.toLocaleString('vi-VN') %> đ</div>
                                <% } else { %>
                                    <div class="text-muted small">&nbsp;</div>
                                    <div class="fw-bold text-danger mb-2 fs-5"><%= product.price.toLocaleString('vi-VN') %> đ</div>
                                <% } %>

                                <div class="mt-2">
                                    <a href="javascript:void(0);" onclick="addToCart('<%= product._id %>')" class="btn w-100 text-white fw-bold rounded-1" style="background-color: #005a3c;">
                                        Chọn mua
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                <% }) %>
            <% } else { %>
                <div class="col-12 text-center py-5">
                    <img src="https://cdn-icons-png.flaticon.com/512/6134/6134065.png" alt="Not found" width="120" class="mb-3 opacity-50">
                    <h5 class="text-muted">Rất tiếc, Bách Hóa Pew không tìm thấy sản phẩm nào phù hợp với từ khóa "<%= keyword %>".</h5>
                    <p class="text-muted small">Vui lòng thử lại bằng các từ khóa chung chung hơn (VD: Mì, Sữa, Nước...).</p>
                    <a href="/" class="btn btn-warning mt-2 fw-bold px-4">Về trang chủ</a>
                </div>
            <% } %>
        </div>
    </div>
    <!-- Footer -->
    <%- include('partials/footer') %>
    <!-- Modal -->
     <%- include('partials/modal') %>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        function addToCart(productId) {
            fetch(`/api/cart/add?id=${productId}`)
                .then(response => response.json())
                .then(data => {
                    if (data.status === 'success') {
                        let badge = document.getElementById('cart-badge');
                        badge.innerText = data.cart_count;
                    }
                })
                .catch(error => console.error('Lỗi thêm giỏ hàng:', error));
        }
    </script>
</body>
</html>